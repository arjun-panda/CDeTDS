    void LoadEmployees() => ApplyEmpSort(PayrollSvc.GetEmployees(AppState.CurrentDeductorId));

    void SortEmployees(string col)
    {
        if (_empSortCol == col) _empSortAsc = !_empSortAsc;
        else { _empSortCol = col; _empSortAsc = true; }
        ApplyEmpSort(_employees);
    }

    void ApplyEmpSort(List<Employee> list)
    {
        _employees = (_empSortCol switch {
            "Name"        => _empSortAsc ? list.OrderBy(e => e.Name)        : list.OrderByDescending(e => e.Name),
            "Designation" => _empSortAsc ? list.OrderBy(e => e.Designation) : list.OrderByDescending(e => e.Designation),
            "Department"  => _empSortAsc ? list.OrderBy(e => e.Department)  : list.OrderByDescending(e => e.Department),
            "PAN"         => _empSortAsc ? list.OrderBy(e => e.Pan)         : list.OrderByDescending(e => e.Pan),
            "DOJ"         => _empSortAsc ? list.OrderBy(e => e.JoinDate)    : list.OrderByDescending(e => e.JoinDate),
            "Status"      => _empSortAsc ? list.OrderBy(e => e.IsActive)    : list.OrderByDescending(e => e.IsActive),
            _             => _empSortAsc ? list.OrderBy(e => e.EmployeeCode): list.OrderByDescending(e => e.EmployeeCode),
        }).ToList();
    }

