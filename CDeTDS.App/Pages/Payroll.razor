            Phone          = emp.Phone,
            BankAccount    = emp.BankAccount,
            BankIfsc       = emp.BankIfsc,
            FlatDoorBlockNo        = emp.FlatDoorBlockNo,
            PremisesBuildingVillage= emp.PremisesBuildingVillage,
            RoadStreetPostOffice   = emp.RoadStreetPostOffice,
            AreaLocality           = emp.AreaLocality,
            TownCityDistrict       = emp.TownCityDistrict,
            State          = emp.State,
            PinCode        = emp.PinCode,
            TaxRegime      = emp.TaxRegime,
