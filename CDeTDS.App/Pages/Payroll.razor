            HraCityType            = string.IsNullOrEmpty(emp.HraCityType) ? "Non-Metro" : emp.HraCityType,
            DaForRetirement        = emp.DaForRetirement,
            IsDifferentlyAbled     = emp.IsDifferentlyAbled,
