    // Reimbursement tracker state — categories are now derived from each employee's Components
    private int _reimbEmpId;
    private Employee? _reimbEmp;
    private List<string> _reimbCategories = new();   // populated from employee's reimbursement Components
    private readonly (int m, string name)[] _reimbMonths = new[] {
        (4,"Apr"),(5,"May"),(6,"Jun"),(7,"Jul"),(8,"Aug"),(9,"Sep"),
        (10,"Oct"),(11,"Nov"),(12,"Dec"),(1,"Jan"),(2,"Feb"),(3,"Mar")
    };
    private Dictionary<string, CDeTDS.DAL.Models.ReimbursementClaim> _reimbGrid = new();

    void LoadReimbursements()
    {
        _reimbGrid.Clear();
        _reimbCategories = new();
        if (_reimbEmpId == 0) { _reimbEmp = null; return; }
        _reimbEmp = _employees.FirstOrDefault(e => e.Id == _reimbEmpId);
        if (_reimbEmp?.Salary == null) return;

        // Categories = names of reimbursement-type Components defined on this employee
        var reimbComps = _reimbEmp.Salary.Components
            .Where(c => c.Category == "reimbursement" && c.Received > 0)
            .ToList();
        _reimbCategories = reimbComps.Select(c => c.Name).ToList();
        if (_reimbCategories.Count == 0) return;     // nothing to track

        int fyStart = TaxRules.FyStartYear(AppState.CurrentFY);
        var repo = new CDeTDS.DAL.ReimbursementRepository();
        var existing = repo.GetForFy(_reimbEmpId, AppState.CurrentFY)
                           .ToDictionary(c => $"{c.Month}_{c.Category}", c => c);

        foreach (var (m, _) in _reimbMonths)
        {
            int yr = m >= 4 ? fyStart : fyStart + 1;
            foreach (var cat in _reimbCategories)
            {
                var key = $"{m}_{cat}";
                if (existing.TryGetValue(key, out var c))
                {
                    _reimbGrid[key] = c;
                }
                else
                {
                    double eligible = reimbComps.First(rc => rc.Name == cat).Received;
                    _reimbGrid[key] = new CDeTDS.DAL.Models.ReimbursementClaim
                    {
                        EmployeeId = _reimbEmpId, FinancialYear = AppState.CurrentFY,
                        Month = m, Year = yr, Category = cat, Eligible = eligible,
                        Claimed = 0, BillCount = 0, Status = "pending"
                    };
                }
            }
        }
    }

    void SaveReimbClaim(CDeTDS.DAL.Models.ReimbursementClaim c)
    {
        new CDeTDS.DAL.ReimbursementRepository().Save(c);
        Snackbar.Add($"Saved {c.Category} for month {c.Month}.", Severity.Success);
    }

    void SaveAllReimbClaims()
    {
        var repo = new CDeTDS.DAL.ReimbursementRepository();
        int saved = 0;
        foreach (var c in _reimbGrid.Values)
            if (c.Claimed > 0 || c.Status != "pending") { repo.Save(c); saved++; }
        Snackbar.Add($"Saved {saved} reimbursement claim(s).", Severity.Success);
    }

    // CTC Auto-Breakup dialog state
    private bool   _showCtcDialog;
    private double _ctcMonthlyInput;
    private string _ctcCityType = "Non-Metro";
    private string _ctcRegime   = "New";
    private double _ctcRent;
    private bool   _ctcNps;
    private string _ctcPfMode = "Capped";  // Full / Capped / None
    private bool   _ctcGratuity = true;
    private string _ctcError = "";
    private double _ctcBasicPct = 0; // 0 = auto-optimize; >0 = user-specified (e.g. 0.40 = 40%)
    private CDeTDS.BLL.SalaryOptimizerResult? _ctcResult;

    void OpenCtcBreakup()
    {
        if (_editingEmployee == null) return;
        _ctcCityType     = string.IsNullOrEmpty(_editingEmployee.HraCityType) ? "Non-Metro" : _editingEmployee.HraCityType;
        _ctcRegime       = string.IsNullOrEmpty(_editingEmployee.TaxRegime)   ? "New"       : _editingEmployee.TaxRegime;
        _ctcMonthlyInput = _editingEmployee.Salary?.GrossSalary ?? 0;
        _ctcRent         = 0;
        _ctcNps          = false;
        _ctcPfMode       = "Capped";
        _ctcGratuity     = _editingEmployee.Salary?.IncludeGratuity ?? true;
        _ctcBasicPct     = 0;
        _ctcResult       = null;
        _ctcError        = "";
        _showCtcDialog   = true;
    }

    void ComputeCtcBreakup()
    {
        _ctcError = "";
        if (_ctcMonthlyInput <= 0) { _ctcError = "Enter a valid monthly CTC."; return; }
        _ctcResult = CDeTDS.BLL.SalaryOptimizer.Optimize(new CDeTDS.BLL.SalaryOptimizerInput
        {
            MonthlyCtc          = _ctcMonthlyInput,
            Regime              = _ctcRegime,
            HraCityType         = _ctcCityType,
            MonthlyRentDeclared = _ctcRent,
            EmployerOffersNps   = _ctcNps,
            PfMode              = _ctcPfMode,
            IncludeGratuity     = _ctcGratuity,
            FinancialYear       = AppState.CurrentFY,
            DateOfBirth         = _editingEmployee?.DateOfBirth ?? "",
            FixedBasicPct       = _ctcBasicPct > 0 ? _ctcBasicPct / 100.0 : 0,
        });
    }

    void ApplyCtcBreakup()
    {
        if (_ctcResult == null || _editingEmployee?.Salary == null) return;
        _editingEmployee.Salary.TargetCtc        = _ctcMonthlyInput;   // anchors Special auto-balance
        _editingEmployee.Salary.IncludeGratuity  = _ctcGratuity;
        _editingEmployee.Salary.Basic            = _ctcResult.MonthlyBasic;
        _editingEmployee.Salary.Hra              = _ctcResult.MonthlyHra;
        _editingEmployee.Salary.SpecialAllowance = _ctcResult.MonthlySpecial;
        _editingEmployee.Salary.PfApplicable     = _ctcPfMode != "None";
        _editingEmployee.Salary.PfFixedAmount    = _ctcPfMode == "Capped" ? 1800 : 0;
        _editingEmployee.HraCityType             = _ctcCityType;
        _editingEmployee.TaxRegime               = _ctcRegime;
        // Legacy columns no longer written — Components is the single source for reimb/variable/employer-NPS.
        _editingEmployee.Salary.ReimbTelephone = 0; _editingEmployee.Salary.ReimbFuel = 0;
        _editingEmployee.Salary.ReimbBooks = 0; _editingEmployee.Salary.ReimbMeal = 0; _editingEmployee.Salary.ReimbUniform = 0;
        _editingEmployee.Salary.AnnualBonus = 0; _editingEmployee.Salary.AnnualIncentive = 0;

        // OtherAllowance is a mirror of Components — keep zero, Components define it.
        _editingEmployee.Salary.OtherAllowance = 0;
        _editingEmployee.Salary.Components.Clear();

        // LTA — use optimizer-computed value (already carved out of Special in the split)
        _editingEmployee.Salary.Lta = _ctcResult.MonthlyLta;

        // Reimbursement Components (Telephone / Meal)
        if (_ctcResult.MonthlyTelephone > 0)
            _editingEmployee.Salary.Components.Add(new SalaryComponent {
                Category = "reimbursement", Name = "Telephone / Internet",
                Received = _ctcResult.MonthlyTelephone, Paid = _ctcResult.MonthlyTelephone, Taxable = 0,
                RuleRef = "Exempt against bills"
            });
        if (_ctcResult.MonthlyMeal > 0)
            _editingEmployee.Salary.Components.Add(new SalaryComponent {
                Category = "reimbursement", Name = "Meal Coupons",
                Received = _ctcResult.MonthlyMeal, Paid = _ctcResult.MonthlyMeal, Taxable = 0,
                RuleRef = "Sec 17(2) ₹50/meal"
            });
        // Employer NPS — saved to salary structure so payroll runs use it
        _editingEmployee.Salary.EmployerNps = _ctcResult.MonthlyNpsEmployer;
        _empHraAuto = true;
        _showCtcDialog = false;
        Snackbar.Add($"Salary structure filled — saves ₹{_ctcResult.AnnualSavings:N0}/year vs naive split.", Severity.Success);
    }

    /// <summary>
    /// On Edit: convert legacy rigid Reimb*/Annual* columns into Components if
    /// they have values but no matching Component exists yet. Lossless — clears
    /// the legacy columns after migration so they don't double-count.
    /// </summary>
    private void MigrateLegacyToComponents()
    {
        if (_editingEmployee?.Salary == null) return;
        var ss = _editingEmployee.Salary;
        void Add(string cat, string name, double recv, double paid, string rule)
        {
            if (recv <= 0) return;
            if (ss.Components.Any(c => c.Name == name && c.Category == cat)) return;
            ss.Components.Add(new SalaryComponent {
                Category = cat, Name = name,
                Received = recv, Paid = paid,
                Taxable = Math.Max(0, recv - paid), RuleRef = rule
            });
        }
        Add("reimbursement", "Telephone / Internet", ss.ReimbTelephone, ss.ReimbTelephone, "Exempt against bills");
        Add("reimbursement", "Fuel / Car",           ss.ReimbFuel,      ss.ReimbFuel,      "Exempt against bills");
        Add("reimbursement", "Books & Periodicals",  ss.ReimbBooks,     ss.ReimbBooks,     "Exempt against bills");
        Add("reimbursement", "Meal Coupons",         ss.ReimbMeal,      ss.ReimbMeal,      "Sec 17(2) ₹50/meal");
        Add("reimbursement", "Uniform Allowance",    ss.ReimbUniform,   ss.ReimbUniform,   "Exempt against bills");
        // Annual variable pay → component (monthly = annual/12)
        if (ss.AnnualBonus > 0)
            Add("variable", "Performance Bonus", Math.Round(ss.AnnualBonus / 12.0), 0, "Annual lump-sum");
        if (ss.AnnualIncentive > 0)
            Add("variable", "Sales / Incentive", Math.Round(ss.AnnualIncentive / 12.0), 0, "Annual lump-sum");
        // Migrate legacy OtherAllowance standalone → first allowance Component (only if no Components exist).
        // Lta stays standalone (dedicated field, NOT a Component).
        if (ss.OtherAllowance > 0 && !ss.Components.Any())
        {
            Add("allowance", "Other Allowance", ss.OtherAllowance, 0, "");
        }
        // Clear legacy values so they don't double-count via GrossSalary computed properties
        ss.ReimbTelephone = 0; ss.ReimbFuel = 0; ss.ReimbBooks = 0; ss.ReimbMeal = 0; ss.ReimbUniform = 0;
        ss.AnnualBonus = 0; ss.AnnualIncentive = 0;
        ss.OtherAllowance = 0;   // mirror only; Components carry the value
    }

