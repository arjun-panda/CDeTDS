    protected override void OnInitialized()
    {
        LoadEmployees();
        var now = DateTime.Today;
        _runYear   = now.Year;
        _slipMonth = now.Month;
        _slipYear  = now.Year;
        LoadSavedRuns();
        _sdMonth   = now.Month;
        RefreshSdEmpStatus();

        var fy = AppState.CurrentFY;
        if (fy.Length >= 4 && int.TryParse(fy[..4], out var fyStart))
            _runYears = new[] { fyStart, fyStart + 1 };
        else
            _runYears = new[] { now.Year };
