    void OpenEditEmployee(Employee emp)
    {
        _empDob          = DateTime.TryParse(emp.DateOfBirth, out var dob)   ? dob   : null;
        _empJoin         = DateTime.TryParse(emp.JoinDate,    out var join)  ? join  : null;
        _empLeave        = DateTime.TryParse(emp.LeavingDate, out var leave) ? leave : null;
        _empSalEffective = DateTime.TryParse(emp.Salary?.EffectiveFrom, out var eff) ? eff : null;
        // Restore named allowances from saved OtherAllowance total
        // Detect old-data rows: special/medical/lta all 0 but other_allowance is large —
        // could be the pre-migration combined sum. Flag for user review.
        bool hasOldCombined = emp.Salary != null
            && emp.Salary.SpecialAllowance == 0 && emp.Salary.MedicalAllowance == 0
            && emp.Salary.Lta == 0 && emp.Salary.OtherAllowance > 0;
        _salaryStructureNeedsReview = hasOldCombined;
        _empGratuityFrom = ""; _empNomineeName = ""; _empNomineeRelation = "";
        _editingEmployee = new Employee
        {
            Id             = emp.Id,
            DeductorId     = emp.DeductorId,
            EmployeeCode   = emp.EmployeeCode,
            Name           = emp.Name,
            FathersName    = emp.FathersName,
            Sex            = emp.Sex,
            DateOfBirth    = NormDate(emp.DateOfBirth),
