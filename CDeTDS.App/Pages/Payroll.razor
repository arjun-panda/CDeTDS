    private bool _tabLoading = false;

    async void OnTabChanged(int index)
    {
        _tabLoading = true;
        StateHasChanged();
        await Task.Yield(); // allow spinner to render

        try
        {
            // Tab 1 = Salary Data — reload from DB so Monthly Run results are always visible
            if (index == 1 && _sdEmpId > 0 && _sdMonth > 0)
            {
                SelectSdMonth(_sdMonth);
                RefreshSdMonthStrip();
            }
            // Tab 3 = Salary Slips — sync month to current Salary Data month and reload
            if (index == 3)
            {
                if (_sdMonth > 0) _slipMonth = _sdMonth;
                LoadSavedRuns();
            }
        }
        finally
        {
            _tabLoading = false;
            StateHasChanged();
        }
    }

    void OnSdEmployeeChanged(int empId)
    {
        _sdEmpId = empId;
        _sdAnnual = null;
        _sdHraAuto = true;   // reset auto-HRA flag on employee switch
        if (empId == 0) return;   // keep _sdMonth so toolbar stays in sync
        // Reload employees so salary structure is always fresh from DB
        LoadEmployees();
        var emp = _employees.FirstOrDefault(e => e.Id == empId);
        if (emp != null)
        {
            _sdHraCity = string.IsNullOrEmpty(emp.HraCityType) ? "Non-Metro" : emp.HraCityType;
            _sdHraPct  = _sdHraCity.Equals("Metro", StringComparison.OrdinalIgnoreCase) ? 50 : 40;
        }
        RefreshSdMonthStrip();
        // Reload detail for the currently-selected month (don't force jump to today)
        if (_sdMonth == 0) _sdMonth = DateTime.Today.Month;
        SelectSdMonth(_sdMonth);
    }

    void RefreshSdMonthStrip()
    {
        if (_sdEmpId == 0) return;
        var saved = SalarySvc.GetAllForFY(_sdEmpId, AppState.CurrentFY);
        for (int i = 0; i < _fyMonths.Length; i++)
            _sdMonthHasData[i] = saved.Any(e => e.Month == _fyMonths[i]);
    }

