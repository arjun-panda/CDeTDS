    void RemoveLandlord(LandlordRecord lr)
    {
        if (lr.Id > 0) PayrollSvc.DeleteLandlord(lr.Id);
        _decl!.Landlords.Remove(lr);
        SyncRentPaidFromLandlords();
        PayrollSvc.SaveDeclaration(_decl!);
    }

    void SaveLandlord(LandlordRecord lr)
    {
        lr.Pan = (lr.Pan ?? "").ToUpperInvariant();
        PayrollSvc.SaveLandlord(lr);
        SyncRentPaidFromLandlords();
        PayrollSvc.SaveDeclaration(_decl!);
        Snackbar.Add("Landlord saved.", Severity.Success);
    }

    void SyncRentPaidFromLandlords()
    {
        if (_decl == null) return;
        double total = _decl.Landlords.Sum(l => l.AnnualRent);
        if (total > 0) _decl.RentPaid = total;
        var dominant = _decl.Landlords.OrderByDescending(l => l.AnnualRent).FirstOrDefault();
        if (dominant != null && !string.IsNullOrEmpty(dominant.CityType))
            _decl.HraCityType = dominant.CityType;
        else if (dominant == null)
            _decl.HraCityType = "Non-Metro";
    }

    void SaveDeclaration()
    {
        if (_decl == null) return;
        PayrollSvc.SaveDeclaration(_decl);
        Snackbar.Add("Declaration saved.", Severity.Success);
    }

