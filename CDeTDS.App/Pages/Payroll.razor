    }


    void DownloadAnnual(EmployeeYearSummary summary, bool html)
    {
        try
        {
            var emp = _employees.FirstOrDefault(e => e.Id == summary.EmployeeId)
                      ?? new Employee { Id = summary.EmployeeId, EmployeeCode = summary.EmployeeCode, Name = summary.EmployeeName };
            var ded = DeductorSvc.GetAll().FirstOrDefault(d => d.Id == AppState.CurrentDeductorId) ?? new Deductor();

            var entries = SalarySvc.GetAllForFY(summary.EmployeeId, AppState.CurrentFY);
            if (!entries.Any()) { Snackbar.Add("No salary entries found for this employee in this FY.", Severity.Warning); return; }

            // Use latest month's entry as basis for annual computation
            var latest = entries.OrderByDescending(e => e.Month == 3 ? 15 : e.Month).First();
            latest.EmployeeName = emp.Name; latest.Pan = emp.Pan;
            AnnualComputation annual;
            try
            {
                var decl = PayrollSvc.GetDeclaration(emp.Id, AppState.CurrentFY)
                           ?? new TaxDeclaration { EmployeeId = emp.Id, FinancialYear = AppState.CurrentFY };
                annual = SalarySvc.ComputeMonth(latest, emp, AppState.CurrentFY, decl);
            }
            catch { annual = new AnnualComputation(); }

            var folder = FolderManager.SalarySlipsForFyFolder(AppState.CurrentFY);
            Directory.CreateDirectory(folder);
            var path = html
                ? SalarySlipExport.GenerateAnnualHtml(annual, emp, AppState.CurrentFY, folder, ded, summary)
                : SalarySlipExport.GenerateAnnualExcel(annual, emp, AppState.CurrentFY, folder, ded, summary);
            FolderManager.OpenFolder(Path.GetDirectoryName(path)!);
            Snackbar.Add($"Saved: {Path.GetFileName(path)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
    }

