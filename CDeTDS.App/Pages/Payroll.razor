    void BulkLopChanged(MonthlyCloseRow row, string? val)
    {
        if (!int.TryParse(val, out var d)) return;
        d = Math.Max(0, Math.Min(d, 30));
        row.LopDays    = d;
        row.DaysWorked = 30 - d;
        row.Status     = row.DaysWorked == 0 ? "Skip" : "Draft";
        var savedTds   = row.TdsManualOverride ? row.Tds : -1;
        try { McSvc.Compute(row, AppState.CurrentDeductorId); } catch { }
        if (savedTds >= 0) { row.Tds = savedTds; row.NetPay = row.Gross - row.Pf - row.Esi - row.Recovery - row.Tds; }
        StateHasChanged();
    }

    void BulkTdsChanged(MonthlyCloseRow row, string? val)
    {
        if (!double.TryParse(val, out var t)) return;
        t = Math.Max(0, t);
        row.Tds              = t;
        row.TdsManualOverride = true;
        row.NetPay           = row.Gross - row.Pf - row.Esi - row.Recovery - row.Tds;
        StateHasChanged();
    }

    async Task BulkSaveAndLock()
    {
        if (AppState.IsReadOnlyFY) { Snackbar.Add("FY is read-only.", Severity.Warning); return; }
        _sdBulkBusy = true; _sdBulkMsg = "Saving..."; StateHasChanged();
        int ok = 0, failed = 0;
        var failures = new List<string>();
        var toProcess = _bulkRows
            .Where(r => _sdBulkSel.TryGetValue(r.EmployeeId, out var v) && v)
            .ToList();
        await Task.Run(() => {
            // Pre-load once to avoid N+1 queries inside the loop.
            var empCache = PayrollSvc.GetEmployees(AppState.CurrentDeductorId)
                               as IReadOnlyList<CDeTDS.DAL.Models.Employee>;
            foreach (var r in toProcess)
            {
                try
                {
                    if (r.Status != "Skip" && !r.TdsManualOverride) McSvc.Compute(r, AppState.CurrentDeductorId);
                    McSvc.SaveAndSync(r, AppState.CurrentDeductorId, empCache);
                    ok++;
                }
                catch (Exception ex) { failed++; failures.Add($"{r.EmployeeName}: {ex.Message}"); }
            }
        });
        _sdBulkBusy = false;
        _sdBulkMsg  = failed > 0 ? $"Saved {ok} · {failed} failed." : $"Saved {ok} employee(s).";
        if (failures.Any())
            _sdBulkMsg += " — " + string.Join("; ", failures.Take(3));
        AppState.NotifyStateChanged();
        LoadBulkGrid();
        RefreshSdEmpStatus();
        LoadSavedRuns();
        if (_sdEmpId > 0) SelectSdMonth(_sdMonth);
        Snackbar.Add(_sdBulkMsg, failed > 0 ? Severity.Warning : Severity.Success);
    }

    void BulkClose()
    {
        _sdBulkEdit = false;
        _sdBulkOpen = false;
        RefreshSdEmpStatus();
        if (_sdEmpId > 0) SelectSdMonth(_sdMonth);
    }

    void RefreshSdEmpStatus()
    {
        _sdEmpStatus.Clear();
        if (_sdMonth == 0) return;
        foreach (var emp in _employees.Where(e => e.IsActive))
        {
            var e = SalarySvc.Get(emp.Id, AppState.CurrentFY, _sdMonth);
            if (e == null) { _sdEmpStatus[emp.Id] = "None"; continue; }
            _sdEmpStatus[emp.Id] = string.IsNullOrEmpty(e.Status) ? "Draft" : e.Status;
        }
    }

    void SelectSdMonth(int month, bool forceSeed = false)
    {
        _sdMonth = month;
        _sdAnnual = null;
        RefreshSdEmpStatus();
        if (_sdEmpId == 0) return;
        int fyStart = TaxRules.FyStartYear(AppState.CurrentFY);
        int yr = month >= 4 ? fyStart : fyStart + 1;
        _sdCurEntry = forceSeed ? null : SalarySvc.Get(_sdEmpId, AppState.CurrentFY, month);
        // Defensive: if saved entry is effectively empty (likely an accidental zero-save and NOT a deliberate
        // Skip status), fall through to the seed branch so user sees the structure values.
        if (_sdCurEntry != null && _sdCurEntry.Status != "Skip"
            && _sdCurEntry.Basic == 0 && _sdCurEntry.HRA == 0 && _sdCurEntry.SpecialAllowance == 0
            && _sdCurEntry.Lta == 0 && _sdCurEntry.OtherAllowances == 0
            && _sdCurEntry.TdsDeducted == 0 && _sdCurEntry.PerqExempted == 0
            && (_sdCurEntry.LineItems == null || _sdCurEntry.LineItems.Count == 0))
        {
            _sdCurEntry = null;
        }
        MonthlySalaryEntry e;
        // Always reload employee fresh from DB so seed values reflect latest salary structure
        // (defends against stale _employees cache when Section 5 was edited but tab not switched)
        var seedEmp = _employees.FirstOrDefault(x => x.Id == _sdEmpId);
        if (seedEmp?.Salary == null || seedEmp.Salary.Basic == 0)
        {
            LoadEmployees();
            seedEmp = _employees.FirstOrDefault(x => x.Id == _sdEmpId);
        }
        var seedSs  = seedEmp?.Salary;
        // ── Determine field sources ──────────────────────────────────────────
        // Locked entry  → everything from saved entry (preserves approved figures).
        // Saved entry → structure fields from seedSs (always fresh); month-specific
        //              fields (Bonus, Arrears, LOP, TDS, LineItems, Perqs, LeaveEnc)
        //              from saved entry so user edits are not lost.
        // No saved entry → seed everything from salary structure.
        bool useStructure = !forceSeed && _sdCurEntry != null && seedSs != null;
        bool useSaved     = _sdCurEntry != null;

        if (seedSs != null)
        {
            // Unlocked or fresh: structure fields always come from seedSs
            e = new MonthlySalaryEntry
            {
                // ── Structure fields (always fresh from salary structure) ──
                Basic            = seedSs.Basic,
                HRA              = seedSs.Hra,
                DaAmount         = seedSs.Da,
                SpecialAllowance = seedSs.SpecialAllowance,
                MedicalAllowance = seedSs.MedicalAllowance,
                Lta              = seedSs.Lta,
                OtherAllowances  = seedSs.OtherAllowance,
                NpsEmployer      = seedSs.EmployerNps,
                PfEmployee       = (seedSs.PfFixedAmount > 0 || seedSs.PfApplicable)
                                   ? (seedSs.PfFixedAmount > 0 ? seedSs.PfFixedAmount : Math.Round(seedSs.Basic * 0.12))
                                   : 0,
                EsiEmployee      = seedSs.EsiApplicable && seedSs.GrossSalary <= 21000
                                   ? Math.Round(seedSs.GrossSalary * 0.0075) : 0,
                ProfessionalTax  = PayrollService.GetPtPublic(seedSs.PtState, seedSs.GrossSalary),
                // ── Month-specific fields: from saved entry if exists, else zero ──
                Bonus            = useSaved ? _sdCurEntry!.Bonus         : 0,
                Commission       = useSaved ? _sdCurEntry!.Commission    : 0,
                AdvanceSalary    = useSaved ? _sdCurEntry!.AdvanceSalary : 0,
                Arrears          = useSaved ? _sdCurEntry!.Arrears       : 0,
                LopDays          = useSaved ? _sdCurEntry!.LopDays       : 0,
                TdsDeducted      = useSaved ? _sdCurEntry!.TdsDeducted   : 0,
                TaxComputed      = useSaved ? _sdCurEntry!.TaxComputed   : 0,
                VPF              = useSaved ? _sdCurEntry!.VPF           : 0,
                PerqTotal        = useSaved ? _sdCurEntry!.PerqTotal     : 0,
                PerqExempted     = useSaved ? _sdCurEntry!.PerqExempted  : 0,
                LeaveEncTotal    = useSaved ? _sdCurEntry!.LeaveEncTotal    : 0,
                LeaveEncExempted = useSaved ? _sdCurEntry!.LeaveEncExempted : 0,
            };
            // Line items: from saved entry if exists (preserves perq/reimb edits);
            // else seed from salary structure components
            if (useSaved && _sdCurEntry!.LineItems?.Count > 0)
            {
                e.LineItems = _sdCurEntry!.LineItems;
            }
            else
            {
                foreach (var c in seedSs.Components)
                {
                    if (c.Received <= 0 || c.Category == "variable") continue;
                    var cat = c.Category == "perquisite" ? "perq" : "other";
                    e.LineItems.Add(new SalaryLineItem {
                        Category = cat, Name = c.Name,
                        Taxable  = Math.Max(0, c.Received - c.Paid),
                        Exempt   = c.Paid, RuleRef = c.RuleRef
                    });
                }
            }
        }
        else
        {
            // No salary structure at all — use saved entry or empty
            e = _sdCurEntry ?? new MonthlySalaryEntry();
        }

        // ── Populate UI fields ───────────────────────────────────────────────
        _sdBasic = e.Basic; _sdGradePay = e.GradePay; _sdHra = e.HRA; _sdDaAmt = e.DaAmount;
        var autoHra = Math.Round(_sdBasic * _sdHraPct / 100.0);
        _sdHraAuto = Math.Abs(_sdHra - autoHra) <= 1;
        _sdSpecial = e.SpecialAllowance; _sdLta = e.Lta;
        _sdLtaTaxable = _sdLta; _sdLtaExempt = 0;
        _sdPerqLines.Clear(); _sdOtherLines.Clear();
        _sdVarEarnRows = new();
        _sdVarDedRows  = new();
        foreach (var li in e.LineItems ?? new List<CDeTDS.DAL.Models.SalaryLineItem>())
        {
            if (li.Category == "perq")
                _sdPerqLines.Add((li.Name, li.Taxable, li.Exempt, li.RuleRef));
            else if (li.Category == "other")
                _sdOtherLines.Add((li.Name, li.Taxable, li.Exempt, li.RuleRef));
            else if (li.Category == "varEarn")
                _sdVarEarnRows.Add((li.Name, li.RuleRef, li.Taxable));
            else if (li.Category == "varDed")
                _sdVarDedRows.Add((li.Name, li.Taxable));
        }
        _sdBonus = e.Bonus; _sdCommission = e.Commission; _sdAdvance = e.AdvanceSalary;
        var _otherLinesSum = _sdOtherLines.Sum(l => l.Taxable + l.Exempt);
        var _varEarnSum    = _sdVarEarnRows.Where(r => !string.Equals(r.Type, "Exempt", StringComparison.OrdinalIgnoreCase)).Sum(r => r.Amount);
        _sdArrears = e.Arrears; _sdOther = Math.Max(0, e.OtherAllowances - _otherLinesSum - _varEarnSum); _sdNpsEmployer = e.NpsEmployer;
        _sdPerqTotal = e.PerqTotal; _sdPerqExempted = e.PerqExempted;
        _sdLeaveEnc = e.LeaveEncTotal; _sdLeaveEncEx = e.LeaveEncExempted;
        _sdPf = e.PfEmployee; _sdVpf = e.VPF; _sdPt = e.ProfessionalTax;
        _sdEsi = e.EsiEmployee;
        _sdTds = e.TdsDeducted;
        _sdLopDays = e.LopDays;
        LoadSchedules();
        // Auto-seed varDed from due schedules (only for unlocked months, skips already-loaded rows)
        if (e.IsLocked == false) SeedScheduledVarDeds();
        if (_sdEmpId > 0 && _sdMonth > 0)
            _ = SdCompute();
    }

    MonthlySalaryEntry BuildSdEntry()
    {
        int fyStart = TaxRules.FyStartYear(AppState.CurrentFY);
        int yr = _sdMonth >= 4 ? fyStart : fyStart + 1;
        var emp = _employees.FirstOrDefault(e => e.Id == _sdEmpId) ?? new Employee();

        // varEarn rows are saved as line items (not folded into OtherAllowances)
        var varEarnTaxable   = _sdVarEarnRows
            .Where(r => !string.Equals(r.Type, "Exempt", StringComparison.OrdinalIgnoreCase))
            .Sum(r => r.Amount);
        var otherLinesTotal  = _sdOtherLines.Sum(l => l.Taxable + l.Exempt);
        var otherLinesExempt = _sdOtherLines.Sum(l => l.Exempt);
        var perqLinesTotal   = _sdPerqLines.Sum(l => l.Taxable + l.Exempt);
        var perqLinesExempt  = _sdPerqLines.Sum(l => l.Exempt);
        var entry = new MonthlySalaryEntry
        {
            Id = _sdCurEntry?.Id ?? 0,
            EmployeeId = _sdEmpId, DeductorId = AppState.CurrentDeductorId, EmployeeName = emp.Name, Pan = emp.Pan,
            Month = _sdMonth, Year = yr, FinancialYear = AppState.CurrentFY,
            Basic = _sdBasic, GradePay = _sdGradePay, HRA = _sdHra, DaAmount = _sdDaAmt,
            SpecialAllowance = _sdSpecial, MedicalAllowance = 0, Lta = _sdLta,
            Bonus = _sdBonus, Commission = _sdCommission, AdvanceSalary = _sdAdvance,
            Arrears = _sdArrears, OtherAllowances = _sdOther + varEarnTaxable + otherLinesTotal, NpsEmployer = _sdNpsEmployer,
            PerqTotal = perqLinesTotal,
            PerqExempted = otherLinesExempt + perqLinesExempt,
            LeaveEncTotal = _sdLeaveEnc, LeaveEncExempted = _sdLeaveEncEx,
            PfEmployee = _sdPf, VPF = _sdVpf, ProfessionalTax = _sdPt,
            EsiEmployee = _sdEsi, TdsDeducted = _sdTds, TaxComputed = _sdTds,
            DaysWorked  = 30 - _sdLopDays,
            LopDays     = _sdLopDays,
            WorkingDays = _sdCurEntry?.WorkingDays > 0 ? _sdCurEntry.WorkingDays : 30,
            IsLocked    = _sdCurEntry?.IsLocked    ?? false,
            ApprovedAt  = _sdCurEntry?.ApprovedAt  ?? "",
            ApprovedBy  = _sdCurEntry?.ApprovedBy  ?? "",
        };
        foreach (var ln in _sdOtherLines)
            entry.LineItems.Add(new CDeTDS.DAL.Models.SalaryLineItem { Category = "other",   Name = ln.Name, Taxable = ln.Taxable, Exempt = ln.Exempt, RuleRef = ln.Rule });
        foreach (var ln in _sdPerqLines)
            entry.LineItems.Add(new CDeTDS.DAL.Models.SalaryLineItem { Category = "perq",    Name = ln.Name, Taxable = ln.Taxable, Exempt = ln.Exempt, RuleRef = ln.Rule });
        foreach (var ln in _sdVarEarnRows)
            entry.LineItems.Add(new CDeTDS.DAL.Models.SalaryLineItem { Category = "varEarn", Name = ln.Name, Taxable = ln.Amount, RuleRef = ln.Type });
        foreach (var ln in _sdVarDedRows)
            entry.LineItems.Add(new CDeTDS.DAL.Models.SalaryLineItem { Category = "varDed",  Name = ln.Name, Taxable = ln.Amount });
        return entry;
    }

    async Task SdCompute()
    {
        if (_sdEmpId == 0 || _sdMonth == 0) return;
        while (_sdComputing) await Task.Delay(50); // wait if already running
        _sdComputing = true;
        StateHasChanged();
        try
        {
            var entry = BuildSdEntry();
            var emp   = _employees.FirstOrDefault(e => e.Id == _sdEmpId) ?? new Employee();
            var decl  = PayrollSvc.GetDeclaration(_sdEmpId, AppState.CurrentFY)
                        ?? new TaxDeclaration { EmployeeId = _sdEmpId, FinancialYear = AppState.CurrentFY };
            _sdAnnual = await Task.Run(() => SalarySvc.ComputeMonth(entry, emp, AppState.CurrentFY, decl));
        }
        catch (Exception ex) { Snackbar.Add("Compute error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
        _sdComputing = false;
        StateHasChanged();
    }

    async Task SdResetFromStructure()
    {
        if (_sdEmpId == 0 || _sdMonth == 0) { Snackbar.Add("Select an employee and month.", Severity.Warning); return; }
        var dbReset = SalarySvc.Get(_sdEmpId, AppState.CurrentFY, _sdMonth);
        var confirmed = await DialogSvc.ShowMessageBox(
            "Reset month from Salary Structure?",
            $"This will discard the saved {new DateTime(1, _sdMonth, 1):MMMM} entry and re-seed all fields from the employee's current salary structure. Useful when an earlier accidental save left the month blank/zero.",
            yesText: "Reset", cancelText: "Cancel");
        if (confirmed != true) return;
        // Clear in-memory current entry and re-run SelectSdMonth — it will fall into the seed branch
        // Force the seed branch so saved zero-row is ignored
        SelectSdMonth(_sdMonth, forceSeed: true);
        // Auto-persist so switching employees doesn't lose the reseed
        try
        {
            var newEntry = BuildSdEntry();
            newEntry.RecalcGross();
            SalarySvc.Save(newEntry);
            _sdCurEntry = newEntry;
            RefreshSdMonthStrip();
            RefreshSdEmpStatus();
            Snackbar.Add($"♻ Reset {new DateTime(1, _sdMonth, 1):MMMM} from salary structure and saved.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Reset succeeded but save failed: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
    }

    void SdSaveMonth()
    {
        if (_sdEmpId == 0) { Snackbar.Add("Select an employee first.", Severity.Warning); return; }
        if (_sdMonth == 0) { Snackbar.Add("Select a month first.", Severity.Warning); return; }
        try
        {
            var entry = BuildSdEntry();
            entry.RecalcGross();
            var emp = _employees.FirstOrDefault(e => e.Id == _sdEmpId);
            if (emp == null) { Snackbar.Add("Employee not found.", Severity.Error); return; }
            var (ok, msg) = McSvc.SaveAndSync(entry, emp, AppState.CurrentDeductorId);
            _sdCurEntry = entry;
            if (!ok) Snackbar.Add($"Sec 192 warning: {msg}", Severity.Warning);
            AppState.NotifyStateChanged();
            RefreshSdMonthStrip();
            RefreshSdEmpStatus();
            LoadSchedules();
            _sdAnnual = null;
            _ = SdCompute();
            if (_slipMonth == _sdMonth) LoadSavedRuns();
            Snackbar.Add($"Saved {new DateTime(1, _sdMonth, 1):MMMM} salary for {entry.EmployeeName}.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Save error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
    }

    async Task SdCopyToAll()
    {
        if (_sdEmpId == 0) { Snackbar.Add("Select an employee first.", Severity.Warning); return; }
        if (_sdMonth == 0) { Snackbar.Add("Select a month first.", Severity.Warning); return; }
        // Forward-only copy: current month → end of FY (March)
        int idx = Array.IndexOf(_fyMonths, _sdMonth);
        if (idx < 0) { Snackbar.Add("Invalid month.", Severity.Warning); return; }
        var forwardMonths = _fyMonths.Skip(idx).ToArray();
        var lastMonthName = new DateTime(1, forwardMonths.Last(), 1).ToString("MMMM");
        var confirmed = await DialogSvc.ShowMessageBox(
            "Copy Forward & Save?",
            $"Copy {new DateTime(1, _sdMonth, 1):MMMM} salary to {lastMonthName} ({forwardMonths.Length} months), compute TDS, and save each month automatically. Existing entries will be overwritten.",
            yesText: "Yes, Copy & Save All", cancelText: "Cancel");
        if (confirmed != true) return;

        _sdComputing = true;
        try
        {
            var base_ = BuildSdEntry();
            var emp   = _employees.FirstOrDefault(e => e.Id == _sdEmpId) ?? new Employee();
            var decl  = PayrollSvc.GetDeclaration(_sdEmpId, AppState.CurrentFY)
                        ?? new TaxDeclaration { EmployeeId = _sdEmpId, FinancialYear = AppState.CurrentFY };
            int fyStart = TaxRules.FyStartYear(AppState.CurrentFY);
            int saved = 0;

            await Task.Run(() =>
            {
                foreach (int m in forwardMonths)
                {
                    int yr = m >= 4 ? fyStart : fyStart + 1;
                    var copy = new MonthlySalaryEntry
                    {
                        Id = 0, EmployeeId = base_.EmployeeId, EmployeeName = base_.EmployeeName,
                        Pan = base_.Pan, Month = m, Year = yr, FinancialYear = base_.FinancialYear,
                        Basic = base_.Basic, GradePay = base_.GradePay, HRA = base_.HRA, DaAmount = base_.DaAmount,
                        SpecialAllowance = base_.SpecialAllowance, MedicalAllowance = base_.MedicalAllowance, Lta = base_.Lta,
                        Bonus = base_.Bonus, Commission = base_.Commission, AdvanceSalary = base_.AdvanceSalary,
                        Arrears = base_.Arrears, OtherAllowances = base_.OtherAllowances, NpsEmployer = base_.NpsEmployer,
                        PerqTotal = base_.PerqTotal, PerqExempted = base_.PerqExempted,
                        LeaveEncTotal = base_.LeaveEncTotal, LeaveEncExempted = base_.LeaveEncExempted,
                        PfEmployee = base_.PfEmployee, VPF = base_.VPF, ProfessionalTax = base_.ProfessionalTax,
                        EsiEmployee = base_.EsiEmployee, TdsDeducted = 0, TaxComputed = 0,
                        LineItems = base_.LineItems.Select(li => new CDeTDS.DAL.Models.SalaryLineItem
                        {
                            Category = li.Category, Name = li.Name,
                            Taxable = li.Taxable, Exempt = li.Exempt, RuleRef = li.RuleRef,
                        }).ToList(),
                    };
                    try
                    {
                        var annual = SalarySvc.ComputeMonth(copy, emp, AppState.CurrentFY, decl);
                        copy.TaxComputed  = annual.ThisMonthTds;
                        copy.TdsDeducted  = annual.ThisMonthTds;
                    }
                    catch { }
                    copy.RecalcGross();
                    SalarySvc.Save(copy);
                    saved++;
                }
            });

            AppState.NotifyStateChanged();
            RefreshSdMonthStrip();
            RefreshSdEmpStatus();
            SelectSdMonth(_sdMonth);
            Snackbar.Add($"Copied & saved {saved} month(s) from {new DateTime(1, _sdMonth, 1):MMMM}.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
        _sdComputing = false;
    }

    async Task SdDownloadSlip(bool html)
    {
        if (_sdEmpId == 0) { Snackbar.Add("Select an employee first.", Severity.Warning); return; }
        if (_sdMonth == 0) { Snackbar.Add("Select a month first.", Severity.Warning); return; }
        if (_sdAnnual == null) await SdCompute();
        if (_sdAnnual == null) return;
        try
        {
            var entry = BuildSdEntry();
            entry.RecalcGross();
            var emp = _employees.FirstOrDefault(e => e.Id == _sdEmpId) ?? new Employee();
            var deds = DeductorSvc.GetAll();
            var ded  = deds.FirstOrDefault(d => d.Id == AppState.CurrentDeductorId) ?? new Deductor();
            var folder = FolderManager.SalarySlipsForFyFolder(AppState.CurrentFY);
            Directory.CreateDirectory(folder);
            var path = html
                ? SalarySlipExport.GenerateHtml(entry, _sdAnnual, emp, ded, folder)
                : SalarySlipExport.GenerateExcel(entry, _sdAnnual, emp, ded, folder);
            FolderManager.OpenFolder(Path.GetDirectoryName(path)!);
            Snackbar.Add($"Saved: {Path.GetFileName(path)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
    }

