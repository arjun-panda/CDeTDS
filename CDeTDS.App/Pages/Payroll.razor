    // Normalize any date string to dd-MM-yyyy. Accepts dd-MM-yyyy, dd/MM/yyyy, dd-MMM-yyyy, yyyyMMdd, or empty.
    static string NormDate(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return "";
        s = s.Trim();
        // Already dd-MM-yyyy
        if (System.Text.RegularExpressions.Regex.IsMatch(s, @"^\d{2}-\d{2}-\d{4}$")) return s;
        var formats = new[] { "dd-MMM-yyyy", "dd/MM/yyyy", "dd-MMM-yyyy", "d/M/yyyy", "yyyy-MM-dd", "yyyyMMdd", "ddMMyyyy" };
        if (DateTime.TryParseExact(s, formats, System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out var dt))
            return dt.ToString("dd-MMM-yyyy");
        if (DateTime.TryParse(s, out var dt2))
            return dt2.ToString("dd-MMM-yyyy");
        return s; // return as-is if not parseable
    }
