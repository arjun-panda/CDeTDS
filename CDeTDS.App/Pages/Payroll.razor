    void DownloadSlipPdf(MonthlySalaryEntry entry)
    {
        try
        {
            var emp = _employees.FirstOrDefault(x => x.Id == entry.EmployeeId)
                      ?? new Employee { Id = entry.EmployeeId, Name = entry.EmployeeName, Pan = entry.Pan };
            var ded = DeductorSvc.GetAll().FirstOrDefault(d => d.Id == AppState.CurrentDeductorId) ?? new Deductor();
            AnnualComputation annual;
            try
            {
                var decl = PayrollSvc.GetDeclaration(emp.Id, entry.FinancialYear)
                           ?? new TaxDeclaration { EmployeeId = emp.Id, FinancialYear = entry.FinancialYear };
                annual = SalarySvc.ComputeMonth(entry, emp, entry.FinancialYear, decl);
            }
            catch { annual = new AnnualComputation(); }
            var folder = FolderManager.SalarySlipsForFyFolder(AppState.CurrentFY);
            var path = SalarySlipExport.GeneratePdf(entry, annual, emp, ded, folder);
            FolderManager.OpenFolder(Path.GetDirectoryName(path)!);
            Snackbar.Add($"📄 PDF saved: {Path.GetFileName(path)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("PDF generation failed: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
    }

