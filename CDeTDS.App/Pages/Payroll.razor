        var _pct = _editingEmployee.HraCityType == "Metro" ? 0.50 : 0.40;
        var _autoHra = Math.Round(_editingEmployee.Salary?.Basic * _pct ?? 0);
        _empHraAuto = _editingEmployee.Salary != null && Math.Abs(_editingEmployee.Salary.Hra - _autoHra) <= 1;
