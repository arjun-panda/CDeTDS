    async Task DownloadFullYearZip()
    {
        _zipping = true;
        try
        {
            var ded  = DeductorSvc.GetAll().FirstOrDefault(d => d.Id == AppState.CurrentDeductorId) ?? new Deductor();
            var emps = _employees.Where(e => e.IsActive).ToList();
            var folder = Path.Combine(FolderManager.SalarySlipsForFyFolder(AppState.CurrentFY), "AllSlips");
            Directory.CreateDirectory(folder);

            int generated = 0;
            await Task.Run(() =>
            {
                foreach (var emp in emps)
                {
                    var entries = SalarySvc.GetAllForFY(emp.Id, AppState.CurrentFY);
                    foreach (var entry in entries)
                    {
                        try
                        {
                            entry.EmployeeName = emp.Name; entry.Pan = emp.Pan;
                            AnnualComputation annual;
                            try
                            {
                                var decl = PayrollSvc.GetDeclaration(emp.Id, entry.FinancialYear)
                                           ?? new TaxDeclaration { EmployeeId = emp.Id, FinancialYear = entry.FinancialYear };
                                annual = SalarySvc.ComputeMonth(entry, emp, entry.FinancialYear, decl);
                            }
                            catch { annual = new AnnualComputation(); }
                            SalarySlipExport.GenerateHtml(entry, annual, emp, ded, folder);
                            generated++;
                        }
                        catch { }
                    }
                }
            });

            if (generated == 0) { Snackbar.Add("No salary entries found for this FY.", Severity.Warning); _zipping = false; return; }

            var zipPath = Path.Combine(FolderManager.SalarySlipsFolder,
                $"AllSlips_{AppState.CurrentFY.Replace("/","-")}.zip");
            if (File.Exists(zipPath)) File.Delete(zipPath);
            ZipFile.CreateFromDirectory(folder, zipPath);
            FolderManager.OpenFolder(Path.GetDirectoryName(zipPath)!);
            Snackbar.Add($"ZIP created with {generated} slips: {Path.GetFileName(zipPath)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
        _zipping = false;
    }

    void Load24QEntries()
