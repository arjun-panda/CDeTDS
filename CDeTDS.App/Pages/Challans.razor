@page "/challans"
@inject AppStateService AppState
@inject ChallanService Svc
@inject TdsEntryService EntrySvc
@inject DeductorService DeductorSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc
@inject NavigationManager Nav
@implements IDisposable

@* ── Sticky header ── *@
<div style="position:sticky;top:0;z-index:50;background:#f5f7fa;margin:-16px -24px 12px -24px;padding:10px 24px;border-bottom:1px solid #e0e0e0;box-shadow:0 2px 6px rgba(0,0,0,.06);flex-shrink:0">
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
        <span style="font-size:15px;font-weight:700;color:#1e293b;white-space:nowrap">Challans — @TaxRules.YearLabel(AppState.CurrentFY)</span>
        @if (_items.Count > 0)
        {
            <div style="display:flex;align-items:stretch;gap:0;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;margin-left:4px">
                <div class="ch-kpi"><span class="ch-kpi-lbl">Challans</span><span class="ch-kpi-val" style="color:#1565C0">@_items.Count</span></div>
                <div class="ch-kpi-sep"></div>
                <div class="ch-kpi"><span class="ch-kpi-lbl">TDS</span><span class="ch-kpi-val" style="color:#2e7d32">₹@_items.Sum(x=>x.TdsAmount).ToString("N0")</span></div>
                <div class="ch-kpi-sep"></div>
                <div class="ch-kpi"><span class="ch-kpi-lbl">Surcharge</span><span class="ch-kpi-val">₹@_items.Sum(x=>x.Surcharge).ToString("N0")</span></div>
                <div class="ch-kpi-sep"></div>
                <div class="ch-kpi"><span class="ch-kpi-lbl">Total Paid</span><span class="ch-kpi-val" style="color:#6a1b9a">₹@_items.Sum(x=>x.TotalAmount).ToString("N0")</span></div>
                @if (_totalUnlinked > 0)
                {
                    <div class="ch-kpi-sep"></div>
                    <div class="ch-kpi"><span class="ch-kpi-lbl">Unlinked</span><span class="ch-kpi-val" style="color:#b45309">@_totalUnlinked</span></div>
                }
            </div>
        }
        <div style="flex:1"></div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   Disabled="@AppState.IsReadOnlyFY" Size="Size.Small"
                   OnClick="OpenAdd">Add Challan</MudButton>
    </div>
    @if (_items.Count > 0)
    {
        <div style="display:flex;align-items:center;gap:10px;margin-top:8px">
            <MudTextField @bind-Value="_search" Placeholder="Search challan no, BSR, bank, section..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                          Style="max-width:300px" Class="mt-0"
                          @bind-Value:after="RebuildView" />
            <span style="font-size:11px;color:#94a3b8">@_filteredItems.Count challan(s) · @_groups.Count section(s)</span>
        </div>
    }
</div>

@* ── Unlinked entries warning ── *@
@if (_totalUnlinked > 0)
{
    <div style="display:flex;flex-direction:column;gap:4px;background:#fffbeb;border:1px solid #f59e0b;border-radius:8px;padding:8px 14px;margin-bottom:10px;flex-shrink:0">
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            <span style="font-size:13px;font-weight:700;color:#92400e">⚠ @_totalUnlinked unlinked TDS entr@(_totalUnlinked == 1 ? "y" : "ies") — link to a challan before generating the return</span>
            <div style="flex:1"></div>
            @foreach (var (q, n) in _unlinkedByQuarter.OrderBy(x => x.Key))
            {
                <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small"
                           Style="font-size:11px;padding:2px 10px;min-width:0"
                           OnClick="() => LinkNow(q)">Link @n in @q</MudButton>
            }
        </div>
        <span style="font-size:11px;color:#78350f">Open the challan edit dialog → check entries → Save. Or click "Link" to open the first challan for that quarter with unlinked entries shown.</span>
    </div>
}

@if (_items.Count == 0)
{
    <EmptyState Icon="@Icons.Material.Filled.AccountBalance"
                Title="No challans yet"
                Subtitle="Challan 281 records TDS deposited to the bank. Add a challan after you pay TDS, then link your TDS entries to it."
                HelpText="Tip: Pay TDS at the bank → enter challan number/BSR/date here → link entries → file 24Q/26Q." />
}
else
{
    @* ── Grouped table ── *@
    <div style="flex:1;min-height:0;overflow-y:auto;overflow-x:hidden">
        <table class="ch-tbl">
            <colgroup>
                <col style="width:28px"/>   @* expand toggle *@
                <col style="width:110px"/>  @* challan no *@
                <col style="width:100px"/>  @* date *@
                <col style="width:100px"/>  @* BSR *@
                <col style="width:80px"/>   @* quarter *@
                <col/>                       @* bank *@
                <col style="width:100px"/>  @* TDS deposited *@
                <col style="width:110px"/>  @* linked / balance *@
                <col style="width:100px"/>  @* total *@
                <col style="width:96px"/>   @* actions *@
            </colgroup>
            <thead>
                <tr class="ch-thead-row">
                    <th class="ch-th"></th>
                    <th class="ch-th">Challan No</th>
                    <th class="ch-th">Date</th>
                    <th class="ch-th">BSR Code</th>
                    <th class="ch-th">Quarter</th>
                    <th class="ch-th">Bank</th>
                    <th class="ch-th" style="text-align:right">TDS Dep (₹)</th>
                    <th class="ch-th" style="text-align:right">Linked / Balance</th>
                    <th class="ch-th" style="text-align:right">Total (₹)</th>
                    <th class="ch-th"></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var grp in _groups)
            {
                var sec      = grp.Key;
                var rows     = grp.Value;
                var expanded = _expandedSections.Contains(sec);
                var grpTds   = rows.Sum(x => x.TdsAmount);
                var grpTotal = rows.Sum(x => x.TotalAmount);

                @* ── Section header row ── *@
                <tr class="ch-sec-row" @onclick="() => ToggleSection(sec)">
                    <td class="ch-sec-td" colspan="10">
                        <div style="display:flex;align-items:center;gap:8px">
                            <span style="font-size:13px;color:#94a3b8;transition:transform .15s;display:inline-block;transform:rotate(@(expanded?"90deg":"0deg"))">▶</span>
                            <span class="ch-sec-badge">@(string.IsNullOrEmpty(sec) ? "No Section" : sec)</span>
                            <span style="font-size:11px;color:#64748b">@rows.Count challan@(rows.Count==1?"":"s")</span>
                            <div style="flex:1"></div>
                            <span style="font-size:12px;color:#374151;font-weight:600">TDS ₹@grpTds.ToString("N0")</span>
                            <span style="color:#cbd5e1;font-size:11px">|</span>
                            <span style="font-size:12px;color:#1e40af;font-weight:700">Total ₹@grpTotal.ToString("N0")</span>
                        </div>
                    </td>
                </tr>

                @* ── Challan rows (visible only when expanded) ── *@
                @if (expanded)
                {
                    @foreach (var c in rows)
                    {
                        <tr class="ch-row" @key="c.Id">
                            <td class="ch-td"></td>
                            <td class="ch-td" style="font-family:monospace;font-weight:600;color:#1e40af">@c.ChallanNo</td>
                            <td class="ch-td" style="color:#475569">@c.ChallanDate.ToString("dd-MMM-yyyy")</td>
                            <td class="ch-td" style="font-family:monospace;font-size:11px;color:#64748b">@c.BsrCode</td>
                            <td class="ch-td"><span class="ch-qtr-badge">@c.Quarter</span></td>
                            <td class="ch-td" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#374151">@c.BankName</td>
                            <td class="ch-td" style="text-align:right;font-weight:600;color:#1e293b">₹@c.TdsAmount.ToString("N0")</td>
                            @{
                                var linked  = _challanLinked.TryGetValue(c.ChallanNo ?? "", out var lv) ? lv : 0;
                                var balance = c.TdsAmount - linked;
                                var balColor = balance < -1 ? "#dc2626" : balance > 1 ? "#92400e" : "#15803d";
                                var balLabel = balance < -1 ? $"⚠ over ₹{Math.Abs(balance):N0}" : balance > 1 ? $"₹{balance:N0} free" : "✓ balanced";
                            }
                            <td class="ch-td" style="text-align:right;font-size:11px">
                                <div style="color:#475569">₹@linked.ToString("N0") linked</div>
                                <div style="font-weight:700;color:@balColor">@balLabel</div>
                            </td>
                            <td class="ch-td" style="text-align:right;font-weight:700;color:#1e293b">₹@c.TotalAmount.ToString("N0")</td>
                            <td class="ch-td" style="white-space:nowrap">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"   Size="Size.Small"
                                               Disabled="@AppState.IsReadOnlyFY" OnClick="() => OpenEdit(c)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Print"  Size="Size.Small" Color="Color.Primary"
                                               OnClick="() => NavigateToPrint(c.Id)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                               Disabled="@AppState.IsReadOnlyFY" OnClick="() => DeleteItem(c)" />
                            </td>
                        </tr>
                    }
                    @* ── Section subtotal row ── *@
                    <tr class="ch-subtotal-row">
                        <td class="ch-subtotal-td" colspan="6" style="text-align:right;font-size:11px;color:#64748b;font-style:italic">
                            Subtotal — @rows.Count challan@(rows.Count==1?"":"s")
                        </td>
                        <td class="ch-subtotal-td" style="text-align:right;font-weight:700;color:#1e293b">₹@grpTds.ToString("N0")</td>
                        <td class="ch-subtotal-td"></td>
                        <td class="ch-subtotal-td" style="text-align:right;font-weight:700;color:#1e40af">₹@grpTotal.ToString("N0")</td>
                        <td class="ch-subtotal-td"></td>
                    </tr>
                }
            }
            @* ── Grand total ── *@
            <tr class="ch-grand-row">
                <td class="ch-grand-td" colspan="6" style="text-align:right;font-size:12px;font-weight:700;color:#1e293b">Grand Total</td>
                <td class="ch-grand-td" style="text-align:right;font-weight:700;color:#1e293b">₹@_filteredItems.Sum(x=>x.TdsAmount).ToString("N0")</td>
                <td class="ch-grand-td"></td>
                <td class="ch-grand-td" style="text-align:right;font-weight:800;color:#1e40af">₹@_filteredItems.Sum(x=>x.TotalAmount).ToString("N0")</td>
                <td class="ch-grand-td"></td>
            </tr>
            </tbody>
        </table>
    </div>
}

<MudDialog @bind-Visible="_dialogOpen" Options="_dialogOptions">
    <TitleContent>@(_editing?.Id == 0 ? "Add" : "Edit") Challan</TitleContent>
    <DialogContent>
        @if (_editing != null)
        {
            @* ── Row 1: 4 fields ── *@
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:8px;margin-bottom:6px">
                <MudTextField @bind-Value="_editing.ChallanNo" Label="Challan No*" Variant="Variant.Outlined" Margin="Margin.Dense" />
                <MudTextField @bind-Value="_editing.BsrCode"   Label="BSR Code*"   Variant="Variant.Outlined" Margin="Margin.Dense" />
                <DateField Value="_challanDate" ValueChanged="d => _challanDate = d" Label="Date*" Variant="Variant.Outlined" Margin="Margin.Dense" Class="date-field" />
                <div>
                    <MudSelect Value="_editing.Section" Label="Section" Variant="Variant.Outlined" Margin="Margin.Dense"
                               ValueChanged="@((string s) => { _editing.Section = s; LoadLinkableEntries(_editing.Quarter, _editing.ChallanNo); })">
                        @foreach (var s in AppConstants.KnownSections)
                        { <MudSelectItem Value="@s">@s</MudSelectItem> }
                    </MudSelect>
                    @* Income-tax Act 2025: legacy 194-series codes are renumbered into the
                       Section 393(1) table — show what this challan actually files under. *@
                    @if (TaxRules.IsNewAct(_editing.FinancialYear) && !string.IsNullOrEmpty(_editing.Section))
                    {
                        var nref = TaxRules.NewActSectionRef(_editing.Section);
                        <MudText Typo="Typo.caption" Style="color:#065f46;line-height:1.2;display:block;margin-top:2px">
                            Files as @(string.IsNullOrEmpty(nref) ? $"IT Act 2025 (legacy s.{_editing.Section})" : nref) — IT Act 2025
                        </MudText>
                    }
                </div>
            </div>

            @* ── Row 2: Minor Head + radio inline ── *@
            <div style="display:flex;align-items:center;gap:12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;padding:5px 12px;margin-bottom:6px">
                <span style="font-size:11px;font-weight:600;color:#64748b;white-space:nowrap">Minor Head (OLTAS)</span>
                <MudRadioGroup @bind-Value="_editing.MinorHeadCode" Style="display:flex;gap:16px">
                    <MudRadio Value="@("200")" Color="Color.Primary" Size="Size.Small"><span style="font-size:12px">200 — Regular Payment</span></MudRadio>
                    <MudRadio Value="@("400")" Color="Color.Warning" Size="Size.Small"><span style="font-size:12px">400 — AO Demand</span></MudRadio>
                </MudRadioGroup>
            </div>

            @* ── Row 3: 6 amount fields ── *@
            <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin-bottom:6px">
                <MudNumericField @bind-Value="_editing.TdsAmount" Label="TDS (₹)"       Variant="Variant.Outlined" Margin="Margin.Dense" Format="N0" HideSpinButtons="true" Class="amount-field" />
                <MudNumericField @bind-Value="_editing.Surcharge" Label="Surcharge"     Variant="Variant.Outlined" Margin="Margin.Dense" Format="N0" HideSpinButtons="true" Class="amount-field" />
                <MudNumericField @bind-Value="_editing.Cess"      Label="Cess"          Variant="Variant.Outlined" Margin="Margin.Dense" Format="N0" HideSpinButtons="true" Class="amount-field" />
                <MudNumericField @bind-Value="_editing.Interest"  Label="Interest"      Variant="Variant.Outlined" Margin="Margin.Dense" Format="N0" HideSpinButtons="true" Class="amount-field" />
                <MudNumericField @bind-Value="_editing.LateFee"   Label="Late Fee"      Variant="Variant.Outlined" Margin="Margin.Dense" Format="N0" HideSpinButtons="true" Class="amount-field" />
                <MudNumericField @bind-Value="_editing.Amount"    Label="Other Charges" Variant="Variant.Outlined" Margin="Margin.Dense" Format="N0" HideSpinButtons="true" Class="amount-field" />
            </div>

            @* ── Row 4: Quarter + Bank + Remarks inline ── *@
            <div style="display:grid;grid-template-columns:100px 1fr 1fr;gap:8px;margin-bottom:6px">
                <MudSelect Value="_editing.Quarter" Label="Quarter" Variant="Variant.Outlined" Margin="Margin.Dense" ShrinkLabel="true"
                           ValueChanged="@((string q) => OnQuarterChanged(q))">
                    @foreach (var q in AppConstants.QuarterCodes)
                    { <MudSelectItem Value="@q">@q</MudSelectItem> }
                </MudSelect>
                <MudTextField @bind-Value="_editing.BankName" Label="Bank"    Variant="Variant.Outlined" Margin="Margin.Dense" />
                <MudTextField @bind-Value="_editing.Remarks"  Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </div>

            @* ── Link TDS Entries ── *@
            @if (!string.IsNullOrEmpty(_editing.Quarter))
            {
                @* ── section header + balance bar on one line ── *@
                <div style="display:flex;align-items:center;gap:10px;background:#eff6ff;border:1px solid #bfdbfe;border-radius:6px;padding:6px 12px;margin-bottom:6px">
                    <span style="font-weight:700;font-size:12px;color:#1d4ed8;white-space:nowrap">Link TDS Entries — @_editing.Quarter</span>
                    <label style="display:flex;align-items:center;gap:4px;font-size:11px;color:#475569;cursor:pointer;white-space:nowrap">
                        <input type="checkbox" checked="@_showAllSections"
                               @onchange="@(e => { _showAllSections = (bool)(e.Value ?? false); LoadLinkableEntries(_editing.Quarter, _editing.ChallanNo); })" />
                        All sections
                    </label>
                    <div style="flex:1"></div>
                    @if (_linkableEntries.Count > 0)
                    {
                        <span style="font-size:11px;color:#1565C0;font-weight:600;white-space:nowrap">Challan ₹@ChallanAmt.ToString("N0")</span>
                        <span style="color:#cbd5e1">|</span>
                        <span style="font-size:11px;color:#2e7d32;font-weight:600;white-space:nowrap">Selected ₹@SelectedTds.ToString("N0")</span>
                        <span style="color:#cbd5e1">|</span>
                        <span style="font-size:11px;font-weight:700;color:@(IsBalanced?"#16a34a":"#dc2626");white-space:nowrap">
                            @(IsBalanced ? "✅ Balanced" : $"⚠ ₹{Math.Abs(ChallanAmt-SelectedTds):N0} {(ChallanAmt>SelectedTds?"under":"over")}")
                        </span>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.AutoFixHigh" OnClick="AutoMatch"
                                   Style="font-size:11px;padding:2px 10px;min-width:0;white-space:nowrap">Auto-Match</MudButton>
                        @if (!string.IsNullOrEmpty(_autoMatchMsg))
                        {
                            <span style="font-size:10px;color:@(_autoMatchOk?"#16a34a":"#e65100");font-weight:600">@_autoMatchMsg</span>
                        }
                    }
                    <span style="font-size:10px;color:#94a3b8;white-space:nowrap">✓ = linked · uncheck to unlink</span>
                </div>

                @if (_linkableEntries.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">No TDS entries found for @_editing.Quarter.</MudAlert>
                }
                else
                {
                    @* ── Entries Table ── *@
                    <div style="overflow-y:auto;border:1px solid #e2e8f0;border-radius:6px;max-height:340px">
                        <table style="width:100%;border-collapse:collapse;font-size:12px;table-layout:fixed">
                            <colgroup>
                                <col style="width:36px"/>
                                <col style="width:100px"/>
                                <col style="width:90px"/>
                                <col/>
                                <col style="width:62px"/>
                                <col style="width:100px"/>
                                <col style="width:56px"/>
                            </colgroup>
                            <thead>
                                <tr style="background:#1e40af;color:#fff;position:sticky;top:0;z-index:1">
                                    <th style="padding:6px 8px;width:36px">
                                        <MudCheckBox T="bool" Value="@(_selectedEntryIds.Count == _linkableEntries.Count)"
                                                     ValueChanged="ToggleAll" Color="Color.Default" Size="Size.Small" />
                                    </th>
                                    <th style="padding:6px 8px;text-align:left;font-size:11px;font-weight:600;letter-spacing:.3px">Entry No</th>
                                    <th style="padding:6px 8px;text-align:left;font-size:11px;font-weight:600;letter-spacing:.3px">Date</th>
                                    <th style="padding:6px 8px;text-align:left;font-size:11px;font-weight:600;letter-spacing:.3px">Deductee</th>
                                    <th style="padding:6px 8px;text-align:center;font-size:11px;font-weight:600;letter-spacing:.3px">Sec</th>
                                    <th style="padding:6px 8px;text-align:right;font-size:11px;font-weight:600;letter-spacing:.3px">Total TDS (₹)</th>
                                    <th style="padding:6px 8px;text-align:center;font-size:11px;font-weight:600;letter-spacing:.3px">Linked</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var e in _linkableEntries)
                                {
                                    var isAutoMatched = _autoMatchedIds.Contains(e.Id);
                                    var isSelected    = _selectedEntryIds.Contains(e.Id);
                                    <tr @key="@($"{e.Id}_{isSelected}")"
                                        style="border-bottom:1px solid #f1f5f9;background:@(isSelected ? (isAutoMatched ? "#f0fdf4" : "#eff6ff") : "#fff")">
                                        <td style="padding:3px 8px">
                                            <MudCheckBox T="bool" Value="@isSelected" Size="Size.Small"
                                                         ValueChanged="@((bool v) => ToggleEntry(e.Id, v))" />
                                        </td>
                                        <td style="padding:3px 8px;font-family:monospace;font-size:11px;color:#64748b">
                                            @e.EntryNo
                                            @if (isAutoMatched) { <span style="font-size:9px;background:#dcfce7;color:#15803d;border-radius:3px;padding:1px 4px;margin-left:3px;font-weight:700">AUTO</span> }
                                        </td>
                                        <td style="padding:3px 8px;white-space:nowrap;color:#475569">@e.EntryDate.ToString("dd-MMM-yy")</td>
                                        <td style="padding:3px 8px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:500">@e.DeducteeName</td>
                                        <td style="padding:3px 8px;text-align:center">
                                            <span style="background:#dbeafe;color:#1e40af;border-radius:3px;padding:1px 5px;font-size:10px;font-weight:700">@(string.IsNullOrEmpty(e.Section) ? "—" : e.Section)</span>
                                        </td>
                                        <td style="padding:3px 8px;text-align:right;font-weight:700;color:#1e293b">₹@e.TotalTds.ToString("N0")</td>
                                        <td style="padding:3px 8px;text-align:center">
                                            @if (isSelected) { <span style="color:#16a34a;font-weight:700">✓</span> }
                                            else { <span style="color:#cbd5e1">—</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        }
        @if (!string.IsNullOrEmpty(_saveError))
        { <MudAlert Severity="Severity.Error" Class="mt-2">@_saveError</MudAlert> }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogOpen = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save"
                   Disabled="@AppState.IsReadOnlyFY">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Challan> _items = new();
    private string _search = "";
    private HashSet<string> _expandedSections = new();

    private List<Challan> _filteredItems = new();
    private Dictionary<string, List<Challan>> _groups = new();

    void RebuildView()
    {
        _filteredItems = string.IsNullOrWhiteSpace(_search)
            ? _items
            : _items.Where(c =>
                c.ChallanNo.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                c.BsrCode.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                c.BankName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                c.Section.Contains(_search, StringComparison.OrdinalIgnoreCase)).ToList();
        _groups = _filteredItems
            .GroupBy(c => string.IsNullOrEmpty(c.Section) ? "" : c.Section)
            .OrderBy(g => string.IsNullOrEmpty(g.Key) ? "ZZZ" : g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    void ToggleSection(string sec)
    {
        if (_expandedSections.Contains(sec)) _expandedSections.Remove(sec);
        else _expandedSections.Add(sec);
    }

    // Unlinked entry counts per quarter
    private Dictionary<string, int> _unlinkedByQuarter = new();
    private int _totalUnlinked => _unlinkedByQuarter.Values.Sum();

    // Linked TDS amount per challan_no — for balance display in table
    private Dictionary<string, double> _challanLinked = new();
    private bool _showAllSections = false; // entry link dialog: show entries from all sections

    private bool _dialogOpen;
    private Challan? _editing;
    private DateTime? _challanDate;
    private string _saveError = "";
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };

    // Entry linking
    private List<TdsEntry> _linkableEntries = new();
    private HashSet<int> _selectedEntryIds = new();
    private HashSet<int> _previouslyLinkedIds = new();
    private HashSet<int> _autoMatchedIds = new();
    private string _autoMatchMsg = "";
    private bool _autoMatchOk = false;

    private double SelectedTds => _linkableEntries.Where(e => _selectedEntryIds.Contains(e.Id)).Sum(e => e.TotalTds);
    private double ChallanAmt  => _editing == null ? 0 : _editing.TdsAmount + _editing.Surcharge + _editing.Cess + _editing.Interest + _editing.LateFee + _editing.Amount;
    private bool   IsBalanced  => Math.Abs(ChallanAmt - SelectedTds) < 1;

    protected override void OnInitialized() { AppState.OnChange += Reload; Load(); }

    void Load()
    {
        _items = Svc.GetAll(AppState.CurrentDeductorId > 0 ? AppState.CurrentDeductorId : null, AppState.CurrentFY);
        foreach (var sec in _items.Select(c => string.IsNullOrEmpty(c.Section) ? "" : c.Section).Distinct())
            _expandedSections.Add(sec);
        RebuildView();
        RefreshUnlinked();
        RefreshChallanLinked();
    }

    void RefreshChallanLinked()
    {
        _challanLinked = new();
        if (AppState.CurrentDeductorId == 0) return;
        try
        {
            using var conn = CDeTDS.DAL.Database.GetConnection();
            using var cmd  = conn.CreateCommand();
            cmd.CommandText = @"SELECT challan_no, SUM(tds_amount) FROM tds_entries
                WHERE deductor_id=@d AND financial_year=@fy
                  AND (challan_no IS NOT NULL AND challan_no != '')
                GROUP BY challan_no";
            cmd.Parameters.AddWithValue("@d",  AppState.CurrentDeductorId);
            cmd.Parameters.AddWithValue("@fy", AppState.CurrentFY);
            using var rdr = cmd.ExecuteReader();
            while (rdr.Read())
                _challanLinked[rdr.GetString(0)] = rdr.IsDBNull(1) ? 0 : rdr.GetDouble(1);
        }
        catch { }
    }

    void RefreshUnlinked()
    {
        _unlinkedByQuarter = new();
        if (AppState.CurrentDeductorId == 0) return;
        try
        {
            using var conn = CDeTDS.DAL.Database.GetConnection();
            using var cmd  = conn.CreateCommand();
            cmd.CommandText = @"SELECT quarter, COUNT(1) FROM tds_entries
                WHERE deductor_id=@d AND financial_year=@fy
                  AND (challan_no IS NULL OR challan_no='')
                  AND status NOT IN ('Adjusted')
                GROUP BY quarter";
            cmd.Parameters.AddWithValue("@d",  AppState.CurrentDeductorId);
            cmd.Parameters.AddWithValue("@fy", AppState.CurrentFY);
            using var rdr = cmd.ExecuteReader();
            while (rdr.Read())
            {
                var q = rdr.GetString(0);
                var n = rdr.GetInt32(1);
                if (n > 0) _unlinkedByQuarter[q] = n;
            }
        }
        catch { }
    }

    void LinkNow(string quarter)
    {
        // Open the first challan for this quarter so the user can link entries
        var challan = _items.FirstOrDefault(c => c.Quarter == quarter);
        if (challan == null) { Snackbar.Add($"No challan found for {quarter} — add one first, then link entries.", Severity.Warning); return; }
        OpenEdit(challan);
        // Override the entry list to show unlinked entries for this quarter (ignoring section filter)
        _linkableEntries = EntrySvc.GetAll(AppState.CurrentDeductorId, AppState.CurrentFY)
            .Where(e => e.Quarter == quarter && e.Status != "Adjusted"
                     && (string.IsNullOrEmpty(e.ChallanNo) || e.ChallanNo == challan.ChallanNo))
            .OrderBy(e => e.EntryNo).ToList();
        _previouslyLinkedIds = _linkableEntries.Where(e => e.ChallanNo == challan.ChallanNo && !string.IsNullOrEmpty(challan.ChallanNo))
                                               .Select(e => e.Id).ToHashSet();
        _selectedEntryIds = new HashSet<int>(_previouslyLinkedIds);
    }

    void Reload() { Load(); StateHasChanged(); }

    void OpenAdd()
    {
        var deductor = AppState.CurrentDeductorId > 0 ? DeductorSvc.GetById(AppState.CurrentDeductorId) : null;
        _editing = new Challan
        {
            DeductorId    = AppState.CurrentDeductorId,
            ChallanDate   = DateTime.Today,
            FinancialYear = AppState.CurrentFY,
            BsrCode       = deductor?.DefaultBsrCode  ?? "",
            BankName      = deductor?.DefaultBankName ?? "",
        };
        _challanDate = DateTime.Today; _saveError = "";
        _linkableEntries = new(); _selectedEntryIds = new(); _previouslyLinkedIds = new();
        _autoMatchedIds = new(); _autoMatchMsg = ""; _autoMatchOk = false;
        _dialogOpen = true;
    }

    void OpenEdit(Challan c)
    {
        _editing = new Challan
        {
            Id = c.Id, ChallanNo = c.ChallanNo, BsrCode = c.BsrCode, ChallanDate = c.ChallanDate,
            DeductorId = c.DeductorId, Section = c.Section, TdsAmount = c.TdsAmount,
            Surcharge = c.Surcharge, Cess = c.Cess, Interest = c.Interest, LateFee = c.LateFee,
            Amount = c.Amount, Quarter = c.Quarter, BankName = c.BankName, AckNo = c.AckNo,
            FinancialYear = c.FinancialYear, Status = c.Status, Remarks = c.Remarks,
            MinorHeadCode = c.MinorHeadCode
        };
        _challanDate = c.ChallanDate; _saveError = "";
        _autoMatchedIds = new(); _autoMatchMsg = ""; _autoMatchOk = false;
        _showAllSections = false;
        LoadLinkableEntries(c.Quarter, c.ChallanNo);
        _dialogOpen = true;
    }

    void LoadLinkableEntries(string quarter, string existingChallanNo = "")
    {
        if (string.IsNullOrEmpty(quarter)) { _linkableEntries = new(); return; }
        var challanSection = _editing?.Section ?? "";
        _linkableEntries = EntrySvc.GetAll(AppState.CurrentDeductorId, AppState.CurrentFY)
            .Where(e => e.Quarter == quarter &&
                        e.Status != "Adjusted" &&
                        (string.IsNullOrEmpty(e.ChallanNo) || e.ChallanNo == existingChallanNo) &&
                        (_showAllSections || string.IsNullOrEmpty(challanSection) || e.Section == challanSection))
            .OrderBy(e => e.EntryNo)
            .ToList();
        _previouslyLinkedIds = _linkableEntries.Where(e => e.ChallanNo == existingChallanNo && !string.IsNullOrEmpty(existingChallanNo))
                                               .Select(e => e.Id).ToHashSet();
        _selectedEntryIds = new HashSet<int>(_previouslyLinkedIds);
        _autoMatchedIds = new();
        _autoMatchMsg = "";
    }

    async void AutoMatch()
    {
        if (_editing == null || ChallanAmt <= 0) return;

        double target = ChallanAmt;
        const double tolerance = 1.0;

        // Strategy 1: exact single entry match
        var exact = _linkableEntries.FirstOrDefault(e => Math.Abs(e.TotalTds - target) < tolerance);
        if (exact != null)
        {
            _selectedEntryIds = new HashSet<int> { exact.Id };
            _autoMatchedIds   = new HashSet<int> { exact.Id };
            _autoMatchMsg = $"✔ Exact match — 1 entry";
            _autoMatchOk  = true;
            _ = ClearAutoMatchMsgAfterDelay();
            return;
        }

        // Strategy 2: greedy accumulation (sorted by TotalTds desc for best fit)
        var candidates = _linkableEntries.OrderByDescending(e => e.TotalTds).ToList();
        var picked     = new HashSet<int>();
        double running = 0;
        foreach (var e in candidates)
        {
            if (running + e.TotalTds <= target + tolerance)
            {
                picked.Add(e.Id);
                running += e.TotalTds;
                if (Math.Abs(running - target) < tolerance) break;
            }
        }

        if (picked.Count > 0 && Math.Abs(running - target) < tolerance)
        {
            _selectedEntryIds = picked;
            _autoMatchedIds   = new HashSet<int>(picked);
            _autoMatchMsg = $"✔ Matched {picked.Count} entries — ₹{running:N0}";
            _autoMatchOk  = true;
        }
        else if (picked.Count > 0)
        {
            _selectedEntryIds = picked;
            _autoMatchedIds   = new HashSet<int>(picked);
            _autoMatchMsg = $"⚠ Best fit: {picked.Count} entries (₹{running:N0}) — review difference";
            _autoMatchOk  = false;
        }
        else
        {
            _autoMatchMsg = "No matching combination found";
            _autoMatchOk  = false;
        }
        _ = ClearAutoMatchMsgAfterDelay();
        await Task.CompletedTask;
    }

    async Task ClearAutoMatchMsgAfterDelay()
    {
        await Task.Delay(5000);
        _autoMatchMsg = "";
        await InvokeAsync(StateHasChanged);
    }

    void OnQuarterChanged(string q)
    {
        if (_editing == null) return;
        _editing.Quarter = q;
        LoadLinkableEntries(q, _editing.ChallanNo);
    }

    void ToggleEntry(int id, bool value)
    {
        if (value) _selectedEntryIds.Add(id);
        else _selectedEntryIds.Remove(id);
    }

    void ToggleAll(bool value)
    {
        if (value) _selectedEntryIds = _linkableEntries.Select(e => e.Id).ToHashSet();
        else _selectedEntryIds.Clear();
    }

    void Save()
    {
        if (_editing == null) return;
        if (AppState.IsReadOnlyFY)
        {
            Snackbar.Add($"{TaxRules.YearLabel(AppState.CurrentFY)} is locked (past year).", Severity.Warning);
            return;
        }

        // Validations
        if (string.IsNullOrWhiteSpace(_editing.ChallanNo))
            { _saveError = "Challan No is required."; return; }
        var challanDigits = new string(_editing.ChallanNo.Where(char.IsDigit).ToArray());
        if (challanDigits.Length != 5)
            { _saveError = "Challan serial must be exactly 5 digits (e.g. 00001)."; return; }
        if (string.IsNullOrWhiteSpace(_editing.BsrCode))
            { _saveError = "BSR Code is required."; return; }
        if (!System.Text.RegularExpressions.Regex.IsMatch(_editing.BsrCode, @"^\d{7}$"))
            { _saveError = "BSR Code must be exactly 7 digits (e.g. 0510308)."; return; }
        if (!_challanDate.HasValue)
            { _saveError = "Challan date is required."; return; }
        if (_challanDate.Value.Date > DateTime.Today)
            { _saveError = "Challan date cannot be a future date."; return; }

        _editing.ChallanDate = _challanDate.Value;
        // Auto-calculate total
        _editing.TotalAmount = Math.Round(
            _editing.TdsAmount + _editing.Surcharge + _editing.Cess +
            _editing.Interest + _editing.LateFee + _editing.Amount, 0);

        var (ok, msg) = Svc.Save(_editing);
        if (!ok) { _saveError = msg; return; }

        // Link/unlink entries
        if (_selectedEntryIds.Any() || _previouslyLinkedIds.Any())
        {
            var toLink   = _selectedEntryIds.ToList();
            var toUnlink = _previouslyLinkedIds.Except(_selectedEntryIds).ToList();
            EntrySvc.LinkEntriesToChallan(_editing.ChallanNo, toLink, toUnlink);
        }

        _dialogOpen = false; Load(); RefreshUnlinked(); RefreshChallanLinked();
        AppState.NotifyStateChanged();
        Snackbar.Add($"Challan saved. {_selectedEntryIds.Count} entries linked.", Severity.Success);
    }

    async Task DeleteItem(Challan c)
    {
        if (AppState.IsReadOnlyFY)
        {
            Snackbar.Add($"{TaxRules.YearLabel(AppState.CurrentFY)} is locked (past year).", Severity.Warning);
            return;
        }
        int linkedCount = 0;
        try
        {
            using var conn = CDeTDS.DAL.Database.GetConnection();
            using var cmd  = conn.CreateCommand();
            cmd.CommandText = "SELECT COUNT(*) FROM tds_entries WHERE challan_no=@cn AND deductor_id=@d";
            cmd.Parameters.AddWithValue("@cn", c.ChallanNo ?? "");
            cmd.Parameters.AddWithValue("@d",  c.DeductorId);
            linkedCount = (int)(long)(cmd.ExecuteScalar() ?? 0L);
        }
        catch { linkedCount = -1; }
        var linkMsg = linkedCount > 0
            ? $"\n\n⚠ {linkedCount} TDS entr{(linkedCount == 1 ? "y" : "ies")} linked to this challan will be unlinked."
            : linkedCount < 0
            ? "\n\n⚠ Could not check linked entries — verify TDS Entries after deletion."
            : "";
        var confirmed = await DialogSvc.ShowMessageBox(
            "Delete Challan?",
            $"Delete challan '{c.ChallanNo}' — ₹{c.TotalAmount:N0}?{linkMsg}",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;
        var (ok, msg) = Svc.Delete(c.Id);
        if (ok) { Load(); AppState.NotifyStateChanged(); Snackbar.Add("Deleted.", Severity.Success); }
        else Snackbar.Add(msg, Severity.Error);
    }

    void NavigateToPrint(int challanId)
        => Nav.NavigateTo($"/challan/print?id={challanId}");

    public void Dispose() => AppState.OnChange -= Reload;
}
