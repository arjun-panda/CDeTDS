@page "/settings"
@inject AppStateService AppState
@inject ISnackbar Snackbar
@inject UpdateCheckService UpdateSvc
@inject IDialogService DialogSvc
@using System.IO
@using System.IO.Compression
@using CDeTDS.BLL
@using CDeTDS.Common
@using CDeTDS.DAL

<MudText Typo="Typo.h5" Class="mb-4">Settings</MudText>

<MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

    @* ── GENERAL ── *@
    <MudTabPanel Text="General" Icon="@Icons.Material.Filled.Settings">
        <MudText Typo="Typo.subtitle1" Class="mb-3">General Settings</MudText>

        <MudGrid>
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2">Application Data Folder</MudText>
                <MudText Color="Color.Secondary" Class="mb-2">@AppState.AppDataPath</MudText>
            </MudItem>

            <MudItem xs="6">
                <MudTextField @bind-Value="_basePath" Label="TDS Data Base Folder"
                              Variant="Variant.Outlined"
                              HelperText="FVU files, returns, and reports are stored here" />
            </MudItem>
            <MudItem xs="6" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveBasePath">Apply Path</MudButton>
                <MudButton Class="ml-2" Variant="Variant.Text" OnClick="OpenBaseFolder">Open Folder</MudButton>
            </MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2">Current Company Folder</MudText>
                @{
                    var compFolder = CDeTDS.DAL.FolderManager.CompanyFolder;
                    var hasCompany = !string.IsNullOrEmpty(compFolder) && compFolder != CDeTDS.DAL.FolderManager.BasePath;
                }
                @if (hasCompany)
                {
                    <div style="display:flex;align-items:center;gap:8px">
                        <MudText Color="Color.Secondary" Style="font-size:12px;word-break:break-all">@compFolder</MudText>
                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                   OnClick='() => { try { CDeTDS.DAL.FolderManager.OpenFolder(compFolder); } catch { } }'>
                            Open
                        </MudButton>
                    </div>
                }
                else
                {
                    <MudText Color="Color.Secondary" Style="font-size:12px">No company selected — select a deductor first.</MudText>
                }
            </MudItem>

            <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Change Password</MudText>
            </MudItem>
            <MudItem xs="4">
                <MudTextField @bind-Value="_oldPassword" Label="Current Password"
                              InputType="InputType.Password" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField @bind-Value="_newPassword" Label="New Password"
                              InputType="InputType.Password" Variant="Variant.Outlined"
                              HelperText="@PwdStrengthLabel(_newPassword)" />
                @{ var sc = PwdStrengthScore(_newPassword); }
                @if (_newPassword.Length > 0)
                {
                    <div style="height:4px;border-radius:2px;margin-top:4px;background:@(sc==1?"#ef4444":sc==2?"#f59e0b":sc==3?"#22c55e":"#94a3b8");width:@(sc*25)%;transition:width .3s"></div>
                }
            </MudItem>
            <MudItem xs="4">
                <MudTextField @bind-Value="_confirmPassword" Label="Confirm Password"
                              InputType="InputType.Password" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ChangePassword">
                    Change Password
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* ── FVU / PORTALS ── *@
    <MudTabPanel Text="FVU & Portals" Icon="@Icons.Material.Filled.Link">

        @* ── Java Status Card ── *@
        <div style="border:1px solid @(_javaOk?"#a5d6a7":"#ffcc80");border-radius:8px;padding:12px 16px;margin-bottom:16px;
                    background:@(_javaOk?"#f1f8e9":"#fff8e1")">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
                <span style="font-size:18px">@(_javaOk ? "✅" : "⚠️")</span>
                <span style="font-weight:700;font-size:14px;color:@(_javaOk?"#2e7d32":"#e65100")">
                    Java — @(_javaOk ? "Detected" : "Not Configured")
                </span>
                @if (_javaOk)
                {
                    <span style="font-size:11px;color:#555;background:#e8f5e9;padding:2px 8px;border-radius:10px">@_javaVersion</span>
                }
            </div>
            <MudGrid Spacing="2">
                <MudItem xs="8">
                    <MudTextField @bind-Value="_javaPath" Label="Java Executable Path"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Placeholder="C:\Program Files\Java\jre\bin\java.exe"
                                  HelperText="Auto-detected from system. Override only if needed." />
                </MudItem>
                <MudItem xs="2" Class="d-flex align-center gap-1">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="AutoDetectJava"
                               StartIcon="@Icons.Material.Filled.Search">Detect</MudButton>
                </MudItem>
                <MudItem xs="2" Class="d-flex align-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="SaveJavaPath">Save</MudButton>
                </MudItem>
            </MudGrid>
        </div>

        @* ── FVU Jar Status Card ── *@
        <div style="border:1px solid @(_fvuOk?"#a5d6a7":"#ffcc80");border-radius:8px;padding:12px 16px;margin-bottom:16px;
                    background:@(_fvuOk?"#f1f8e9":"#fff8e1")">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
                <span style="font-size:18px">@(_fvuOk ? "✅" : "⚠️")</span>
                <span style="font-weight:700;font-size:14px;color:@(_fvuOk?"#2e7d32":"#e65100")">
                    FVU Jar — @(_fvuOk ? $"Found: {Path.GetFileName(_fvuPath)}" : "Not Found")
                </span>
                @if (_fvuOk)
                {
                    <span style="font-size:11px;color:#555;margin-left:4px">@_fvuPath</span>
                }
            </div>

            @if (!_fvuOk)
            {
                @* ── One-click download & watch ── *@
                <div style="background:#e3f2fd;border-radius:6px;padding:10px 14px;margin-bottom:10px">
                    <div style="font-size:12px;font-weight:700;color:#1565C0;margin-bottom:6px">
                        ⚡ Auto-Install FVU
                    </div>
                    <div style="font-size:11px;color:#555;margin-bottom:8px;line-height:1.6">
                        Downloads the official FVU 9.4 from Protean, extracts and installs automatically.
                        Requires internet. If download fails, it falls back to any zip you've already downloaded.
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick="InstallFvuFromDownloads" Disabled="_fvuInstalling">
                            @if (_fvuInstalling)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                <span>Installing FVU...</span>
                            }
                            else
                            {
                                <span>Download & Install FVU 9.4</span>
                            }
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.OpenInBrowser"
                                   OnClick="OpenFvuDownloadPage">
                            Protean Download Page
                        </MudButton>
                    </div>
                    @if (!string.IsNullOrEmpty(_fvuInstallMsg))
                    {
                        <MudAlert Severity="@_fvuInstallSeverity" Dense="true" Class="mt-2">@_fvuInstallMsg</MudAlert>
                    }
                </div>
                <div style="font-size:11px;color:#777;margin-bottom:8px">
                    — or manually paste the path to an already-downloaded jar below —
                </div>
            }

            <MudGrid Spacing="2">
                <MudItem xs="8">
                    <MudTextField @bind-Value="_fvuPath" Label="NSDL FVU Utility Path (.jar)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Placeholder="C:\Program Files\CDeTDS\FVU\TDS_STANDALONE_FVU_9.4.jar"
                                  HelperText="Full path to the main FVU jar (not VersionValidator.jar)" />
                </MudItem>
                <MudItem xs="2" Class="d-flex align-center">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="AutoDetectFvu"
                               StartIcon="@Icons.Material.Filled.Search">Detect</MudButton>
                </MudItem>
                <MudItem xs="2" Class="d-flex align-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="SaveFvuPath">Save</MudButton>
                </MudItem>
            </MudGrid>
        </div>

        @* ── Overall readiness ── *@
        @if (_javaOk && _fvuOk)
        {
            <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                ✅ FVU is fully configured. You can generate and validate returns from the Returns / FVU page.
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                Complete the above setup to enable FVU validation. The .txt file can still be generated without Java/FVU.
            </MudAlert>
        }

    </MudTabPanel>

    @* ── IT PORTAL ── *@
    <MudTabPanel Text="IT Portal" Icon="@Icons.Material.Filled.CloudDownload">
        <MudText Typo="Typo.subtitle1" Class="mb-1">IT Portal Credentials</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
            Used for one-click CSI file download. Credentials are stored locally in the app database.
        </MudText>
        <MudGrid>
            <MudItem xs="5">
                <MudTextField @bind-Value="_itPortalUserId" Label="TAN / User ID"
                              Variant="Variant.Outlined"
                              HelperText="Same as your IT portal login ID (TAN)" />
            </MudItem>
            <MudItem xs="5">
                <MudTextField @bind-Value="_itPortalPassword" Label="IT Portal Password"
                              InputType="@(_showItPass ? InputType.Text : InputType.Password)"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showItPass ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="() => _showItPass = !_showItPass"
                              HelperText="Stored encrypted in local DB — never transmitted to anyone except the IT portal" />
            </MudItem>
            <MudItem xs="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveItPortalCreds">Save</MudButton>
            </MudItem>
        </MudGrid>
        @if (!string.IsNullOrEmpty(_itPortalSaveMsg))
        {
            <MudAlert Severity="@_itPortalSaveSeverity" Dense="true" Class="mt-3">@_itPortalSaveMsg</MudAlert>
        }
    </MudTabPanel>

    @* ── BACKUP ── *@
    <MudTabPanel Text="Backup & Restore" Icon="@Icons.Material.Filled.Backup">
        <MudText Typo="Typo.subtitle1" Class="mb-3">Backup &amp; Restore</MudText>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Daily backups run automatically on first launch each day (last 30 days kept). Use <strong>Backup Now</strong> before any risky operation.
        </MudAlert>
        <div style="display:flex;gap:10px;align-items:center;margin-bottom:14px;flex-wrap:wrap">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Backup" OnClick="DoBackupNow">
                Backup Now
            </MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadBackupFiles">
                Refresh List
            </MudButton>
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.FolderOpen" OnClick="OpenBackupFolder">
                Open Folder
            </MudButton>
            <span style="margin-left:auto;color:#64748b;font-size:12px">
                @_backupInfos.Count backup@(_backupInfos.Count == 1 ? "" : "s") · @_backupInfos.Count(b => b.IsAuto) auto · @_backupInfos.Count(b => !b.IsAuto) manual
            </span>
        </div>
        <div style="font-size:11px;color:#64748b;margin-bottom:8px">
            DB: <code>@_dbPath</code> · Backup folder: <code>@FolderManager.BackupFolder</code>
        </div>

        @if (_backupInfos.Count == 0)
        {
            <MudAlert Severity="Severity.Warning" Dense="true">No backups found yet. Click <strong>Backup Now</strong> to create one.</MudAlert>
        }
        else
        {
            <table class="mtbl" style="font-size:12px;width:100%">
                <thead style="background:#f1f5f9">
                    <tr>
                        <th style="text-align:left">File</th>
                        <th style="text-align:center;width:80px">Type</th>
                        <th style="text-align:right;width:90px">Size</th>
                        <th style="text-align:right;width:160px">Created</th>
                        <th style="text-align:right;width:80px">Age</th>
                        <th style="text-align:center;width:160px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in _backupInfos)
                    {
                        var file = b;
                        var age = DateTime.Now - file.CreatedAt;
                        var ageLabel = age.TotalDays >= 1 ? $"{(int)age.TotalDays}d ago"
                                     : age.TotalHours >= 1 ? $"{(int)age.TotalHours}h ago"
                                     : age.TotalMinutes >= 1 ? $"{(int)age.TotalMinutes}m ago" : "now";
                        <tr>
                            <td style="font-family:monospace">@file.FileName</td>
                            <td style="text-align:center">
                                @if (file.IsAuto)
                                {
                                    <span style="background:#dbeafe;color:#1d4ed8;padding:1px 6px;border-radius:8px;font-size:10px">AUTO</span>
                                }
                                else
                                {
                                    <span style="background:#fef3c7;color:#92400e;padding:1px 6px;border-radius:8px;font-size:10px">MANUAL</span>
                                }
                            </td>
                            <td style="text-align:right;font-family:monospace">@file.SizeLabel</td>
                            <td style="text-align:right">@file.CreatedAt.ToString("dd-MMM-yyyy HH:mm")</td>
                            <td style="text-align:right;color:#64748b">@ageLabel</td>
                            <td style="text-align:center">
                                <button class="rm-btn" style="background:#dbeafe;color:#1d4ed8;border:1px solid #93c5fd;margin-right:4px"
                                        @onclick="@(() => ConfirmRestore(file.Path))" title="Restore this backup (overwrites current DB)">⤴ Restore</button>
                                <button class="rm-btn" style="background:#fee2e2;color:#991b1b;border:1px solid #fca5a5"
                                        @onclick="@(() => ConfirmDeleteBackup(file))" title="Delete this backup file">✕</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @* Delete confirmation dialog *@
        <MudDialog @bind-Visible="_deleteConfirmOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, CloseButton = true })">
            <TitleContent><MudText Typo="Typo.h6">Delete backup?</MudText></TitleContent>
            <DialogContent>
                <MudText>This will permanently delete:</MudText>
                <MudText Style="font-family:monospace;margin-top:8px">@(_deleteTarget?.FileName ?? "")</MudText>
                <MudText Color="Color.Secondary" Class="mt-2">Created @(_deleteTarget?.CreatedAt.ToString("dd-MMM-yyyy HH:mm") ?? "") · @(_deleteTarget?.SizeLabel ?? "")</MudText>
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="@(() => _deleteConfirmOpen = false)">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DoDeleteBackup">Delete</MudButton>
            </DialogActions>
        </MudDialog>
    </MudTabPanel>

    @* ── FY ROLLOVER ── *@
    <MudTabPanel Text="FY Rollover" Icon="@Icons.Material.Filled.FastForward">
        <MudText Typo="Typo.subtitle1" Class="mb-2">Year-End Rollover</MudText>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            <b>Run this once in April</b> after the financial year ends to prepare payroll for the new FY.
            Copies each employee's salary structure and HRA settings to the new FY and seeds April salary as Draft.
            Investment declarations (80C, 80D etc.) are reset to zero — employees re-submit Form 12BB.
            Old entries, challans, and returns are never touched — they remain accessible via the FY selector.
        </MudAlert>
        <MudGrid>
            <MudItem xs="4">
                <MudSelect @bind-Value="_rollFromFy" Label="From FY" Variant="Variant.Outlined">
                    @foreach (var fy in CDeTDS.Common.AppConstants.FinancialYears)
                    {
                        <MudSelectItem Value="@fy">@fy</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="4">
                <MudSelect @bind-Value="_rollToFy" Label="To FY" Variant="Variant.Outlined">
                    @foreach (var fy in CDeTDS.Common.AppConstants.FinancialYearsWithNext)
                    {
                        <MudSelectItem Value="@fy">@fy</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="4" Class="d-flex align-center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.FastForward"
                           OnClick="DoRollover" Disabled="@_rolloverRunning">
                    @(_rolloverRunning ? "Running..." : "Run Rollover")
                </MudButton>
            </MudItem>
        </MudGrid>
        @if (_rolloverResult != null)
        {
            <MudAlert Severity="@(_rolloverResult.HasErrors ? Severity.Warning : Severity.Success)" Class="mt-3">
                <b>@_rolloverResult.EmpTotal employees</b> processed &nbsp;·&nbsp;
                Declarations copied: <b>@_rolloverResult.DeclCopied</b> (skipped: @_rolloverResult.DeclSkipped) &nbsp;·&nbsp;
                April seeded: <b>@_rolloverResult.AprilSeeded</b> (skipped: @_rolloverResult.AprilSkipped)
                @if (_rolloverResult.HasErrors)
                {
                    <ul class="mt-2">
                        @foreach (var e in _rolloverResult.Errors)
                        {
                            <li>@e</li>
                        }
                    </ul>
                }
            </MudAlert>
        }
    </MudTabPanel>

    @* ── DUE DATES ── *@
    <MudTabPanel Text="Due Dates" Icon="@Icons.Material.Filled.DateRange">
        <MudText Typo="Typo.subtitle1" Class="mb-3">Due Date Reminders</MudText>
        <MudGrid>
            <MudItem xs="4">
                <MudNumericField @bind-Value="_dueSoonDays" Label="Alert Days Before Due"
                                 Variant="Variant.Outlined" HideSpinButtons="true"
                                 HelperText="Show warning this many days before deadline" />
            </MudItem>
            <MudItem xs="4" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDueSoonDays">
                    Save
                </MudButton>
            </MudItem>

            <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Quarter Filing Status</MudText>
            </MudItem>
            @foreach (var q in _quarters)
            {
                <MudItem xs="6">
                    <MudCheckBox T="bool" Value="@IsQuarterFiled(q)"
                                 ValueChanged="@((v) => SetQuarterFiled(q, v))"
                                 Label="@($"Q{q} ({QuarterLabel(q)}) filed")" />
                </MudItem>
            }
        </MudGrid>
    </MudTabPanel>

    @* ── ABOUT ── *@
    <MudTabPanel Text="About" Icon="@Icons.Material.Filled.Info">
        <MudGrid Spacing="4">
            @* Left: App info *@
            <MudItem xs="12" md="5">
                <div class="d-flex flex-column align-center pa-4">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary"
                             Style="font-size:56px" Class="mb-3" />
                    <MudText Typo="Typo.h4" Style="font-weight:700;color:#1565C0">CDeTDS</MudText>
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-3">
                        TDS Compliance Software — Income-tax Act 2025
                    </MudText>
                    <MudDivider Style="width:180px" Class="mb-3" />
                    <MudSimpleTable Dense="true" Class="mb-3" Style="width:100%">
                        <tbody>
                            <tr><td><b>Version</b></td><td>v@(AppConstants.AppVersion)</td></tr>
                            <tr><td><b>Framework</b></td><td>.NET 8 · Blazor · MudBlazor</td></tr>
                            <tr><td><b>Database</b></td><td>SQLite (WAL mode)</td></tr>
                            <tr><td><b>FVU Utility</b></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(_localFvuVersion))
                                    {
                                        @if (!string.IsNullOrEmpty(_latestFvuVersion) && _fvuOutdated)
                                        {
                                            <span style="color:#b45309">v@_localFvuVersion ⚠ v@_latestFvuVersion available</span>
                                        }
                                        else
                                        {
                                            <span style="color:#166534">v@_localFvuVersion ✓</span>
                                        }
                                    }
                                    else { <span style="color:#9ca3af">Not configured</span> }
                                </td>
                            </tr>
                            <tr><td><b>License</b></td><td>@AppState.CurrentLicense.TierLabel</td></tr>
                            <tr><td><b>Expires</b></td><td>@AppState.CurrentLicense.ExpiryDate.ToString("dd-MMM-yyyy") (@AppState.CurrentLicense.DaysLeft days)</td></tr>
                            <tr><td><b>Machine ID</b></td><td style="font-family:monospace;font-size:11px">@_machineId</td></tr>
                        </tbody>
                    </MudSimpleTable>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Developed by <b>Arjun Panda</b> &nbsp;·&nbsp; © @DateTime.Today.Year
                    </MudText>
                    <MudText Typo="Typo.caption">
                        <a href="mailto:admin@capitaldesk.co.in" style="color:#1565C0">admin@capitaldesk.co.in</a>
                    </MudText>
                </div>
            </MudItem>

            @* Right: Actions *@
            <MudItem xs="12" md="7">
                <MudCard Elevation="1" Class="mb-3">
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.subtitle1"><b>Updates</b></MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (!string.IsNullOrEmpty(_aboutUpdateMsg))
                        {
                            <MudAlert Severity="@_aboutUpdateSeverity" Dense="true" Class="mb-2">@_aboutUpdateMsg</MudAlert>
                        }
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   Disabled="_checkingUpdate" OnClick="CheckForUpdatesAbout">
                            @if (_checkingUpdate) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                            Check for Updates
                        </MudButton>
                        @if (!string.IsNullOrEmpty(_updateDownloadUrl))
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Class="ml-2"
                                       StartIcon="@Icons.Material.Filled.Download"
                                       OnClick="OpenDownloadPage">
                                Download v@_latestVersion
                            </MudButton>
                        }
                        @if (_fvuOutdated && !string.IsNullOrEmpty(_fvuDownloadUrl))
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Class="ml-2"
                                       StartIcon="@Icons.Material.Filled.Update"
                                       OnClick="OpenFvuDownloadPage">
                                Download FVU v@_latestFvuVersion
                            </MudButton>
                        }
                    </MudCardActions>
                </MudCard>

                <MudCard Elevation="1" Class="mb-3">
                    <MudCardHeader>
                        <CardHeaderContent>
