    async Task CheckForUpdatesAbout()
    {
        _checkingUpdate  = true;
        _aboutUpdateMsg  = "";
        _updateDownloadUrl = "";
        StateHasChanged();
        var info = await UpdateSvc.CheckAsync(forceCheck: true);
        if (info != null)
        {
            // App update
            if (info.IsNewer)
            {
                _aboutUpdateMsg     = $"v{info.Version} is available ({info.ReleaseDate}): {info.Notes}";
                _aboutUpdateSeverity = Severity.Warning;
                _updateDownloadUrl  = info.DownloadUrl;
                _latestVersion      = info.Version;
            }
            else
            {
                _aboutUpdateMsg      = $"You are on the latest version (v{AppConstants.AppVersion}).";
                _aboutUpdateSeverity = Severity.Success;
            }
            // FVU version check
            if (!string.IsNullOrEmpty(info.FvuLatestVersion))
            {
                _latestFvuVersion = info.FvuLatestVersion;
                _fvuDownloadUrl   = info.FvuDownloadUrl;
                _localFvuVersion  = CDeTDS.DAL.FvuUtilityRunner.GetLocalFvuVersion();
                if (!string.IsNullOrEmpty(_localFvuVersion))
                {
                    try { _fvuOutdated = Version.Parse(_latestFvuVersion) > Version.Parse(_localFvuVersion); }
                    catch { _fvuOutdated = false; }
                }
                if (_fvuOutdated && !info.IsNewer)
                {
                    _aboutUpdateMsg      = $"FVU update available: v{_latestFvuVersion}. App is up to date (v{AppConstants.AppVersion}).";
                    _aboutUpdateSeverity = Severity.Warning;
                }
            }
        }
        else
        {
            _aboutUpdateMsg      = $"You are on the latest version (v{AppConstants.AppVersion}).";
            _aboutUpdateSeverity = Severity.Success;
        }
        _checkingUpdate = false;
    }

    void OpenDownloadPage()
    {
