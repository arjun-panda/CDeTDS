    void ConfirmRestore(string path)
    {
        _restorePath = path; _restoreConfirmOpen = true;
    }

    void DoRestore()
    {
        _restoreConfirmOpen = false;
        if (string.IsNullOrEmpty(_restorePath)) return;
        try
        {
            // Checkpoint WAL into main DB file before copying so restore is consistent
            Database.CheckpointAndClose();

            if (File.Exists(_dbPath))
            {
                var safeguard = _dbPath + $".pre_restore_{DateTime.Now:yyyyMMdd_HHmmss}.bak";
                File.Copy(_dbPath, safeguard, overwrite: false);
            }

            File.Copy(_restorePath, _dbPath, overwrite: true);

            // Remove stale WAL/SHM files so restored DB opens cleanly
            foreach (var ext in new[] { "-wal", "-shm" })
            {
                var f = _dbPath + ext;
                if (File.Exists(f)) File.Delete(f);
            }

            Snackbar.Add($"Restored from {Path.GetFileName(_restorePath)}. Restart the app to apply.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Restore failed: " + ex.Message, Severity.Error); }
        finally { _restorePath = ""; }
    }

    // ── Rollover ──
    async Task DoRollover()
    {
        if (_rollFromFy == _rollToFy)
        {
            Snackbar.Add("From FY and To FY must be different.", Severity.Warning);
            return;
        }
        var confirmed = await DialogSvc.ShowMessageBox(
            "Run FY Rollover?",
            $"This will copy declarations from {_rollFromFy} → {_rollToFy} and seed April salary as Draft for all active employees. Existing entries are NOT overwritten.",
            yesText: "Run", cancelText: "Cancel");
        if (confirmed != true) return;

        _rolloverRunning = true;
        _rolloverResult  = null;
        StateHasChanged();

        await Task.Run(() =>
        {
            var svc = new CDeTDS.BLL.RolloverService();
            _rolloverResult = svc.Execute(AppState.CurrentDeductorId, _rollFromFy, _rollToFy);
        });

        _rolloverRunning = false;
        var msg = _rolloverResult!.HasErrors
            ? $"Rollover completed with warnings. {_rolloverResult.AprilSeeded} seeded."
            : $"Rollover complete. {_rolloverResult.AprilSeeded} employees seeded for April {_rollToFy}.";
        Snackbar.Add(msg, _rolloverResult.HasErrors ? Severity.Warning : Severity.Success);
    }

