                            <pre style="font-size:11px;line-height:1.6;white-space:pre-wrap;max-height:260px;overflow-y:auto;
                                        background:#f8f9fa;border-radius:4px;padding:10px;margin:0;font-family:monospace">@_changelogText</pre>
                        </MudCardContent>
                    }
                </MudCard>

                <MudCard Elevation="1">
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.subtitle1"><b>Support &amp; Diagnostics</b></MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Class="mb-1"><b>Log folder:</b></MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family:monospace;word-break:break-all">@_logFolder</MudText>
