        catch { }
    }

    static string LoadLatestChangelog()
    {
        try
        {
            var path = Path.Combine(AppContext.BaseDirectory, "CHANGELOG.txt");
            if (!File.Exists(path)) return "Changelog not found.";
            var lines = File.ReadAllLines(path);
            // Collect lines from the first version header up to (but not including) the second
            var result = new System.Text.StringBuilder();
            bool started = false;
            foreach (var line in lines)
            {
                bool isVersionHeader = line.StartsWith("v") && line.Length > 4 && line[1] >= '0' && line[1] <= '9';
                if (isVersionHeader)
                {
                    if (started) break;   // second version block — stop
                    started = true;
                }
                if (started) result.AppendLine(line);
            }
            return result.Length > 0 ? result.ToString().TrimEnd() : "No changelog entries found.";
        }
        catch { return "Could not read changelog."; }
    }

    void OpenLogFolder()
    {
        try
        {
            Directory.CreateDirectory(_logFolder);
            System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo(_logFolder) { UseShellExecute = true });
        }
        catch { Snackbar.Add("Could not open log folder: " + _logFolder, Severity.Warning); }
    }

    void SendLogToSupport()
    {
        try
        {
            // Collect last 30 lines per log file (mailto: URI has ~2000 char limit)
            var logs = new System.Text.StringBuilder();
            if (Directory.Exists(_logFolder))
            {
                foreach (var f in Directory.GetFiles(_logFolder, "*.log"))
                {
                    logs.AppendLine($"=== {Path.GetFileName(f)} ===");
                    var lines = File.ReadAllLines(f);
                    foreach (var l in lines.TakeLast(30)) logs.AppendLine(l);
                    logs.AppendLine();
                }
            }
            else
            {
                logs.AppendLine("No log files found — app has not encountered any errors yet.");
            }

            var rawBody =
                $"CDeTDS v{AppConstants.AppVersion}\n" +
                $"Machine ID: {_machineId}\n" +
                $"Date: {DateTime.Now:dd-MMM-yyyy HH:mm}\n\n" +
                $"--- LOG EXCERPT ---\n{logs}";

            // Truncate to keep mailto URI under 1800 chars after encoding
            if (rawBody.Length > 900) rawBody = rawBody[..900] + "\n...(truncated — attach full log from folder above)";

            var body    = Uri.EscapeDataString(rawBody);
            var subject = Uri.EscapeDataString($"CDeTDS Support Log — v{AppConstants.AppVersion}");
            System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo(
                $"mailto:admin@capitaldesk.co.in?subject={subject}&body={body}")
                { UseShellExecute = true });
            _logSentMsg = "Email drafted. Attach the full log from the folder above and send to support.";
        }
        catch { Snackbar.Add("Please manually email logs from: " + _logFolder, Severity.Info); }
    }

