    // Calculator
    private string _section       = "194J";
    private double _amount        = 100000;
    private string _deducteeType  = "Individual";
    private bool   _panAvailable  = true;
    private bool   _itrFiled      = true;
    private double _lowerCertRate = 0;
    private TdsCalculationResult? _calcResult;

    // Rules table
    private List<TdsRule> _allRules    = new();
    private string        _rulesSearch = "";
    private bool          _showInactive = false;

    // Rule dialog
    private bool     _ruleDialogOpen = false;
    private TdsRule? _editingRule;
    private DateTime? _ruleEffFrom;
    private DateTime? _ruleEffTo;
    private string   _ruleSaveError = "";

    // Rules status tab
    private string   _rulesDbVersion   = "";
    private int      _ruleCount        = 0;
    private bool     _updatingRules    = false;
    private string   _rulesUpdateMsg   = "";
    private Severity _rulesUpdateSeverity = Severity.Info;

    // IT Act 2025 payment-code activation (future: final new-act FVU/RPU)
    private bool _usePaymentCodes;
    private int  _payCodeCount;

    private IEnumerable<TdsRule> FilteredRules => _allRules.Where(r =>
        (_showInactive || r.IsActive) &&
        (string.IsNullOrEmpty(_rulesSearch) ||
         r.SectionCode.Contains(_rulesSearch, StringComparison.OrdinalIgnoreCase) ||
         r.NatureOfPayment.Contains(_rulesSearch, StringComparison.OrdinalIgnoreCase) ||
         r.DeducteeType.Contains(_rulesSearch, StringComparison.OrdinalIgnoreCase)));

    protected override void OnInitialized()
    {
        AppState.OnChange += Reload;
        LoadRules();
        LoadRulesStatus();
    }

    void LoadRules()
    {
        try { _allRules = RulesSvc.GetAllRules(activeOnly: false); }
        catch (Exception ex) { Snackbar.Add("Failed to load rules: " + ex.Message, Severity.Error); }
    }

    void LoadRulesStatus()
    {
        try
        {
            _rulesDbVersion   = CDeTDS.DAL.Database.GetSetting("RULES_VERSION", "Not applied");
            _ruleCount        = _allRules.Count;
            _usePaymentCodes  = CDeTDS.DAL.Database.GetSetting("FVU_USE_PAYMENT_CODES", "0") == "1";
            _payCodeCount     = _allRules.Count(r => !string.IsNullOrEmpty(r.PaymentCode));
        }
        catch { }
    }

    void TogglePaymentCodes(bool on)
    {
        _usePaymentCodes = on;
        try
        {
            CDeTDS.DAL.Database.SetSetting("FVU_USE_PAYMENT_CODES", on ? "1" : "0");
            CDeTDS.DAL.Database.LogAction("admin", on ? "ENABLE" : "DISABLE", "TdsRules",
                "IT Act 2025 payment codes in e-TDS files");
            Snackbar.Add(on
                ? "⚠ Payment codes enabled. Staged codes are from the Protean RPU v1.0 BETA — do not file real returns until they are re-verified against the FINAL FVU/RPU release."
                : "Payment codes disabled — new-act files use the interim 392/393 codes.",
                on ? Severity.Warning : Severity.Info);
        }
        catch (Exception ex) { Snackbar.Add("Failed to save setting: " + ex.Message, Severity.Error); }
    }

    async Task ApplyBuiltInRules()
    {
        _updatingRules   = true;
        _rulesUpdateMsg  = "";
        StateHasChanged();
        var msg = await Task.Run(() => new RulesUpdateService().AutoUpdateIfNeeded());
        _rulesUpdateMsg      = msg;
        _rulesUpdateSeverity = msg.StartsWith("✓") || msg.Contains("up to date") ? Severity.Success : Severity.Warning;
        LoadRules();
        LoadRulesStatus();
        _updatingRules = false;
    }

    void Reload() { LoadRules(); StateHasChanged(); }

    void ResetCalc() { _calcResult = null; _amount = 100000; _lowerCertRate = 0; }

    void Calculate()
    {
        try
        {
            _calcResult = RulesSvc.Calculate(_section, _amount, _deducteeType,
                panAvailable: _panAvailable, itrFiled: _itrFiled, txDate: DateTime.Today);
            // apply LDC override
            if (_lowerCertRate > 0 && _calcResult != null && !_calcResult.BelowThreshold)
            {
                var ldc = _amount * _lowerCertRate / 100;
                _calcResult.ApplicableRate    = _lowerCertRate;
                _calcResult.TdsAmount         = ldc;
                _calcResult.SurchargeAmount   = 0;
                _calcResult.CessAmount        = ldc * 0.04;
                _calcResult.TotalTds          = ldc + _calcResult.CessAmount;
                _calcResult.RuleApplied      += $" [LDC u/s 197 @ {_lowerCertRate:N2}%]";
            }
        }
        catch (Exception ex) { _calcResult = null; Snackbar.Add("Calculation failed: " + ex.Message, Severity.Error); }
    }

    void OpenAddRule()
    {
        _editingRule = new TdsRule
        {
            IsActive = true, IsResident = true, DeducteeType = "All",
            CessRate = 4.0, EffectiveFrom = new DateTime(AppState.CurrentFY.Length >= 4 && int.TryParse(AppState.CurrentFY[..4], out var fyY) ? fyY : DateTime.Today.Year, 4, 1)
        };
        _ruleEffFrom   = _editingRule.EffectiveFrom;
        _ruleEffTo     = null;
        _ruleSaveError = "";
        _ruleDialogOpen = true;
    }

    void OpenEditRule(TdsRule r)
    {
        _editingRule = new TdsRule
        {
            Id = r.Id, SectionCode = r.SectionCode, NatureOfPayment = r.NatureOfPayment,
            DeducteeType = r.DeducteeType, IsResident = r.IsResident,
            ThresholdLimit = r.ThresholdLimit, TdsRate = r.TdsRate,
            SurchargeRate = r.SurchargeRate, CessRate = r.CessRate,
            EffectiveFrom = r.EffectiveFrom, EffectiveTo = r.EffectiveTo,
            ReferenceAct = r.ReferenceAct, Notes = r.Notes, IsActive = r.IsActive
        };
        _ruleEffFrom   = r.EffectiveFrom;
        _ruleEffTo     = r.EffectiveTo;
        _ruleSaveError = "";
        _ruleDialogOpen = true;
    }

    void SaveRule()
    {
        if (_editingRule == null) return;
        if (string.IsNullOrWhiteSpace(_editingRule.SectionCode))
            { _ruleSaveError = "Section code is required."; return; }
        if (string.IsNullOrWhiteSpace(_editingRule.NatureOfPayment))
            { _ruleSaveError = "Nature of payment is required."; return; }
        if (_ruleEffFrom.HasValue) _editingRule.EffectiveFrom = _ruleEffFrom.Value;
        _editingRule.EffectiveTo = _ruleEffTo;
        _editingRule.SectionCode = _editingRule.SectionCode.Trim().ToUpper();

        var (ok, msg) = RulesSvc.SaveRule(_editingRule);
        if (ok)
        {
            _ruleDialogOpen = false;
            LoadRules();
            Snackbar.Add("Rule saved.", Severity.Success);
        }
        else _ruleSaveError = msg;
    }

    async Task ToggleActive(TdsRule r)
    {
        var action = r.IsActive ? "deactivate" : "activate";
        var confirmed = await DialogSvc.ShowMessageBox(
            $"{(r.IsActive ? "Deactivate" : "Activate")} Rule?",
            $"{action.Substring(0,1).ToUpper() + action.Substring(1)} rule '{r.SectionCode} — {r.NatureOfPayment}'?",
            yesText: "Yes", cancelText: "Cancel");
        if (confirmed != true) return;
        var copy = new TdsRule
        {
            Id = r.Id, SectionCode = r.SectionCode, NatureOfPayment = r.NatureOfPayment,
            DeducteeType = r.DeducteeType, IsResident = r.IsResident,
            ThresholdLimit = r.ThresholdLimit, TdsRate = r.TdsRate,
            SurchargeRate = r.SurchargeRate, CessRate = r.CessRate,
            EffectiveFrom = r.EffectiveFrom, EffectiveTo = r.EffectiveTo,
            ReferenceAct = r.ReferenceAct, Notes = r.Notes,
            IsActive = !r.IsActive
        };
        var (ok, msg) = RulesSvc.SaveRule(copy);
        if (ok) { LoadRules(); Snackbar.Add($"Rule {action}d.", Severity.Info); }
        else Snackbar.Add(msg, Severity.Error);
    }

    public void Dispose() => AppState.OnChange -= Reload;
}
