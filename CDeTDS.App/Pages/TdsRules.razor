@page "/rules"
@inject TdsRulesService RulesSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc
@implements IDisposable
@inject AppStateService AppState
@using CDeTDS.BLL

<div class="d-flex align-center gap-3 mb-4">
    <MudText Typo="Typo.h5">TDS Rules</MudText>
    <MudSpacer />
    <MudText Typo="Typo.caption" Color="Color.Secondary">
        FY @AppState.CurrentFY · @AppState.CurrentLicense.TierLabel
    </MudText>
</div>

<MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

    @* ── Tab 1: Live Calculator ── *@
    <MudTabPanel Text="Live Calculator" Icon="@Icons.Material.Filled.Calculate">
        <MudGrid>
            <MudItem xs="3">
                <MudSelect @bind-Value="_section" Label="Section" Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var s in AppConstants.KnownSections)
                    { <MudSelectItem Value="@s">@s</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="3">
                <MudNumericField @bind-Value="_amount" Label="Amount (₹)" Variant="Variant.Outlined" Format="N2" HideSpinButtons="true" Class="amount-field" />
            </MudItem>
            <MudItem xs="3">
                <MudSelect @bind-Value="_deducteeType" Label="Deductee Type" Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var t in AppConstants.DeducteeTypes)
                    { <MudSelectItem Value="@t">@t</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="3" Class="d-flex align-end gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Calculate">Calculate</MudButton>
                <MudButton Variant="Variant.Text" OnClick="ResetCalc">Clear</MudButton>
            </MudItem>
            <MudItem xs="3">
                <MudCheckBox @bind-Value="_panAvailable" Label="PAN Available" />
            </MudItem>
            <MudItem xs="3">
                <MudTooltip Text="Section 206AB was removed by Finance Act 2025 w.e.f. 1-Apr-2025. No higher rate applies for ITR non-filers from FY 2025-26 onwards.">
                    <MudCheckBox @bind-Value="_itrFiled" Label="ITR Filed (206AB — removed FY25)" Disabled="true" />
                </MudTooltip>
            </MudItem>
            <MudItem xs="3">
                <MudNumericField @bind-Value="_lowerCertRate" Label="LDC Rate % (0=none)"
                                 Variant="Variant.Outlined" Format="N2" Min="0" Max="100"
                                 HideSpinButtons="true" Class="amount-field" HelperText="Lower deduction cert u/s 197" />
            </MudItem>
        </MudGrid>

        @if (_calcResult != null)
        {
            <MudDivider Class="my-4" />
            <MudGrid>
                <MudItem xs="12" md="5">
                    <MudPaper Class="pa-3" Elevation="0" Style="background:#e3f2fd;border-radius:8px">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Calculation Result</MudText>
                        <MudSimpleTable Dense="true">
                            <tbody>
                                <tr><td>Section</td><td><b>@_calcResult.SectionCode</b></td></tr>
                                <tr><td>Nature of Payment</td><td>@_calcResult.NatureOfPayment</td></tr>
                                <tr><td>Gross Amount</td><td>₹ @_calcResult.GrossAmount.ToString("N0")</td></tr>
                                <tr><td>Applicable Rate</td><td><b>@_calcResult.ApplicableRate %</b></td></tr>
                                <tr><td>TDS</td><td>₹ @_calcResult.TdsAmount.ToString("N0")</td></tr>
                                <tr><td>Surcharge</td><td>₹ @_calcResult.SurchargeAmount.ToString("N0")</td></tr>
                                <tr><td>Health & Ed Cess (4%)</td><td>₹ @_calcResult.CessAmount.ToString("N0")</td></tr>
                                <tr style="background:#1565C0;color:#fff">
                                    <td><b>Total TDS to Deduct</b></td>
                                    <td><b>₹ @_calcResult.TotalTds.ToString("N0")</b></td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                        @if (_calcResult.BelowThreshold)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                                Amount is below threshold — no TDS applicable.
                            </MudAlert>
                        }
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="7">
                    @if (_calcResult.HigherRateApplied)
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-2">
                            <b>Higher rate applied:</b> @_calcResult.HigherRateReason
                        </MudAlert>
                    }
                    @if (_calcResult.Warnings.Count > 0)
                    {
                        @foreach (var w in _calcResult.Warnings)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-1">@w</MudAlert>
                        }
                    }
                    @if (!string.IsNullOrEmpty(_calcResult.RuleApplied))
                    {
                        <MudPaper Class="pa-3 mt-2" Elevation="0" Style="background:#f5f5f5;border-radius:8px">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Rule Applied</MudText>
                            <MudText Typo="Typo.body2">@_calcResult.RuleApplied</MudText>
                        </MudPaper>
                    }
                    @* Quick reference *@
                    <MudPaper Class="pa-3 mt-3" Elevation="0" Style="background:#fff8e1;border-radius:8px">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Key Rules</MudText>
                        <MudText Typo="Typo.caption">• <b>u/s 206AA</b>: PAN not provided → TDS @@ higher of 20% or twice applicable rate</MudText>
                        <MudText Typo="Typo.caption" Style="text-decoration:line-through;color:#999">• <b>u/s 206AB</b>: Removed by Finance Act 2025 w.e.f. 1-Apr-2025 — no longer applicable</MudText>
                        <MudText Typo="Typo.caption">• <b>u/s 197</b>: Lower deduction certificate from AO applies LDC rate</MudText>
                        <MudText Typo="Typo.caption">• Cess: 4% Health &amp; Education Cess on (TDS + Surcharge)</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </MudTabPanel>

    @* ── Tab 2: Rules Reference ── *@
    <MudTabPanel Text="Rules Reference" Icon="@Icons.Material.Filled.TableChart">
        <div class="d-flex gap-2 mb-3 align-center">
            <MudTextField @bind-Value="_rulesSearch" Placeholder="Search section or nature..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" Style="max-width:320px" Variant="Variant.Outlined" />
            <MudCheckBox @bind-Value="_showInactive" Label="Show inactive" Color="Color.Secondary" />
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddRule">
                Add Rule
            </MudButton>
        </div>

        <div style="height:calc(100vh - 340px);overflow-y:auto;overflow-x:auto">
        <MudDataGrid T="TdsRule" Items="FilteredRules" Dense="true" Hover="true" Striped="true" Bordered="true"
                     FixedHeader="true" Height="calc(100vh - 340px)">
            <Columns>
                <TemplateColumn Title="Section"  SortBy="x => x.SectionCode"    HeaderStyle="width:70px"  CellStyle="width:70px">
                    <CellTemplate>@context.Item.SectionCode</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Nature of Payment" SortBy="x => x.NatureOfPayment" HeaderStyle="width:180px" CellStyle="width:180px;white-space:normal;line-height:1.3">
                    <CellTemplate>@context.Item.NatureOfPayment</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Type"     SortBy="x => x.DeducteeType"   HeaderStyle="width:85px"  CellStyle="width:85px">
                    <CellTemplate>@context.Item.DeducteeType</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Threshold (₹)"             HeaderStyle="width:85px" CellStyle="width:85px;text-align:right">
                    <CellTemplate>@context.Item.ThresholdLimit.ToString("N0")</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Rate %"                    HeaderStyle="width:60px" CellStyle="width:60px;text-align:right">
                    <CellTemplate><b>@context.Item.TdsRate.ToString("N2")</b></CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="SC %"                      HeaderStyle="width:55px" CellStyle="width:55px;text-align:right">
                    <CellTemplate>@context.Item.SurchargeRate.ToString("N2")</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Cess %"                    HeaderStyle="width:55px" CellStyle="width:55px;text-align:right">
                    <CellTemplate>@context.Item.CessRate.ToString("N2")</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Act Ref"  SortBy="x => x.ReferenceAct"   HeaderStyle="width:160px" CellStyle="width:160px;font-size:12px">
                    <CellTemplate>@context.Item.ReferenceAct</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Eff. From"                 HeaderStyle="width:120px" CellStyle="width:120px;font-size:12px;white-space:nowrap">
                    <CellTemplate>
                        @context.Item.EffectiveFrom.ToString("dd-MMM-yyyy")
                        @if (context.Item.EffectiveTo.HasValue)
                        { <div style="font-size:10px;color:#e65100">to @context.Item.EffectiveTo.Value.ToString("dd-MMM-yyyy")</div> }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions" Sortable="false"  HeaderStyle="width:90px" CellStyle="width:90px">
                    <CellTemplate>
                        @if (context.Item.IsActive) {
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Style="vertical-align:middle;margin-right:2px" />
                        } else {
                            <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Default" Size="Size.Small" Style="vertical-align:middle;margin-right:2px" />
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="() => OpenEditRule(context.Item)" />
                        <MudIconButton Icon="@(context.Item.IsActive ? Icons.Material.Filled.ToggleOff : Icons.Material.Filled.ToggleOn)"
                                       Size="Size.Small" Color="@(context.Item.IsActive ? Color.Default : Color.Success)"
                                       OnClick="() => ToggleActive(context.Item)" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
        </div>
    </MudTabPanel>

    @* ── Tab 3: Section Quick Reference ── *@
    <MudTabPanel Text="Section Guide" Icon="@Icons.Material.Filled.MenuBook">
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Key TDS sections under the @TaxRules.ActName(AppState.CurrentFY) applicable for @TaxRules.YearLabel(AppState.CurrentFY)@(TaxRules.IsNewAct(AppState.CurrentFY) ? " — legacy 194-series numbers shown with their Income-tax Act 2025 references" : "")
        </MudAlert>
        @* Offset must exceed all chrome above (app bar + title + tabs + padding + alert), *@
        @* otherwise the div's bottom falls below the viewport and the last rows are unreachable *@
        @* (the outer page scrollbar is hidden by app.css). Generous 340px = always fits. *@
        <div style="height:calc(100vh - 340px);overflow-y:auto">
        <MudSimpleTable Dense="true" Striped="true" Hover="true">
            <thead>
                <tr>
                    <th>Section</th>
                    @if (TaxRules.IsNewAct(AppState.CurrentFY))
                    { <th>Income-tax Act 2025 Reference</th> }
                    <th>Nature of Payment</th><th>Threshold (₹)</th>
                    <th>Resident Rate</th><th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _sectionGuide)
                {
                    <tr style="@(s.Removed ? "color:#999;text-decoration:line-through" : "")">
                        <td><b>@s.Sec</b></td>
                        @if (TaxRules.IsNewAct(AppState.CurrentFY))
                        {
                            var nref = TaxRules.NewActSectionRef(s.Sec);
                            <td style="color:#065f46">@(string.IsNullOrEmpty(nref) ? "—" : nref)</td>
                        }
                        <td>@s.Nature</td><td>@s.Threshold</td><td>@s.Rate</td><td>@s.Notes</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
        </div>
    </MudTabPanel>

    @* ── Tab 4: Finance Act / Rules Status ── *@
    <MudTabPanel Text="Rules Status" Icon="@Icons.Material.Filled.Update">
        <MudGrid Spacing="3" Justify="Justify.Center">
            <MudItem xs="12" md="7">
                <MudPaper Class="pa-5" Elevation="1" Style="border-radius:12px">
                    <MudText Typo="Typo.h6" Class="mb-1">Finance Act — TDS Rules Status</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                        TDS rates and thresholds are compiled into the app and auto-seeded to the database on startup.
                        Every April 1 (Finance Act), a new app version is released with updated rules.
                        Use this panel to check the current rules version and manually re-apply if needed.
                    </MudText>

                    <MudSimpleTable Dense="true" Class="mb-4" Style="width:100%">
                        <tbody>
                            <tr>
                                <td style="width:160px"><b>Compiled Rules</b></td>
                                <td style="font-family:monospace">v@(RulesUpdateService.AppVersion)</td>
                            </tr>
                            <tr>
                                <td><b>Applied to DB</b></td>
                                <td style="font-family:monospace">
                                    @if (_rulesDbVersion == RulesUpdateService.AppVersion)
                                    {
                                        <span style="color:#166534">@_rulesDbVersion ✓ up to date</span>
                                    }
                                    else
                                    {
                                        <span style="color:#b45309">@_rulesDbVersion ⚠ out of date</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td><b>Total Rules</b></td>
                                <td>@_ruleCount standard + custom rules in database</td>
                            </tr>
                            <tr>
                                <td><b>Effective From</b></td>
                                <td>1 April @(AppState.CurrentFY.Length >= 4 ? AppState.CurrentFY[..4] : DateTime.Today.Year.ToString()) (@TaxRules.YearLabel(AppState.CurrentFY))</td>
                            </tr>
                            <tr>
                                <td><b>Act Reference</b></td>
                                @* Finance Act year = FY start year (FA 2026 governs FY 2026-27) *@
                                <td>@TaxRules.ActName(AppState.CurrentFY) · Finance Act @(AppState.CurrentFY.Length >= 4 && int.TryParse(AppState.CurrentFY[..4], out var faYear) ? faYear.ToString() : DateTime.Today.Year.ToString()) · CBDT Circulars</td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>

                    @if (!string.IsNullOrEmpty(_rulesUpdateMsg))
                    {
                        <MudAlert Severity="@_rulesUpdateSeverity" Dense="true" Class="mb-3">@_rulesUpdateMsg</MudAlert>
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Sync"
                               Disabled="_updatingRules" OnClick="ApplyBuiltInRules">
                        @if (_updatingRules) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Re-apply Built-in Rules
                    </MudButton>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2 d-block">
                        Safe to run anytime — only updates standard sections, never overwrites custom rules or user notes.
                    </MudText>

                    <MudDivider Class="my-4" />

                    @* ── IT Act 2025 payment codes (future activation) ── *@
                    <MudText Typo="Typo.subtitle2" Class="mb-2"><b>IT Act 2025 Payment Codes</b></MudText>
                    <div style="border:1px solid #fcd34d;border-radius:8px;padding:8px 12px;background:#fffbeb;margin-bottom:8px">
                        <MudCheckBox T="bool" Value="_usePaymentCodes" ValueChanged="TogglePaymentCodes"
                                     Color="Color.Success" Dense="true"
                                     Label="@($"Write payment codes in new-act files ({_payCodeCount} rules have a code) — keep OFF until final FVU")" />
                    </div>
                    @if (_usePaymentCodes && _payCodeCount == 0)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                            Enabled, but no rule has a payment code yet — files will still use the interim
                            392/393 codes until codes are entered.
                        </MudAlert>
                    }
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block">
                        From TY 2026-27, e-TDS files will eventually carry 4-digit payment codes instead of
                        section numbers. Codes staged so far come from Protean's <b>RPU v1.0 BETA</b> and may
                        change — keep the box above <b>unticked</b> until Protean releases the FINAL new-act
                        FVU/RPU and data structure document, and the codes are re-verified against it. Until
                        then, files use the FVU 9.4 interim format and validate normally.
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="5">
                <MudPaper Class="pa-5" Elevation="1" Style="border-radius:12px;background:#f0fdf4">
                    <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Finance Act 2025 — Key Changes (FY 2025-26)</b></MudText>
                    <MudSimpleTable Dense="true" Style="font-size:12px">
                        <thead>
                            <tr><th>Section</th><th>Change</th></tr>
                        </thead>
                        <tbody>
                            <tr><td><b>194</b></td><td>Dividend threshold raised ₹5,000 → ₹10,000</td></tr>
                            <tr><td><b>194H</b></td><td>Rate reduced 5% → 2%; threshold ₹15,000 → ₹20,000</td></tr>
                            <tr><td><b>194I</b></td><td>Threshold changed to ₹50,000 per month or part thereof</td></tr>
                            <tr><td><b>194J</b></td><td>Threshold raised ₹30,000 → ₹50,000</td></tr>
                            <tr><td><b>194A</b></td><td>Senior citizen bank interest threshold ₹50,000 → ₹1,00,000</td></tr>
                            <tr><td><b>206AB</b></td><td>Omitted — higher TDS for ITR non-filers no longer applies</td></tr>
                            <tr><td><b>194Q</b></td><td>Continues — only 206C(1H) cross-reference removed</td></tr>
                        </tbody>
                    </MudSimpleTable>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-3 d-block">
                        CDeTDS is updated every year after the Finance Act. Use <b>Re-apply Built-in Rules</b> to ensure your database reflects the latest rates.
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

</MudTabs>

@* ── Add/Edit Rule Dialog ── *@
<MudDialog @bind-Visible="_ruleDialogOpen" Options='new DialogOptions { MaxWidth=MaxWidth.Medium, FullWidth=true, CloseOnEscapeKey=true }'>
    <TitleContent>
        <MudIcon Icon="@Icons.Material.Filled.Gavel" Class="mr-2" />
        @(_editingRule?.Id == 0 ? "Add" : "Edit") TDS Rule
    </TitleContent>
    <DialogContent>
        @if (_editingRule != null)
        {
            <MudGrid>
                <MudItem xs="4">
                    <MudTextField @bind-Value="_editingRule.SectionCode" Label="Section Code*"
                                  Variant="Variant.Outlined" Placeholder="194C" />
                </MudItem>
                <MudItem xs="8">
                    <MudTextField @bind-Value="_editingRule.NatureOfPayment" Label="Nature of Payment*"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="4">
                    <MudSelect @bind-Value="_editingRule.DeducteeType" Label="Deductee Type"
                               Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem Value='@("All")'>All</MudSelectItem>
                        @foreach (var t in AppConstants.DeducteeTypes)
                        { <MudSelectItem Value="@t">@t</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="4">
                    <MudCheckBox @bind-Value="_editingRule.IsResident" Label="Resident" />
                </MudItem>
                <MudItem xs="4">
                    <MudCheckBox @bind-Value="_editingRule.IsActive" Label="Active" />
                </MudItem>
                <MudItem xs="3">
                    <MudNumericField @bind-Value="_editingRule.ThresholdLimit" Label="Threshold (₹)"
                                     Variant="Variant.Outlined" Format="N0" Min="0" HideSpinButtons="true" Class="amount-field" />
                </MudItem>
                <MudItem xs="3">
                    <MudNumericField @bind-Value="_editingRule.TdsRate" Label="TDS Rate %*"
                                     Variant="Variant.Outlined" Format="N3" Min="0" Max="100" HideSpinButtons="true" Class="amount-field" />
                </MudItem>
                <MudItem xs="3">
                    <MudNumericField @bind-Value="_editingRule.SurchargeRate" Label="Surcharge %"
                                     Variant="Variant.Outlined" Format="N2" Min="0" Max="40" HideSpinButtons="true" Class="amount-field" />
                </MudItem>
                <MudItem xs="3">
                    <MudNumericField @bind-Value="_editingRule.CessRate" Label="Cess %"
                                     Variant="Variant.Outlined" Format="N2" Min="0" Max="10" HideSpinButtons="true" Class="amount-field" />
                </MudItem>
                <MudItem xs="6">
                    <DateField Value="_ruleEffFrom" ValueChanged="d => _ruleEffFrom = d" Label="Effective From*"
                               Variant="Variant.Outlined" Class="date-field" />
                </MudItem>
                <MudItem xs="6">
                    <DateField Value="_ruleEffTo" ValueChanged="d => _ruleEffTo = d" Label="Effective To (blank=current)"
                               Variant="Variant.Outlined" Class="date-field" />
                </MudItem>
                <MudItem xs="8">
                    <MudTextField @bind-Value="_editingRule.ReferenceAct" Label="Act Reference"
                                  Variant="Variant.Outlined" Placeholder="e.g. IT Act 1961 s.194C (FY ≤ 2025-26) or IT Act 2025 ref" />
                </MudItem>
                <MudItem xs="4">
                    <MudTextField @bind-Value="_editingRule.PaymentCode" Label="IT Act 2025 Payment Code"
                                  Variant="Variant.Outlined" Placeholder="e.g. 1006"
                                  HelperText="From official Protean doc only — leave blank until released" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_editingRule.Notes" Label="Notes"
                                  Variant="Variant.Outlined" Lines="2" />
                </MudItem>
            </MudGrid>
            @if (!string.IsNullOrEmpty(_ruleSaveError))
            { <MudAlert Severity="Severity.Error" Class="mt-2">@_ruleSaveError</MudAlert> }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _ruleDialogOpen = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveRule">Save Rule</MudButton>
    </DialogActions>
</MudDialog>

@code {
    // ── Section Guide rows (1961-Act numbers; Act 2025 refs added per FY in markup) ──
    private record SectionGuideRow(string Sec, string Nature, string Threshold, string Rate, string Notes, bool Removed = false);
    private static readonly SectionGuideRow[] _sectionGuide =
    {
        new("192",   "Salary", "Basic exemption limit", "Slab rate (old/new regime)", "Employer deducts monthly; Form 24Q / Form 138 (Act 2025)"),
        new("192A",  "Premature PF withdrawal", "50,000", "10%", "206AA applies if no PAN → 20%"),
        new("193",   "Interest on securities", "10,000 (all deductees — FA 2023 unified)", "10%", "Debentures, Govt securities; listed bonds exempted"),
        new("194",   "Dividend", "10,000", "10%", "Finance Act 2025 increased threshold from ₹5,000 → ₹10,000 w.e.f. 1-Apr-2025; mutual fund dividends → 194K"),
        new("194A",  "Interest other than securities", "40,000 (general); 1,00,000 (bank/co-op/post, senior citizen)", "10%", "Finance Act 2025 raised senior citizen threshold ₹50,000 → ₹1,00,000 w.e.f. 1-Apr-2025"),
        new("194B",  "Winnings from lottery/crossword puzzle", "10,000 per transaction", "30%", "TDS on gross amount; no deduction allowed"),
        new("194BA", "Winnings from online games", "Nil (no threshold)", "30%", "Inserted by Finance Act 2023 w.e.f. 01-Apr-2023; net winnings basis"),
        new("194BB", "Winnings from horse races", "10,000 per transaction", "30%", "Bookmaker / totalisator"),
        new("194C",  "Contractor / sub-contractor", "₹30,000 single; ₹1,00,000 aggregate p.a.", "1% Individual/HUF; 2% Company/LLP", "Includes advertising, transport, catering"),
        new("194D",  "Insurance commission", "15,000", "5% Individual; 10% Company (domestic)", "Life / general insurance agents"),
        new("194DA", "Life insurance maturity payment", "1,00,000", "5% on income portion (maturity − premium paid)", "Only on income component; not on return of premium"),
