@page "/dashboard"
@inject AppStateService AppState
@inject DashboardService DashSvc
@inject DueDateService DueSvc
@inject ReportsService RptSvc
@inject PayrollService PayrollSvc
@inject DeductorService DeductorSvc
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable
@using TDSPro.Common

@* First-run wizard — shown only when no deductors exist *@
@if (_showWizard)
{
    <FirstRunWizard OnFinished="OnWizardFinished" />
}

<div class="dashboard-page">

    @* ── Header banner ── *@
    <div class="dashboard-header" style="padding-top:12px;padding-bottom:8px">
        <div style="background:linear-gradient(135deg,#1565C0 0%,#1976D2 60%,#42A5F5 100%);
                    padding:10px 20px;color:#fff;border-radius:10px;
                    display:flex;align-items:center;justify-content:space-between;
                    box-shadow:0 2px 8px rgba(0,0,0,.18);">
            <div>
                <div style="font-size:15px;font-weight:700;line-height:1.2">Welcome, @AppState.CurrentUser</div>
                <div style="font-size:11px;opacity:.85;margin-top:2px">
                    @AppState.CurrentDeductorName &nbsp;·&nbsp; FY @AppState.CurrentFY &nbsp;·&nbsp; AY @TaxRules.AssessmentYearLabel(AppState.CurrentFY) &nbsp;·&nbsp; @TaxRules.ActName(AppState.CurrentFY)
                </div>
            </div>
            <MudChip T="string" Icon="@Icons.Material.Filled.Verified" Color="Color.Success"
                     Style="background:rgba(255,255,255,.15);color:#fff;font-size:12px">
                @AppState.CurrentLicense.TierLabel &nbsp; @AppState.CurrentLicense.DaysLeft d left
            </MudChip>
        </div>
    </div>

    @if (_stats == null)
    {
        <div style="padding:24px"><MudProgressLinear Indeterminate="true" Color="Color.Primary" /></div>
    }
    else
    {
        @* ── KPI rows ── *@
        <div class="dashboard-kpi-row" style="padding-top:6px;padding-bottom:4px">
            @* TDS KPIs *@
            <div style="display:flex;gap:8px;margin-bottom:6px">
                <div class="db-kpi" @onclick='() => Nav.NavigateTo("/entries")'><div class="db-kpi-lbl">Total Entries</div><div class="db-kpi-val" style="color:#1565C0">@_stats.TotalEntries</div></div>
                <div class="db-kpi" @onclick='() => Nav.NavigateTo("/entries")'><div class="db-kpi-lbl">Gross Amount</div><div class="db-kpi-val" style="color:#0288d1">₹@_stats.TotalAmount.ToString("N0")</div></div>
                <div class="db-kpi" @onclick='() => Nav.NavigateTo("/entries")'><div class="db-kpi-lbl">Total TDS</div><div class="db-kpi-val" style="color:#2e7d32">₹@_stats.TotalTds.ToString("N0")</div></div>
                <div class="db-kpi" @onclick='() => Nav.NavigateTo("/challans")'><div class="db-kpi-lbl">Challans</div><div class="db-kpi-val" style="color:#e65100">@_stats.TotalChallans</div></div>
                <div class="db-kpi" @onclick='() => Nav.NavigateTo("/entries")'><div class="db-kpi-lbl">Pending</div><div class="db-kpi-val" style="color:@(_stats.PendingEntries>0?"#c62828":"#999")">@_stats.PendingEntries</div></div>
                <div class="db-kpi" @onclick='() => Nav.NavigateTo("/deductees")'><div class="db-kpi-lbl">Deductees</div><div class="db-kpi-val" style="color:#6a1b9a">@_stats.TotalDeductees</div></div>
                @if (_payrollStats != null)
                {
                    <div class="db-kpi-sep"></div>
                    <div class="db-kpi" @onclick='() => Nav.NavigateTo("/payroll")'><div class="db-kpi-lbl">Payroll Processed</div><div class="db-kpi-val" style="color:#2e7d32">@_payrollStats.Processed</div></div>
                    <div class="db-kpi" @onclick='() => Nav.NavigateTo("/payroll")'><div class="db-kpi-lbl">Total Gross</div><div class="db-kpi-val" style="color:#1565C0">₹@_payrollStats.TotalGross.ToString("N0")</div></div>
                    <div class="db-kpi" @onclick='() => Nav.NavigateTo("/payroll")'><div class="db-kpi-lbl">Month TDS</div><div class="db-kpi-val" style="color:#c62828">₹@_payrollStats.MonthTds.ToString("N0")</div></div>
                    <div class="db-kpi" @onclick='() => Nav.NavigateTo("/payroll")'><div class="db-kpi-lbl">YTD TDS</div><div class="db-kpi-val" style="color:#0288d1">₹@_payrollStats.YtdTds.ToString("N0")</div></div>
                }
            </div>
        </div>

        @* ── Quick Actions ── *@
        <div class="dashboard-actions" style="padding-bottom:6px">
            <div style="display:flex;gap:8px;flex-wrap:wrap;background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:8px 12px">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.FileUpload" OnClick='()=>Nav.NavigateTo("/returns")'>File Return</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.TableChart" OnClick='()=>Nav.NavigateTo("/excel")'>Import Excel</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Calculate" OnClick='()=>Nav.NavigateTo("/calculator")'>Interest Calc</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.FolderOpen" OnClick="OpenFolder">Open Folder</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Print" OnClick='()=>Nav.NavigateTo("/challan/print")'>Challan Print</MudButton>
            </div>
        </div>

        @* ── Middle: Charts + Recent Entries — fills remaining height ── *@
        <div class="dashboard-middle">
            @* Quarterly TDS bar chart *@
            <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:14px;display:flex;flex-direction:column;min-height:0">
                <div style="font-size:12px;font-weight:700;color:#374151;margin-bottom:8px">Quarterly TDS (₹)</div>
                @if (_quarterData.Any())
                {
                    var _maxTds = _quarterData.Max(q => q.TdsAmount) == 0 ? 1.0 : _quarterData.Max(q => q.TdsAmount);
                    <div style="flex:1;display:flex;align-items:flex-end;gap:12px;border-bottom:2px solid #e0e0e0;padding-bottom:4px;min-height:0">
                        @foreach (var q in _quarterData)
                        {
                            double barPct = q.TdsAmount / _maxTds * 85;
                            if (barPct < 3 && q.TdsAmount > 0) barPct = 3;
                            <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;gap:4px;height:100%">
                                <div style="font-size:10px;color:#555;font-weight:600">₹@((q.TdsAmount/1000).ToString("N0"))K</div>
                                <div style="width:60%;background:linear-gradient(180deg,#42A5F5,#1565C0);border-radius:4px 4px 0 0;height:@(barPct.ToString("F0"))%"></div>
                            </div>
                        }
                    </div>
                    <div style="display:flex;gap:12px;margin-top:4px">
                        @foreach (var q in _quarterData)
                        {
                            <div style="flex:1;text-align:center;font-size:11px;font-weight:700;color:#1565C0">@q.Quarter</div>
                        }
                    </div>
                }
                else { <div style="color:#9e9e9e;font-size:12px">No data for @AppState.CurrentFY</div> }
            </div>

            @* ── Filing Readiness ── *@
            <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:14px;display:flex;flex-direction:column;min-height:0;gap:6px">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2px">
                    <div style="font-size:12px;font-weight:700;color:#374151">Filing Readiness</div>
                    <div style="font-size:10px;color:#94a3b8">FY @AppState.CurrentFY</div>
                </div>

                @* Quarter status rows — 24Q and 26Q *@
                @foreach (var form in new[]{"24Q","26Q"})
                {
                    <div style="font-size:10px;font-weight:700;color:#94a3b8;margin-top:4px;margin-bottom:1px">@form</div>
                    @foreach (var q in new[]{"Q1","Q2","Q3","Q4"})
                    {
                        var rec = _filingStatus.FirstOrDefault(r => r.FormType == form && r.Quarter == q);
                        bool filed   = rec != null && !string.IsNullOrEmpty(rec.FvuFilePath);
                        bool hasPrn  = rec != null && !string.IsNullOrEmpty(rec.Prn);
                        string dot   = filed ? "#16a34a" : "#e5e7eb";
                        string label = filed ? (hasPrn ? $"Filed · PRN {rec!.Prn[..Math.Min(10,rec.Prn.Length)]}" : "Generated") : "Pending";
                        string lc    = filed ? "#16a34a" : "#9ca3af";
                        <div style="display:flex;align-items:center;gap:6px;padding:3px 0;border-bottom:1px solid #f1f5f9">
                            <div style="width:8px;height:8px;border-radius:50%;background:@dot;flex-shrink:0"></div>
                            <div style="font-size:11px;font-weight:600;color:#374151;width:22px">@q</div>
                            <div style="font-size:10px;color:@lc;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@label</div>
                            @if (!filed)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small"
                                               Style="padding:2px;width:20px;height:20px;color:#1565C0"
                                               OnClick='() => Nav.NavigateTo("/returns")' />
                            }
                        </div>
                    }
                }

                @* Pre-flight checklist *@
                <div style="margin-top:8px;border-top:1px solid #f1f5f9;padding-top:8px;display:flex;flex-direction:column;gap:4px">
                    @foreach (var (icon, label, ok) in _preflight)
                    {
                        <div style="display:flex;align-items:center;gap:6px;font-size:11px">
                            <span style="color:@(ok?"#16a34a":"#dc2626");font-size:13px">@(ok?"✅":"❌")</span>
                            <span style="color:@(ok?"#374151":"#dc2626")">@label</span>
                        </div>
                    }
                </div>
            </div>

            @* Recent TDS Entries *@
            <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:14px 0 0 14px;display:flex;flex-direction:column;min-height:0;flex:1.5;overflow:hidden">
                <div style="font-size:12px;font-weight:700;color:#374151;margin-bottom:6px;padding-right:14px">Recent TDS Entries</div>
                <div style="flex:1;overflow-y:auto;min-height:0;padding-right:14px;padding-bottom:14px">
                    <table style="width:100%;border-collapse:collapse;font-size:11px">
                        <thead>
                            <tr style="background:#f1f5f9;position:sticky;top:0">
                                <th style="padding:5px 8px;text-align:left;color:#64748b;font-weight:600">Date</th>
                                <th style="padding:5px 8px;text-align:left;color:#64748b;font-weight:600">Sec</th>
                                <th style="padding:5px 8px;text-align:right;color:#64748b;font-weight:600">TDS</th>
                                <th style="padding:5px 8px;text-align:left;color:#64748b;font-weight:600">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in _recentEntries)
                            {
                                <tr style="border-bottom:1px solid #f1f5f9">
                                    <td style="padding:5px 8px">@e.EntryDate.ToString("dd-MMM")</td>
                                    <td style="padding:5px 8px;color:#1565C0;font-weight:600">@e.Section</td>
                                    <td style="padding:5px 8px;text-align:right;font-family:monospace">@e.TotalTds.ToString("N0")</td>
                                    <td style="padding:5px 8px">
                                        <span style="font-size:10px;font-weight:600;padding:2px 7px;border-radius:10px;
                                            background:@(e.Status=="Paid"?"#e8f5e9":e.Status=="Overdue"?"#ffebee":"#fff3e0");
                                            color:@(e.Status=="Paid"?"#2e7d32":e.Status=="Overdue"?"#c62828":"#e65100")">
                                            @e.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* ── Due Date Alerts ── *@
        @if (_alerts.Any())
        {
            <div class="dashboard-alerts">
                @foreach (var a in _alerts)
                {
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
                        <div style="flex:1;background:@(a.IsOverdue?"#ffebee":"#fff8e1");border-left:4px solid @(a.IsOverdue?"#c62828":"#FF9800");
                                    border-radius:6px;padding:6px 12px;font-size:12px">
                            <b>@a.FormType</b> @a.Quarter FY @a.Fy — Due: @a.DueDateValue.ToString("dd-MMM-yyyy") — @a.DaysLabel
                        </div>
                        <MudButton Size="Size.Small" Variant="Variant.Filled"
                                   Color="@(a.IsOverdue ? Color.Error : Color.Warning)"
                                   OnClick='() => Nav.NavigateTo("/returns")'>File Now</MudButton>
                    </div>
                }
            </div>
        }
    }

</div>

@code {
    private DashboardStats? _stats;
    private List<DueDate> _alerts = new();
    private List<QuarterSummary> _quarterData = new();
    private List<TdsEntry> _recentEntries = new();
    private PayrollDashStats? _payrollStats;
    private string _payrollMonthLabel = "";
    private bool   _showWizard;
    private List<TDSPro.DAL.FilingHistoryRecord> _filingStatus = new();
    private List<(string Icon, string Label, bool Ok)> _preflight = new();

    record PayrollDashStats(int Processed, double TotalGross, double MonthTds, double YtdTds);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("document.body.classList.add", "dashboard-active");
    }

    protected override void OnInitialized()
    {
        AppState.OnChange += OnContextChanged;
        // Show first-run wizard once when no deductors exist + user hasn't dismissed it
        var skipped = TDSPro.DAL.Database.GetSetting("FirstRunWizard_Skipped", "");
        var hasDeductors = DeductorSvc.GetAll().Any();
        if (!hasDeductors && skipped != "1") _showWizard = true;
    }

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    void OnWizardFinished()
    {
        _showWizard = false;
        // Mark dismissed so it doesn't reappear if user skipped before adding a deductor
        TDSPro.DAL.Database.SetSetting("FirstRunWizard_Skipped", "1");
        _ = LoadAsync();
        StateHasChanged();
    }

    void OnContextChanged() { _ = LoadAsync(); InvokeAsync(StateHasChanged); }

    async Task LoadAsync()
    {
        var did = AppState.CurrentDeductorId > 0 ? (int?)AppState.CurrentDeductorId : null;
        _stats = await Task.Run(() => DashSvc.GetStats(AppState.CurrentFY, did));

        // Quarter chart data
        try { _quarterData = await Task.Run(() => RptSvc.GetQuarterSummary(AppState.CurrentFY, did)); }
        catch { _quarterData = new(); }

        // Recent 10 entries
        try
        {
            var svc = new TdsEntryService();
            _recentEntries = await Task.Run(() =>
                svc.GetAll(AppState.CurrentDeductorId, AppState.CurrentFY)
                   .OrderByDescending(e => e.EntryDate).Take(10).ToList());
        }
        catch { _recentEntries = new(); }

        // Payroll stats for current month
        try
        {
            var now = DateTime.Today;
            _payrollMonthLabel = now.ToString("MMMM yyyy");
            var runs = await Task.Run(() =>
                PayrollSvc.GetRuns(now.Month, now.Year, AppState.CurrentDeductorId));
            if (runs.Any())
            {
                var allRuns = await Task.Run(() =>
                    PayrollSvc.GetRunsForFY(AppState.CurrentFY, AppState.CurrentDeductorId));
                _payrollStats = new PayrollDashStats(
                    Processed: runs.Count,
                    TotalGross: runs.Sum(r => r.GrossSalary),
                    MonthTds: runs.Sum(r => r.TdsDeducted),
                    YtdTds: allRuns.Sum(r => r.TdsDeducted));
            }
        }
        catch { _payrollStats = null; }

        // Due date alerts — current FY overdue + upcoming 30 days only
        try
        {
            _alerts = await Task.Run(() =>
                DueSvc.GetAlerts(lookAheadDays: 45)
                      .Where(a => a.IsDueSoon)
                      .OrderBy(a => a.DueDateValue)
                      .ToList());
        }
        catch { _alerts = new(); }

        // Filing readiness — latest record per form+quarter
        try
        {
            var filingDid = AppState.CurrentDeductorId;
            var filingFy  = AppState.CurrentFY;
            _filingStatus = await Task.Run(() =>
            {
                var latest = new List<TDSPro.DAL.FilingHistoryRecord>();
                foreach (var form in new[]{"24Q","26Q"})
                    foreach (var q in new[]{"Q1","Q2","Q3","Q4"})
                    {
                        var recs = TDSPro.DAL.Database.GetFilingHistory(filingDid, filingFy, form, q);
                        var best = recs.OrderByDescending(r => r.Id).FirstOrDefault();
                        if (best != null) latest.Add(best);
                    }
                return latest;
            });
        }
        catch { _filingStatus = new(); }

        // Pre-flight checklist
        try
        {
            var runner = new TDSPro.DAL.FvuUtilityRunner();
            var pf     = await Task.Run(() => runner.CheckPreflight());
            var csiPath = System.IO.Path.Combine(
                TDSPro.DAL.FolderManager.CsiFolder,
                $"{AppState.CurrentDeductorTan}.csi");
            bool csiOk = System.IO.File.Exists(csiPath);
            _preflight = new()
            {
                ("", "Java runtime",     pf.Issues.All(i => !i.Contains("Java"))),
                ("", "FVU 9.4 JAR",      pf.Issues.All(i => !i.Contains("FVU"))),
                ("", $"CSI file ({AppState.CurrentDeductorTan})", csiOk),
            };
        }
        catch { _preflight = new(); }

        await InvokeAsync(StateHasChanged);
    }

    void OpenFolder()
    {
        try { FolderManager.OpenFolder(FolderManager.CompanyFolder); } catch { }
    }

    public void Dispose()
    {
        AppState.OnChange -= OnContextChanged;
        _ = JS.InvokeVoidAsync("document.body.classList.remove", "dashboard-active");
    }
}
