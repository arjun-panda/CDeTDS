@page "/form16"
@using System.IO
@inject AppStateService AppState
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject PayrollService PayrollSvc
@inject DeductorService DeductorSvc

@* ── Sticky header ── *@
<div style="position:sticky;top:0;z-index:50;background:#f5f7fa;margin:-16px -24px 16px -24px;padding:10px 24px;border-bottom:1px solid #e0e0e0;box-shadow:0 2px 6px rgba(0,0,0,.06)">
    <span style="font-size:15px;font-weight:700;color:#1e293b">Form 16 / 16A Generation</span>
</div>

<MudTabs @bind-ActivePanelIndex="_activeTab" Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-0">

    @* ── Form 16A (Non-Salary) ── *@
    <MudTabPanel Text="Form 16A — Non-Salary">
        <div style="padding:20px 24px">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="4">
                    <PanField Value="@_deducteePan" Label="Deductee PAN*" ShowType="true"
                              ValueChanged="@((v) => _deducteePan = v)" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect @bind-Value="_quarter16A" Label="Quarter" Variant="Variant.Outlined" ShrinkLabel="true">
                        <MudSelectItem Value='""'>Full Year</MudSelectItem>
                        @foreach (var q in AppConstants.QuarterCodes)
                        { <MudSelectItem Value="@q">@q</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="5">
                    <div style="display:flex;gap:8px;flex-wrap:wrap">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Preview16A"
                                   StartIcon="@Icons.Material.Filled.Visibility" Disabled="_generating">Preview</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Print16A"
                                   StartIcon="@Icons.Material.Filled.Print" Disabled="_generating">Print / PDF</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="Download16A"
                                   StartIcon="@Icons.Material.Filled.Download" Disabled="_generating">Save HTML</MudButton>
                    </div>
                </MudItem>
            </MudGrid>
        </div>
    </MudTabPanel>

    @* ── Form 16 (Salary) ── *@
    <MudTabPanel Text="Form 16 — Salary">
        <div style="padding:20px 24px">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="5">
                    <MudSelect T="int" @bind-Value="_employeeId" Label="Employee*" Variant="Variant.Outlined" ShrinkLabel="true">
                        <MudSelectItem Value="0">— Select Employee —</MudSelectItem>
                        @foreach (var e in _employees)
                        { <MudSelectItem Value="@e.Id">@e.Name (@e.Pan)</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="7">
                    <div style="display:flex;flex-wrap:wrap;gap:6px;align-items:center">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Preview16"
                                   StartIcon="@Icons.Material.Filled.Visibility" Disabled="_generating" Size="Size.Small">Preview</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Print16"
                                   StartIcon="@Icons.Material.Filled.Print" Disabled="_generating" Size="Size.Small">Print/PDF</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="Download16"
                                   StartIcon="@Icons.Material.Filled.Download" Disabled="_generating" Size="Size.Small">Save HTML</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Download16Pdf"
                                   StartIcon="@Icons.Material.Filled.PictureAsPdf" Disabled="_generating" Size="Size.Small">Save PDF</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="Generate12BA"
                                   StartIcon="@Icons.Material.Filled.AttachFile" Disabled="_generating" Size="Size.Small">Form 12BA</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="GenerateComputation"
                                   StartIcon="@Icons.Material.Filled.Calculate" Disabled="_generating" Size="Size.Small">Comp. HTML</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="GenerateComputationPdf"
                                   StartIcon="@Icons.Material.Filled.PictureAsPdf" Disabled="_generating" Size="Size.Small">Comp. PDF</MudButton>
                    </div>
                </MudItem>
            </MudGrid>
        </div>
    </MudTabPanel>

    @* ── Form 27D (TCS) ── *@
    <MudTabPanel Text="Form 27D — TCS">
        <div style="padding:20px 24px">
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                <b>Form 27D</b> — TCS Certificate issued to collectees under Section 206C / Rule 37D for FY @AppState.CurrentFY.
            </MudAlert>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="4">
                    <PanField Value="@_collecteePan" Label="Collectee PAN*" ShowType="true"
                              ValueChanged="@((v) => _collecteePan = v)" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect @bind-Value="_quarter27D" Label="Quarter" Variant="Variant.Outlined" ShrinkLabel="true">
                        <MudSelectItem Value='""'>Full Year</MudSelectItem>
                        @foreach (var q in AppConstants.QuarterCodes)
                        { <MudSelectItem Value="@q">@q</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="5">
                    <div style="display:flex;gap:8px;flex-wrap:wrap">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Preview27D"
                                   StartIcon="@Icons.Material.Filled.Visibility" Disabled="_generating">Preview</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Print27D"
                                   StartIcon="@Icons.Material.Filled.Print" Disabled="_generating">Print / PDF</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="Download27D"
                                   StartIcon="@Icons.Material.Filled.Download" Disabled="_generating">Save HTML</MudButton>
                    </div>
                </MudItem>
            </MudGrid>
        </div>
    </MudTabPanel>

    @* ── Bulk Generation ── *@
    <MudTabPanel Text="Bulk Generate">
        <div style="padding:20px 24px">
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                Generate Form 16 (salary) for <b>all active employees</b> for FY @AppState.CurrentFY and save to the output folder.
            </MudAlert>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.AllInbox" OnClick="BulkGenerate16"
                       Disabled="_generating">
                @if (_generating) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Generate All Form 16
            </MudButton>
            @if (!string.IsNullOrEmpty(_bulkResult))
            {
                <MudAlert Severity="@_bulkSeverity" Class="mt-3" Style="white-space:pre-line">@_bulkResult</MudAlert>
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FolderOpen"
                           Class="mt-2" OnClick="OpenForm16Folder">Open Output Folder</MudButton>
            }
        </div>
    </MudTabPanel>
</MudTabs>

@if (_generating)
{
    <div class="d-flex justify-center my-6"><MudProgressCircular Indeterminate="true" /></div>
}

@if (!string.IsNullOrEmpty(_html))
{
    <div id="form16-preview" class="print-area">
        @((MarkupString)_html)
    </div>
}

<style>
    @@media print {
        .mud-appbar, .mud-drawer, .mud-main-content > .mud-paper { display: none !important; }
        .print-area { margin: 0; padding: 0; }
    }
</style>

@code {
    private int    _activeTab    = 0;
    private string _deducteePan = "";
    private string _quarter16A  = "";
    private string _collecteePan = "";
    private string _quarter27D  = "";
    private int    _employeeId  = 0;
    private string _html        = "";
    private bool   _generating;
    private string _bulkResult = "";
    private Severity _bulkSeverity = Severity.Info;

    private List<Employee> _employees = new();

    protected override void OnInitialized()
    {
        if (AppState.CurrentDeductorId > 0)
            _employees = PayrollSvc.GetEmployees(AppState.CurrentDeductorId);
    }

    async Task Preview16A()
    {
        if (AppState.CurrentDeductorId == 0) { Snackbar.Add("Select a deductor first.", Severity.Warning); return; }
        if (string.IsNullOrWhiteSpace(_deducteePan)) { Snackbar.Add("Deductee PAN is required.", Severity.Warning); return; }
        _generating = true; _html = ""; StateHasChanged();
        try
        {
            _html = await Task.Run(() =>
            {
                var data = Form16Generator.BuildForm16A(
                    AppState.CurrentDeductorId, _deducteePan.Trim().ToUpper(), AppState.CurrentFY,
                    string.IsNullOrWhiteSpace(_quarter16A) ? null : _quarter16A);
                return Form16Generator.RenderHtml(data);
            });
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
        _generating = false;
    }

    async Task Print16A()
    {
        if (string.IsNullOrEmpty(_html)) await Preview16A();
        if (!string.IsNullOrEmpty(_html))
            await JS.InvokeVoidAsync("tdspro.printElement", "form16-preview");
    }

    async Task Preview16()
    {
        if (AppState.CurrentDeductorId == 0) { Snackbar.Add("Select a deductor first.", Severity.Warning); return; }
        if (_employeeId == 0) { Snackbar.Add("Select an employee.", Severity.Warning); return; }
        _generating = true; _html = ""; StateHasChanged();
        try
        {
            _html = await Task.Run(() =>
            {
                var data = Form16Generator.BuildForm16Salary(
                    AppState.CurrentDeductorId, _employeeId, AppState.CurrentFY);
                return Form16Generator.RenderForm16SalaryHtml(data);
            });
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
        _generating = false;
    }

    async Task Print16()
    {
        if (string.IsNullOrEmpty(_html)) await Preview16();
        if (!string.IsNullOrEmpty(_html))
            await JS.InvokeVoidAsync("tdspro.printElement", "form16-preview");
    }

    async Task Download16A()
    {
        if (string.IsNullOrEmpty(_html)) await Preview16A();
        if (string.IsNullOrEmpty(_html)) return;
        try
        {
            var folder = FolderManager.Form16AForFyFolder(AppState.CurrentFY);
            Directory.CreateDirectory(folder);
            var path = Path.Combine(folder, $"Form16A_{_deducteePan}_{_quarter16A}_{AppState.CurrentFY.Replace("/","-")}.html");
            File.WriteAllText(path, _html, System.Text.Encoding.UTF8);
            FolderManager.OpenFolder(folder);
            Snackbar.Add($"Saved: {Path.GetFileName(path)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
    }

    async Task Download16()
    {
        if (string.IsNullOrEmpty(_html)) await Preview16();
        if (string.IsNullOrEmpty(_html)) return;
        try
        {
            var emp = _employees.FirstOrDefault(e => e.Id == _employeeId);
            var folder = FolderManager.Form16ForFyFolder(AppState.CurrentFY);
            Directory.CreateDirectory(folder);
            var name = emp != null ? $"Form16_{emp.EmployeeCode}_{emp.Pan}" : $"Form16_Emp{_employeeId}";
            var path = Path.Combine(folder, $"{name}_{AppState.CurrentFY.Replace("/","-")}.html");
            File.WriteAllText(path, _html, System.Text.Encoding.UTF8);
            FolderManager.OpenFolder(folder);
            Snackbar.Add($"Saved: {Path.GetFileName(path)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
    }

    async Task Download16Pdf()
    {
        if (AppState.CurrentDeductorId == 0) { Snackbar.Add("Select a deductor first.", Severity.Warning); return; }
        if (_employeeId == 0) { Snackbar.Add("Select an employee.", Severity.Warning); return; }
        _generating = true; StateHasChanged();
        try
        {
            var data = await Task.Run(() => Form16Generator.BuildForm16Salary(AppState.CurrentDeductorId, _employeeId, AppState.CurrentFY));
            var folder = FolderManager.Form16ForFyFolder(AppState.CurrentFY);
            var path = Form16Generator.SaveForm16SalaryPdf(data, folder);
            FolderManager.OpenFolder(folder);
            Snackbar.Add($"📄 PDF saved: {Path.GetFileName(path)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
        _generating = false;
    }

    async Task GenerateComputationPdf()
    {
        if (AppState.CurrentDeductorId == 0) { Snackbar.Add("Select a deductor first.", Severity.Warning); return; }
        if (_employeeId == 0) { Snackbar.Add("Select an employee.", Severity.Warning); return; }
        _generating = true; StateHasChanged();
        try
        {
            var data = await Task.Run(() => IncomeComputationGenerator.Build(AppState.CurrentDeductorId, _employeeId, AppState.CurrentFY));
            var folder = FolderManager.Form16ForFyFolder(AppState.CurrentFY);
            var path = IncomeComputationGenerator.SavePdf(data, folder);
            FolderManager.OpenFolder(folder);
            Snackbar.Add($"📄 Computation PDF saved: {Path.GetFileName(path)} — Total tax ₹{data.TotalTax:N0}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
        _generating = false;
    }

    async Task Generate12BA()
    {
        if (AppState.CurrentDeductorId == 0) { Snackbar.Add("Select a deductor first.", Severity.Warning); return; }
        if (_employeeId == 0) { Snackbar.Add("Select an employee.", Severity.Warning); return; }
        _generating = true; StateHasChanged();
        try
        {
            var data = await Task.Run(() => Form12BAGenerator.Build(AppState.CurrentDeductorId, _employeeId, AppState.CurrentFY));
            if (data.Perquisites.Count == 0)
            {
                Snackbar.Add("No perquisites recorded for this employee in this FY. Add perq line items in Salary Data first.", Severity.Warning);
                _generating = false; return;
            }
            var folder = FolderManager.Form16ForFyFolder(AppState.CurrentFY);
            var path = Form12BAGenerator.SaveHtml(data, folder);
            FolderManager.OpenFolder(folder);
            Snackbar.Add($"Form 12BA saved: {Path.GetFileName(path)} — Total perq taxable ₹{data.TotalChargeable:N0}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
        _generating = false;
    }

    async Task GenerateComputation()
    {
        if (AppState.CurrentDeductorId == 0) { Snackbar.Add("Select a deductor first.", Severity.Warning); return; }
        if (_employeeId == 0) { Snackbar.Add("Select an employee.", Severity.Warning); return; }
        _generating = true; StateHasChanged();
        try
        {
            var data = await Task.Run(() => IncomeComputationGenerator.Build(AppState.CurrentDeductorId, _employeeId, AppState.CurrentFY));
            var folder = FolderManager.Form16ForFyFolder(AppState.CurrentFY);
            var path = IncomeComputationGenerator.SaveHtml(data, folder);
            FolderManager.OpenFolder(folder);
            Snackbar.Add($"Computation saved: {Path.GetFileName(path)} — Total tax ₹{data.TotalTax:N0}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
        _generating = false;
    }

    async Task Preview27D()
    {
        if (AppState.CurrentDeductorId == 0) { Snackbar.Add("Select a deductor first.", Severity.Warning); return; }
        if (string.IsNullOrWhiteSpace(_collecteePan)) { Snackbar.Add("Collectee PAN is required.", Severity.Warning); return; }
        _generating = true; _html = ""; StateHasChanged();
        try
        {
            _html = await Task.Run(() =>
            {
                var data = Form16Generator.BuildForm27D(
                    AppState.CurrentDeductorId, _collecteePan.Trim().ToUpper(), AppState.CurrentFY,
                    string.IsNullOrWhiteSpace(_quarter27D) ? null : _quarter27D);
                if (data.Transactions.Count == 0)
                    return "<div style='padding:24px;font-family:sans-serif;color:#b45309'>No TCS entries (206C sections) found for this PAN in FY " + AppState.CurrentFY + ".</div>";
                return Form16Generator.RenderForm27D(data);
            });
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
        _generating = false;
    }

    async Task Print27D()
    {
        if (string.IsNullOrEmpty(_html)) await Preview27D();
        if (!string.IsNullOrEmpty(_html))
            await JS.InvokeVoidAsync("tdspro.printElement", "form16-preview");
    }

    async Task Download27D()
    {
        if (string.IsNullOrEmpty(_html)) await Preview27D();
        if (string.IsNullOrEmpty(_html)) return;
        try
        {
            var folder = FolderManager.Form27DForFyFolder(AppState.CurrentFY);
            Directory.CreateDirectory(folder);
            var path = Path.Combine(folder, $"Form27D_{_collecteePan}_{_quarter27D}_{AppState.CurrentFY.Replace("/","-")}.html");
            File.WriteAllText(path, _html, System.Text.Encoding.UTF8);
            FolderManager.OpenFolder(folder);
            Snackbar.Add($"Saved: {Path.GetFileName(path)}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add("Error: " + ErrorTranslator.UserFriendly(ex), Severity.Error); }
    }

    async Task BulkGenerate16()
    {
        if (AppState.CurrentDeductorId == 0) { Snackbar.Add("Select a deductor first.", Severity.Warning); return; }
        _generating = true; _bulkResult = ""; StateHasChanged();
        try
        {
            var folder = FolderManager.Form16ForFyFolder(AppState.CurrentFY);
            Directory.CreateDirectory(folder);
            var emps = PayrollSvc.GetEmployees(AppState.CurrentDeductorId).Where(e => e.IsActive).ToList();
            int ok = 0, fail = 0;
            var errors = new System.Text.StringBuilder();

            await Task.Run(() =>
            {
                foreach (var emp in emps)
                {
                    try
                    {
                        var data = Form16Generator.BuildForm16Salary(AppState.CurrentDeductorId, emp.Id, AppState.CurrentFY);
                        var html = Form16Generator.RenderForm16SalaryHtml(data);
                        var path = Path.Combine(folder, $"Form16_{emp.EmployeeCode}_{(emp.Pan ?? "NOPAN")}_{AppState.CurrentFY.Replace("/","-")}.html");
                        File.WriteAllText(path, html, System.Text.Encoding.UTF8);
                        ok++;
                    }
                    catch (Exception ex) { fail++; errors.AppendLine($"• {emp.Name}: {ex.Message}"); }
                }
            });

            _bulkSeverity = fail == 0 ? Severity.Success : (ok > 0 ? Severity.Warning : Severity.Error);
            _bulkResult = $"Generated {ok} / {emps.Count} Form 16 files → {folder}";
            if (fail > 0) _bulkResult += $"\n\nFailed ({fail}):\n{errors}";
        }
        catch (Exception ex) { _bulkResult = "Error: " + ErrorTranslator.UserFriendly(ex); _bulkSeverity = Severity.Error; }
        _generating = false;
    }

    void OpenForm16Folder()
    {
        try { FolderManager.OpenFolder(FolderManager.Form16ForFyFolder(AppState.CurrentFY)); } catch { }
    }
}
