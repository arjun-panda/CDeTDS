@page "/excel"
@inject AppStateService AppState
@inject TdsEntryService EntrySvc
@inject DeducteeService DeducteeSvc
@inject ChallanService ChallanSvc
@inject PayrollService PayrollSvc
@inject ISnackbar Snackbar
@using System.IO
@using TDSPro.DAL.Models

<div class="d-flex align-center gap-3 mb-4">
    <MudText Typo="Typo.h5">Import / Export</MudText>
    <MudSpacer />
    <MudText Typo="Typo.caption" Color="Color.Secondary">FY @AppState.CurrentFY · @AppState.CurrentDeductorName</MudText>
</div>

<MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="import-tab-panel">

    @* ── IMPORT ── *@
    <MudTabPanel Text="Import Data" Icon="@Icons.Material.Filled.Upload">
        <div style="display:flex;flex-direction:column;gap:10px;padding-bottom:24px">

            @* TDS Entries *@
            <div style="border:1px solid #e0e0e0;border-left:4px solid #1565C0;border-radius:8px;padding:12px 16px">
                <div style="display:flex;align-items:flex-start;gap:12px;flex-wrap:wrap">
                    <div style="display:flex;align-items:center;gap:8px;min-width:200px">
                        <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Primary" Size="Size.Small" />
                        <span style="font-weight:600;font-size:14px">TDS Entries</span>
                    </div>
                    <div style="flex:1;min-width:260px;font-size:12px;color:#666;line-height:1.6">
                        Date · TAN · PAN · Section · Amount · Rate · FY · Quarter. Unknown deductees are auto-created from PAN.
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                        <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick='() => DownloadTemplate("entries")'>Template</MudButton>
                        <FilePicker @bind-Value="_entriesFilePath" Title="Select TDS Entries Excel" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Upload"
                                   OnClick="ImportEntries" Disabled="@(AppState.IsReadOnlyFY || _importing || string.IsNullOrEmpty(_entriesFilePath))">
                            @if (_importing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                            Import
                        </MudButton>
                    </div>
                </div>
                @ResultAlert(_entryResult, "entries")
            </div>

            @* Deductees *@
            <div style="border:1px solid #e0e0e0;border-left:4px solid #7b1fa2;border-radius:8px;padding:12px 16px">
                <div style="display:flex;align-items:flex-start;gap:12px;flex-wrap:wrap">
                    <div style="display:flex;align-items:center;gap:8px;min-width:200px">
                        <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Secondary" Size="Size.Small" />
                        <span style="font-weight:600;font-size:14px">Deductee Master</span>
                    </div>
                    <div style="flex:1;min-width:260px;font-size:12px;color:#666;line-height:1.6">
                        Name · PAN · Section · Rate · Type · Resident. Type and rate auto-detected from PAN if blank.
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                        <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick='() => DownloadTemplate("deductees")'>Template</MudButton>
                        <FilePicker @bind-Value="_deducteesFilePath" Title="Select Deductee Master Excel" />
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Upload"
                                   OnClick="ImportDeductees" Disabled="@(_importing || string.IsNullOrEmpty(_deducteesFilePath))">
                            @if (_importing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                            Import
                        </MudButton>
                    </div>
                </div>
                @ResultAlert(_deducteeResult, "deductees")
            </div>

            @* Challans *@
            <div style="border:1px solid #e0e0e0;border-left:4px solid #2e7d32;border-radius:8px;padding:12px 16px">
                <div style="display:flex;align-items:flex-start;gap:12px;flex-wrap:wrap">
                    <div style="display:flex;align-items:center;gap:8px;min-width:200px">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Success" Size="Size.Small" />
                        <span style="font-weight:600;font-size:14px">Challans (ITNS 281)</span>
                    </div>
                    <div style="flex:1;min-width:260px;font-size:12px;color:#666;line-height:1.6">
                        BSR Code · Date · Challan No · Section · Quarter · TDS Amount. Upsert by BSR + Challan No + Date.
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                        <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick='() => DownloadTemplate("challans")'>Template</MudButton>
                        <FilePicker @bind-Value="_challansFilePath" Title="Select Challans Excel" />
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Upload"
                                   OnClick="ImportChallans" Disabled="@(AppState.IsReadOnlyFY || _importing || string.IsNullOrEmpty(_challansFilePath))">
                            @if (_importing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                            Import
                        </MudButton>
                    </div>
                </div>
                @ResultAlert(_challanResult, "challans")
            </div>

            @* Employees *@
            <div style="border:1px solid #e0e0e0;border-left:4px solid #e65100;border-radius:8px;padding:12px 16px">
                <div style="display:flex;align-items:flex-start;gap:12px;flex-wrap:wrap">
                    <div style="display:flex;align-items:center;gap:8px;min-width:200px">
                        <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Warning" Size="Size.Small" />
                        <span style="font-weight:600;font-size:14px">Employee Master (24Q)</span>
                    </div>
                    <div style="flex:1;min-width:260px;font-size:12px;color:#666;line-height:1.6">
                        Name · PAN · Code · Designation · Salary structure. Upsert by PAN. Salary structure auto-created if Basic provided.
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                        <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick='() => DownloadTemplate("employees")'>Template</MudButton>
                        <FilePicker @bind-Value="_employeesFilePath" Title="Select Employee Master Excel" />
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Upload"
                                   OnClick="ImportEmployees" Disabled="@(_importing || string.IsNullOrEmpty(_employeesFilePath))">
                            @if (_importing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                            Import
                        </MudButton>
                    </div>
                </div>
                @ResultAlert(_employeeResult, "employees")
            </div>

            @* TRACES Conso File *@
            <div style="border:1px solid #e0e0e0;border-left:4px solid #37474f;border-radius:8px;padding:12px 16px">
                <div style="display:flex;align-items:flex-start;gap:12px;flex-wrap:wrap">
                    <div style="display:flex;align-items:center;gap:8px;min-width:200px">
                        <MudIcon Icon="@Icons.Material.Filled.CloudDownload" Size="Size.Small" />
                        <span style="font-weight:600;font-size:14px">TRACES Conso File</span>
                    </div>
                    <div style="flex:1;min-width:260px;font-size:12px;color:#666;line-height:1.6">
                        Import consolidated .tds/.txt file from TRACES portal for correction filing. Auto-creates challans, deductees and TDS entries.
                        <div style="margin-top:6px;background:#fff8e1;border:1px solid #f59e0b;border-radius:4px;padding:5px 8px;color:#78350f;font-size:11px;line-height:1.6">
                            ⚠ <b>Before importing:</b> A backup is taken automatically.
                            Existing challans are updated (not duplicated) using BSR+ChallanNo+Date as key.
                            Existing TDS entries are matched by deductee+date+section+amount — if you already entered
                            the same entry manually with a different amount, a duplicate may be created.
                            Review TDS Entries after import and delete any duplicates.
                        </div>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                        <FilePicker @bind-Value="_consoFilePath" Title="Select TRACES Conso File"
                                    Filter="TRACES Files|*.tds;*.txt|All Files|*.*" />
                        <MudButton Variant="Variant.Filled" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Upload"
                                   OnClick="ImportConso" Disabled="@(AppState.IsReadOnlyFY || _importing || string.IsNullOrEmpty(_consoFilePath))">
                            @if (_importing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                            Import
                        </MudButton>
                    </div>
                </div>
                @if (_consoFilePath.EndsWith(".tds", StringComparison.OrdinalIgnoreCase))
                {
                    <div style="margin-top:8px">
                        <MudTextField @bind-Value="_consoPassword" Label="ZIP Password" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Class="upper-field" Style="max-width:400px"
                                      InputType="@(_showConsoPass ? InputType.Text : InputType.Password)"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(_showConsoPass ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                      OnAdornmentClick="() => _showConsoPass = !_showConsoPass"
                                      HelperText="Format: TAN_RequestNumber  e.g. DELI03886B_86528" />
                    </div>
                }
                @if (_consoResult != null)
                {
                    <MudAlert Severity="@(_consoResult.Success ? Severity.Success : Severity.Error)" Class="mt-2" Dense="true">
                        @_consoResult.Message
                    </MudAlert>
                    @if (_consoResult.Success)
                    {
                        <div style="font-size:12px;margin-top:4px;color:#1e6b3c">
                            Form: @_consoResult.FormType | @_consoResult.Quarter | FY @_consoResult.FY &nbsp;·&nbsp;
                            Challans: @_consoResult.ChallansImported &nbsp;·&nbsp;
                            Deductees: @_consoResult.DeducteesImported &nbsp;·&nbsp;
                            Entries: @_consoResult.EntriesImported
                            @if (_consoResult.DeducteesSkipped > 0)
                            { <span style="color:#7f4f00"> · @_consoResult.DeducteesSkipped skipped</span> }
                        </div>
                    }
                    @if (_consoResult.Warnings.Any())
                    {
                        <div style="max-height:80px;overflow-y:auto;font-size:11px;margin-top:4px">
                            @foreach (var w in _consoResult.Warnings) { <div style="color:#7f4f00">⚠ @w</div> }
                        </div>
                    }
                    @if (_consoResult.Errors.Any())
                    {
                        <div style="max-height:80px;overflow-y:auto;font-size:11px;margin-top:4px">
                            @foreach (var e in _consoResult.Errors) { <div style="color:#990000">✕ @e</div> }
                        </div>
                    }
                }
            </div>

        </div>
    </MudTabPanel>

    @* ── EXPORT ── *@
    <MudTabPanel Text="Export Data" Icon="@Icons.Material.Filled.Download">
        <div style="display:flex;flex-direction:column;gap:10px;padding-bottom:24px">

            <div style="border:1px solid #e0e0e0;border-left:4px solid #1565C0;border-radius:8px;padding:12px 16px">
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                    <div style="display:flex;align-items:center;gap:8px;min-width:200px">
                        <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Primary" Size="Size.Small" />
                        <span style="font-weight:600;font-size:14px">TDS Entries</span>
                    </div>
                    <div style="flex:1;min-width:260px;font-size:12px;color:#666">All entries · FY @AppState.CurrentFY</div>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.TableChart"
                               OnClick="ExportEntries" Disabled="_exporting">Export Excel</MudButton>
                </div>
            </div>

            <div style="border:1px solid #e0e0e0;border-left:4px solid #7b1fa2;border-radius:8px;padding:12px 16px">
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                    <div style="display:flex;align-items:center;gap:8px;min-width:200px">
                        <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Secondary" Size="Size.Small" />
                        <span style="font-weight:600;font-size:14px">Deductees</span>
                    </div>
                    <div style="flex:1;min-width:260px;font-size:12px;color:#666">Full deductee master</div>
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.TableChart"
                               OnClick="ExportDeductees" Disabled="_exporting">Export Excel</MudButton>
                </div>
            </div>

            <div style="border:1px solid #e0e0e0;border-left:4px solid #2e7d32;border-radius:8px;padding:12px 16px">
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                    <div style="display:flex;align-items:center;gap:8px;min-width:200px">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Success" Size="Size.Small" />
                        <span style="font-weight:600;font-size:14px">Challans</span>
                    </div>
                    <div style="flex:1;min-width:260px;font-size:12px;color:#666">All challans · FY @AppState.CurrentFY</div>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.TableChart"
                               OnClick="ExportChallans" Disabled="_exporting">Export Excel</MudButton>
                </div>
            </div>

            <div style="border:1px solid #e0e0e0;border-left:4px solid #e65100;border-radius:8px;padding:12px 16px">
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                    <div style="display:flex;align-items:center;gap:8px;min-width:200px">
                        <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Warning" Size="Size.Small" />
                        <span style="font-weight:600;font-size:14px">Employees</span>
                    </div>
                    <div style="flex:1;min-width:260px;font-size:12px;color:#666">Employee master with salary structure</div>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.TableChart"
                               OnClick="ExportEmployees" Disabled="_exporting">Export Excel</MudButton>
                </div>
            </div>

            <div style="border:1px solid #e0e0e0;border-left:4px solid #00467F;border-radius:8px;padding:12px 16px">
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                    <div style="display:flex;align-items:center;gap:8px;min-width:200px">
                        <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Color="Color.Info" Size="Size.Small" />
                        <span style="font-weight:600;font-size:14px">Tally Format</span>
                    </div>
                    <div style="flex:1;min-width:260px;font-size:12px;color:#666">Journal entries for Tally import</div>
                    <MudButton Variant="Variant.Filled" Color="Color.Info" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.TableChart"
                               OnClick="ExportTally" Disabled="_exporting">Export Tally</MudButton>
                </div>
            </div>

            <div style="border:1px solid #e0e0e0;border-left:4px solid #555;border-radius:8px;padding:12px 16px">
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                    <div style="display:flex;align-items:center;gap:8px;min-width:200px">
                        <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" />
                        <span style="font-weight:600;font-size:14px">Export Folder</span>
                    </div>
                    <div style="flex:1;min-width:260px;font-size:12px;color:#666">Open folder where all exported files are saved</div>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.FolderOpen"
                               OnClick="OpenExportFolder">Open Folder</MudButton>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_exportMsg))
            {
                <MudAlert Severity="@_exportSeverity" Dense="true">@_exportMsg</MudAlert>
            }

        </div>
    </MudTabPanel>

    @* ── YEAR-END TRANSFER ── *@
    <MudTabPanel Text="Year-End Transfer" Icon="@Icons.Material.Filled.SwapHoriz">
        <MudGrid Spacing="3" Justify="Justify.Center">
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-6" Elevation="2" Style="border-radius:12px">
                    <MudText Typo="Typo.h6" Class="mb-1">Year-End Data Transfer</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                        Sets the active financial year to the new FY. All deductees and employees carry forward automatically.
                        Prior year entries and challans are preserved and accessible via the FY filter — nothing is deleted.
                        Tax declarations are reset so employees can submit fresh declarations for the new year.
                    </MudText>

                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <MudSelect @bind-Value="_yearEndFrom" Label="Archive Year (From)" Variant="Variant.Outlined">
                                @foreach (var fy in AppConstants.FinancialYears)
                                { <MudSelectItem Value="@fy">@fy</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6">
                            <MudSelect @bind-Value="_yearEndTo" Label="New Active Year (To)" Variant="Variant.Outlined">
                                @foreach (var fy in AppConstants.FinancialYears)
                                { <MudSelectItem Value="@fy">@fy</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>

                    <MudAlert Severity="Severity.Warning" Class="mt-3 mb-3" Dense="true">
                        This will switch the active FY for <b>@AppState.CurrentDeductorName</b> from <b>@_yearEndFrom</b> to <b>@_yearEndTo</b>.
                        All prior data remains intact. Tax declarations for @_yearEndTo will be cleared for fresh submission.
                    </MudAlert>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium"
                               StartIcon="@Icons.Material.Filled.SwapHoriz"
                               OnClick="DoYearEndTransfer" Disabled="_transferring || _yearEndFrom == _yearEndTo">
                        @if (_transferring) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Transfer to @_yearEndTo
                    </MudButton>

                    @if (_yearEndResult != null)
                    {
                        <MudAlert Severity="@(_yearEndResult.Success ? Severity.Success : Severity.Error)" Class="mt-3">
                            @_yearEndResult.Message
                        </MudAlert>
                        @if (_yearEndResult.Success)
                        {
                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="6" sm="3">
                                    <MudPaper Class="pa-3 text-center" Elevation="0" Style="background:#f0fdf4;border-radius:8px">
                                        <MudText Typo="Typo.h5" Style="color:#166534">@_yearEndResult.DeducteesCarried</MudText>
                                        <MudText Typo="Typo.caption">Deductees Carried</MudText>
                                    </MudPaper>
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudPaper Class="pa-3 text-center" Elevation="0" Style="background:#f0fdf4;border-radius:8px">
                                        <MudText Typo="Typo.h5" Style="color:#166534">@_yearEndResult.EmployeesCarried</MudText>
                                        <MudText Typo="Typo.caption">Employees Carried</MudText>
                                    </MudPaper>
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudPaper Class="pa-3 text-center" Elevation="0" Style="background:#fff7ed;border-radius:8px">
                                        <MudText Typo="Typo.h5" Style="color:#9a3412">@_yearEndResult.EntriesArchived</MudText>
                                        <MudText Typo="Typo.caption">Entries Archived</MudText>
                                    </MudPaper>
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudPaper Class="pa-3 text-center" Elevation="0" Style="background:#fff7ed;border-radius:8px">
                                        <MudText Typo="Typo.h5" Style="color:#9a3412">@_yearEndResult.ChallansArchived</MudText>
                                        <MudText Typo="Typo.caption">Challans Archived</MudText>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>
                        }
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* ── TEMPLATES ── *@
    <MudTabPanel Text="Templates" Icon="@Icons.Material.Filled.Help">
        <div style="display:flex;flex-direction:column;gap:10px;padding-bottom:24px">

            <div style="border:1px solid #1565C0;border-radius:8px;padding:10px 16px;background:#e3f2fd;font-size:13px;color:#1565C0">
                Download blank Excel templates with sample rows and instructions. Delete the sample row (row 2) before importing.
            </div>

            @foreach (var t in _templates)
            {
                <div style="border:1px solid #e0e0e0;border-left:4px solid #1565C0;border-radius:8px;padding:12px 16px">
                    <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                        <div style="display:flex;align-items:center;gap:8px;min-width:200px">
                            <MudIcon Icon="@Icons.Material.Filled.TableChart" Color="Color.Primary" Size="Size.Small" />
                            <span style="font-weight:600;font-size:14px">@t.Name</span>
                        </div>
                        <div style="flex:1;min-width:260px;font-size:12px;color:#666">@t.Desc</div>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick="() => DownloadTemplate(t.Key)">Download</MudButton>
                    </div>
                </div>
            }

            <div style="border:1px solid #e0e0e0;border-left:4px solid #555;border-radius:8px;padding:12px 16px 20px;background:#fafafa">
                <div style="font-weight:600;font-size:14px;margin-bottom:8px">Import Rules</div>
                <div style="display:flex;flex-direction:column;gap:4px;font-size:12px;color:#555">
                    <div>▸ Dates: <b>dd-MM-yyyy</b> preferred (e.g. 31-03-2026). Also accepts dd/MM/yyyy and d-M-yyyy.</div>
                    <div>▸ PAN: exactly 10 chars, format ABCDE1234F.</div>
                    <div>▸ Deductee type and TDS rate are <b>auto-detected from PAN</b> if left blank.</div>
                    <div>▸ Deductees missing from master are <b>auto-created</b> during TDS Entries import.</div>
                    <div>▸ Challan upsert key: BSR Code + Challan No + Date.</div>
                    <div>▸ Employee upsert key: PAN (per deductor).</div>
                    <div>▸ Amount columns: numeric values. ₹ symbol and commas are stripped automatically.</div>
                    <div>▸ Yellow sample row is <b>auto-skipped</b> — no need to delete it manually.</div>
                    <div>▸ No row limit — import as many rows as needed.</div>
                </div>
            </div>

        </div>
    </MudTabPanel>

</MudTabs>

@code {
    private string _entriesFilePath   = "";
    private string _deducteesFilePath = "";
    private string _challansFilePath  = "";
    private string _employeesFilePath = "";
    private string _consoFilePath     = "";
    private string _consoPassword     = "";
    private bool   _showConsoPass;

    private bool _importing;
    private bool _exporting;
    private bool _transferring;

    private ImportResult?      _entryResult;
    private ImportResult?      _deducteeResult;
    private ImportResult?      _challanResult;
    private ImportResult?      _employeeResult;
