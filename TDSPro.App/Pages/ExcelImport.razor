    async Task DoYearEndTransfer()
    {
        if (_yearEndFrom == _yearEndTo) { Snackbar.Add("From and To FY must be different.", Severity.Warning); return; }
        if (!string.IsNullOrEmpty(AppState.SessionFY) && _yearEndTo != AppState.SessionFY)
        {
            Snackbar.Add($"Transfer target must be your logged-in FY ({AppState.SessionFY}). Log out and log in to FY {_yearEndTo} to import there.", Severity.Warning);
            return;
        }
        _transferring = true; _yearEndResult = null; StateHasChanged();
        try
        {
            var r = await Task.Run(() => ExcelEngine.TransferYearEnd(AppState.CurrentDeductorId, _yearEndFrom, _yearEndTo));
            _yearEndResult = r;
            if (r.Success)
            {
                AppState.SetFY(_yearEndTo);
                Snackbar.Add($"Viewing FY {_yearEndTo}. To edit, log out and log in selecting FY {_yearEndTo}.", Severity.Info);
            }
            else Snackbar.Add(r.Message, Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add("Transfer failed: " + ex.Message, Severity.Error); }
        _transferring = false;
    }

    bool ValidatePath(string path)
    {
        if (string.IsNullOrWhiteSpace(path)) { Snackbar.Add("Please select a file first.", Severity.Warning); return false; }
        if (!File.Exists(path)) { Snackbar.Add($"File not found: {path}", Severity.Error); return false; }
        return true;
    }

    string TimestampedPath(string name)
    {
        Directory.CreateDirectory(FolderManager.ExportsFolder);
        return Path.Combine(FolderManager.ExportsFolder, $"{name}_{DateTime.Now:yyyyMMdd_HHmm}.xlsx");
    }
