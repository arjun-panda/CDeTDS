    protected override void OnInitialized()
    {
        var fys = AppConstants.FinancialYears;
        _yearEndFrom = AppState.CurrentFY;
        var idx = Array.IndexOf(fys, AppState.CurrentFY);
        _yearEndTo = idx >= 0 && idx + 1 < fys.Length ? fys[idx + 1] : AppState.CurrentFY;
    }

    private readonly Dictionary<string, bool> _showErrors = new();

    private RenderFragment ResultAlert(ImportResult? r, string key = "") => __builder =>
    {
        if (r == null) return;

        // Summary alert
        __builder.OpenComponent<MudAlert>(0);
        __builder.AddAttribute(1, "Severity", r.HasErrors ? (r.SuccessCount > 0 ? Severity.Warning : Severity.Error) : Severity.Success);
        __builder.AddAttribute(2, "Class", "mt-2");
        __builder.AddAttribute(3, "Dense", true);
        __builder.AddAttribute(4, "ChildContent", (RenderFragment)(__b => __b.AddContent(5, r.Summary)));
        __builder.CloseComponent();

        if (r.Errors.Any())
        {
            var rowErrors   = r.Errors.Where(e => System.Text.RegularExpressions.Regex.IsMatch(e, @"^Row \d+:")).ToList();
            var otherErrors = r.Errors.Where(e => !System.Text.RegularExpressions.Regex.IsMatch(e, @"^Row \d+:")).ToList();
            var autoCreated = r.Errors.Where(e => e.Contains("auto-created")).ToList();
            var realErrors  = r.Errors.Where(e => !e.Contains("auto-created")).ToList();

            bool expanded = _showErrors.TryGetValue(key, out var v) ? v : false;
            string toggleLabel = expanded ? "▲ Hide details" : $"▼ Show {r.Errors.Count} detail(s)";

            // Toggle link
            __builder.OpenElement(10, "div");
            __builder.AddAttribute(11, "style", "margin-top:4px;font-size:11px");

            if (autoCreated.Any())
            {
                __builder.OpenElement(12, "span");
                __builder.AddAttribute(13, "style", "color:#b45309;margin-right:8px");
                __builder.AddContent(14, $"⚠ {autoCreated.Count} auto-created");
                __builder.CloseElement();
            }
            if (realErrors.Any())
            {
                __builder.OpenElement(15, "span");
                __builder.AddAttribute(16, "style", "color:#c62828;margin-right:8px");
                __builder.AddContent(17, $"✕ {realErrors.Count} error(s)");
                __builder.CloseElement();
            }

            __builder.OpenElement(18, "a");
            __builder.AddAttribute(19, "style", "cursor:pointer;color:#1565C0;text-decoration:underline");
            __builder.AddAttribute(20, "onclick", EventCallback.Factory.Create(this, () =>
            {
                _showErrors[key] = !(_showErrors.TryGetValue(key, out var cur) && cur);
                StateHasChanged();
            }));
            __builder.AddContent(21, toggleLabel);
            __builder.CloseElement();
            __builder.CloseElement(); // div

            if (expanded)
            {
                __builder.OpenElement(22, "div");
                __builder.AddAttribute(23, "style", "max-height:160px;overflow-y:auto;font-size:11px;margin-top:4px;border:1px solid #e0e0e0;border-radius:4px;padding:4px 8px;background:#fafafa");
                int seq = 24;
                foreach (var e in r.Errors)
                {
                    bool isInfo = e.Contains("auto-created");
                    __builder.OpenElement(seq++, "div");
                    __builder.AddAttribute(seq++, "style", isInfo ? "color:#b45309;padding:1px 0" : "color:#c62828;padding:1px 0");
                    __builder.AddContent(seq++, isInfo ? "ℹ " + e : "✕ " + e);
                    __builder.CloseElement();
                }
                __builder.CloseElement();
            }
        }
    };

    private record TemplateInfo(string Key, string Name, string Desc);
