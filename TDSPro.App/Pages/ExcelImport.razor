    async Task ImportConso()
    {
        if (!ValidatePath(_consoFilePath)) return;
        _importing = true; _consoResult = null; StateHasChanged();
        try
        {
            // Auto-backup before import so user can restore if import creates duplicates
            await Task.Run(() => { try { TDSPro.DAL.FolderManager.BackupNow(TDSPro.DAL.Database.DbPath); } catch { } });
            var password = _consoFilePath.EndsWith(".tds", StringComparison.OrdinalIgnoreCase)
                ? _consoPassword.Trim()
                : null;
            var r = await Task.Run(() => ConsoImporter.Import(_consoFilePath, zipPassword: password));
            _consoResult = r;
            Snackbar.Add(r.Message, r.Success ? Severity.Success : Severity.Error);
            if (r.Success) Snackbar.Add("Backup taken before import — restore from Settings → Backup & Restore if needed.", Severity.Info);
        }
        catch (Exception ex) { Snackbar.Add("Import failed: " + ex.Message, Severity.Error); }
        _importing = false;
    }

    async Task ExportEntries()
    {
