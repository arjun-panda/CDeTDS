            _exportSeverity = Severity.Success;
            FolderManager.OpenFolder(Path.GetDirectoryName(path)!);
        }
        catch (Exception ex) { _exportMsg = "Error: " + ErrorTranslator.UserFriendly(ex); _exportSeverity = Severity.Error; }
