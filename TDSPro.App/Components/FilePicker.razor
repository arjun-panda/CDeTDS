@inject FilePickerService PickerSvc
@using System.IO

<div class="d-flex align-center gap-2 mb-3">

    <div style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
                font-size:12px;background:#f5f5f5;border-radius:6px;padding:6px 10px;
                color:@(string.IsNullOrEmpty(Value) ? "#aaa" : "#333")"
         title="@Value">
        @(string.IsNullOrEmpty(Value) ? "No file selected" : Path.GetFileName(Value))
    </div>

    <MudButton Variant="Variant.Outlined" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.FolderOpen"
               OnClick="Browse">Browse</MudButton>

    @if (!string.IsNullOrEmpty(Value))
    {
        <MudIconButton Icon="@Icons.Material.Filled.Clear" Size="Size.Small"
                       OnClick="Clear" />
    }

</div>

@if (!string.IsNullOrEmpty(Value))
{
    <div style="font-size:11px;color:#888;margin-bottom:8px;word-break:break-all">@Value</div>
}

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Filter { get; set; } = "Excel Files|*.xlsx|All Files|*.*";
    [Parameter] public string Title  { get; set; } = "Select file";

    void Browse()
    {
        var picked = PickerSvc.PickFile(Title, Filter);
        if (picked != null)
            ValueChanged.InvokeAsync(picked);
    }

    void Clear() => ValueChanged.InvokeAsync("");
}
