@inject DeductorService    DeductorSvc
@inject PayrollService     PayrollSvc
@inject AppStateService    AppState
@inject ISnackbar          Snackbar
@inject NavigationManager  Nav

<MudDialog @bind-Visible="_open" Options="@(new DialogOptions { MaxWidth=MaxWidth.Medium, FullWidth=true, NoHeader=false, CloseButton=false })">
    <TitleContent>
        <MudText Typo="Typo.h6">🎉 Welcome to CDeTDS — let's get you set up</MudText>
    </TitleContent>
    <DialogContent>
        <MudStepper @bind-ActiveIndex="_step" NonLinear="false">
            <ChildContent>

                @* ── STEP 1: Company / Deductor ── *@
                <MudStep Title="Your Company">
                    <ChildContent>
                        <MudText Class="mb-3">First, tell us about your company (the deductor).</MudText>
                        <MudGrid>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="_ded.CompanyName" Label="Company Name *" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="_ded.Tan" Label="TAN * (10 chars)" Variant="Variant.Outlined" MaxLength="10" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="_ded.Pan" Label="Company PAN" Variant="Variant.Outlined" MaxLength="10" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="_ded.Email" Label="Email" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_ded.Address" Label="Address" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="4">
                                <MudTextField @bind-Value="_ded.City" Label="City" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="4">
                                <MudSelect @bind-Value="_ded.State" Label="State" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                                    @foreach (var s in AppConstants.IndianStates)
                                    { <MudSelectItem Value="@s">@s</MudSelectItem> }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="4">
                                <MudTextField @bind-Value="_ded.Pincode" Label="PIN" Variant="Variant.Outlined" MaxLength="6" />
                            </MudItem>
                        </MudGrid>
                        @if (!string.IsNullOrEmpty(_stepError))
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">@_stepError</MudAlert>
                        }
                    </ChildContent>
                </MudStep>

                @* ── STEP 2: First Employee ── *@
                <MudStep Title="First Employee">
                    <ChildContent>
                        <MudText Class="mb-3">Add one employee now so you can try Salary Data right away. Skip this step if you'll add employees later.</MudText>
                        <MudGrid>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="_emp.EmployeeCode" Label="Employee Code *" Variant="Variant.Outlined" Placeholder="EMP-001" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="_emp.Name" Label="Full Name *" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="_emp.Pan" Label="PAN * (10 chars)" Variant="Variant.Outlined" MaxLength="10" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="_empDob" Label="Date of Birth (dd-MMM-yyyy)" Variant="Variant.Outlined" Placeholder="15-Jan-1990" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="_empJoin" Label="Date of Joining (dd-MMM-yyyy)" Variant="Variant.Outlined" Placeholder="01-Apr-2024" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudSelect T="string" @bind-Value="_emp.TaxRegime" Label="Tax Regime" Variant="Variant.Outlined">
                                    <MudSelectItem Value="@("New")">New Regime</MudSelectItem>
                                    <MudSelectItem Value="@("Old")">Old Regime</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="6">
                                <MudNumericField T="double" @bind-Value="_empBasic" Label="Monthly Basic (₹)" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudNumericField T="double" @bind-Value="_empHra" Label="Monthly HRA (₹)" Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                        @if (!string.IsNullOrEmpty(_stepError))
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">@_stepError</MudAlert>
                        }
                    </ChildContent>
                </MudStep>

                @* ── STEP 3: Done ── *@
                <MudStep Title="Done">
                    <ChildContent>
                        <div style="text-align:center;padding:20px">
                            <div style="font-size:48px;margin-bottom:12px">🎉</div>
                            <MudText Typo="Typo.h5" Class="mb-3">You're all set!</MudText>
                            <MudText Class="mb-4">Here's what to do next:</MudText>
                            <div style="display:flex;flex-direction:column;gap:10px;text-align:left;max-width:500px;margin:0 auto">
                                <MudPaper Class="pa-3" Elevation="1">
                                    <strong>1. Open Payroll → Salary Data</strong><br />
                                    <span style="color:#64748b;font-size:12px">Pick this month → fill in any per-month adjustments → Save Month</span>
                                </MudPaper>
                                <MudPaper Class="pa-3" Elevation="1">
                                    <strong>2. Approve &amp; Lock</strong><br />
                                    <span style="color:#64748b;font-size:12px">Locks the month and auto-creates a Section 192 TDS entry</span>
                                </MudPaper>
                                <MudPaper Class="pa-3" Elevation="1">
                                    <strong>3. End of quarter → Returns → 24Q</strong><br />
                                    <span style="color:#64748b;font-size:12px">Generates the FVU file ready for NSDL upload</span>
                                </MudPaper>
                            </div>
                        </div>
                    </ChildContent>
                </MudStep>
            </ChildContent>
        </MudStepper>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="SkipWizard">Skip wizard</MudButton>
        <MudSpacer />
        @if (_step > 0)
        {
            <MudButton OnClick="@(() => { _stepError = ""; _step--; })">Back</MudButton>
        }
        @if (_step < 2)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextStep" Disabled="_busy">
                @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Next
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="FinishWizard">Finish</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public EventCallback OnFinished { get; set; }

    private bool   _open  = true;
    private int    _step  = 0;
    private bool   _busy  = false;
    private string _stepError = "";

    private Deductor _ded = new() { FinancialYear = "2026-27" };
    private Employee _emp = new() { TaxRegime = "New", Sex = "Male", HraCityType = "Non-Metro" };
    private string  _empDob   = "";
    private string  _empJoin  = DateTime.Today.ToString("dd-MMM-yyyy");
    private double  _empBasic = 30000;
    private double  _empHra   = 12000;

    private int _newDeductorId = 0;

    void NextStep()
    {
        _stepError = "";
        if (_step == 0)
        {
            // Validate + save deductor
            if (string.IsNullOrWhiteSpace(_ded.CompanyName)) { _stepError = "Company Name is required."; return; }
            if (!Validators.IsValidTan(_ded.Tan))             { _stepError = "TAN must be 10 chars: 4 letters + 5 digits + 1 letter (e.g. DELA12345A)."; return; }
            if (!string.IsNullOrWhiteSpace(_ded.Pan) && !Validators.IsValidPan(_ded.Pan))
                                                              { _stepError = "PAN format invalid (e.g. ABCDE1234F)."; return; }
            _busy = true;
            try
            {
                var res = DeductorSvc.Save(_ded);
                if (!res.Ok) { _stepError = res.Msg; _busy = false; return; }
                _newDeductorId = _ded.Id;
                // Switch active deductor to the newly-created company
                AppState.SetDeductor(_newDeductorId, _ded.CompanyName, _ded.Tan);
            }
            finally { _busy = false; }
            _step++;
            return;
        }
        if (_step == 1)
        {
            // Save employee (optional — allow blank skip)
            if (string.IsNullOrWhiteSpace(_emp.EmployeeCode) &&
                string.IsNullOrWhiteSpace(_emp.Name) &&
                string.IsNullOrWhiteSpace(_emp.Pan))
            {
                // User skipped this step — just advance
                _step++;
                return;
            }
            // Otherwise validate
            if (string.IsNullOrWhiteSpace(_emp.EmployeeCode)) { _stepError = "Employee Code is required."; return; }
            if (string.IsNullOrWhiteSpace(_emp.Name))         { _stepError = "Name is required."; return; }
            if (!Validators.IsValidPan(_emp.Pan))             { _stepError = "PAN format invalid (e.g. ABCDE1234F)."; return; }
            if (!Validators.TryParseAppDate(_empDob, out _))  { _stepError = "Date of Birth is required (dd-MMM-yyyy)."; return; }
            if (!Validators.TryParseAppDate(_empJoin, out _)) { _stepError = "Date of Joining is required (dd-MMM-yyyy)."; return; }

            _busy = true;
            try
            {
                _emp.DeductorId  = _newDeductorId;
                _emp.DateOfBirth = _empDob;
                _emp.JoinDate    = _empJoin;
                _emp.Salary      = new SalaryStructure { Basic = _empBasic, Hra = _empHra };
                var res = PayrollSvc.SaveEmployee(_emp);
                if (!res.ok) { _stepError = res.msg; _busy = false; return; }
            }
            finally { _busy = false; }
            _step++;
            return;
        }
    }

    void SkipWizard()
    {
        _open = false;
        _ = OnFinished.InvokeAsync();
    }

    void FinishWizard()
    {
        _open = false;
        Snackbar.Add("Setup complete. Opening Payroll → Salary Data...", Severity.Success);
        _ = OnFinished.InvokeAsync();
        Nav.NavigateTo("/payroll");
    }
}
