    private string _faqCategory = "Returns & FVU";

    void ToggleHelp() => _helpOpen = !_helpOpen;
    void ToggleFaq(string q) => _openFaq = _openFaq == q ? "" : q;
    void RecoverError() => _errorBoundary?.Recover();

    void SendFeedback()
    {
        var machineId = TDSPro.DAL.LicenseService.GetMachineId();
        var subject   = Uri.EscapeDataString($"CDeTDS v{AppConstants.AppVersion} — Feedback / Bug Report");
        var body      = Uri.EscapeDataString(
            $"CDeTDS v{AppConstants.AppVersion}\n" +
            $"Machine ID: {machineId}\n" +
            $"FY: {AppState.CurrentFY}\n\n" +
            "--- Describe your feedback or bug ---\n\n");
        var uri = $"mailto:admin@capitaldesk.co.in?subject={subject}&body={body}";
        try { System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo(uri) { UseShellExecute = true }); }
        catch { Snackbar.Add("Please email feedback to: admin@capitaldesk.co.in", Severity.Info); }
    }

    async Task CheckForUpdates()
    {
        _updateMsg = "Checking...";
        StateHasChanged();
        var info = await UpdateSvc.CheckAsync(forceCheck: true);
        if (info != null)
        {
            _updateMsg = $"v{info.Version} available — {info.ReleaseDate}";
            ShowUpdateSnackbar(info);
        }
        else
        {
            _updateMsg = $"✅ You are on the latest version (v{AppConstants.AppVersion}).";
        }
        StateHasChanged();
    }

    void ShowUpdateSnackbar(UpdateInfo info)
    {
        Snackbar.Add(
            $"CDeTDS v{info.Version} is available! {info.Notes}",
            Severity.Info,
            cfg =>
            {
                cfg.ActionColor      = Color.Warning;
                cfg.Action           = "Download";
                cfg.ActionVariant    = Variant.Filled;
                cfg.Onclick          = _ =>
                {
                    try
                    {
                        System.Diagnostics.Process.Start(
                            new System.Diagnostics.ProcessStartInfo(info.DownloadUrl)
                            { UseShellExecute = true });
                    }
                    catch { }
                    return Task.CompletedTask;
                };
                cfg.VisibleStateDuration = 12000;
            });
    }

    protected override void OnInitialized()
    {
        AppState.OnChange += OnStateChanged;
        Nav.LocationChanged += OnLocationChanged;
        if (!AppState.IsLoggedIn)
            Nav.NavigateTo("/login");
        else
            EnforceExpiry();
        _clock = DateTime.Now.ToString("ddd dd-MMM HH:mm");
        _timer = new System.Threading.Timer(_ =>
        {
            _clock = DateTime.Now.ToString("ddd dd-MMM HH:mm");
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !AppState.IsLoggedIn) return;
        // Background update check — shows snackbar if newer version found
        var info = await UpdateSvc.CheckAsync();
        if (info != null) ShowUpdateSnackbar(info);
    }

    void OnStateChanged() { EnforceExpiry(); StateHasChanged(); }

    void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        EnforceExpiry();
        JS.InvokeVoidAsync("window.tdspro.scrollToTop");
    }

    void EnforceExpiry()
    {
        if (!AppState.IsLoggedIn) return;
        if (!AppState.CurrentLicense.IsExpired) return;
        var uri = Nav.ToBaseRelativePath(Nav.Uri);
        if (uri != "activate")
            Nav.NavigateTo("/activate", forceLoad: false);
    }

    async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    void OnFYChanged(string fy) => AppState.SetFY(fy);

    async Task OpenCompanySelector()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        await DialogSvc.ShowAsync<CompanySelector>("", options);
    }

    void Logout()
    {
        AppState.Logout();
        Nav.NavigateTo("/login", forceLoad: false);
    }

    public void Dispose()
    {
        AppState.OnChange -= OnStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
        _timer?.Dispose();
    }
}
