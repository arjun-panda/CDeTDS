@using TDSPro.DAL
@using TDSPro.Common

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Primary" />
            <MudText Typo="Typo.h6">TDS Pro — End User License Agreement</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Please read and accept the license agreement to use TDS Pro.
        </MudAlert>

        <div style="height:340px;overflow-y:auto;border:1px solid #e0e0e0;border-radius:6px;padding:16px 20px;font-size:13px;line-height:1.7;color:#333;background:#fafafa">

            <p style="font-weight:700;font-size:15px;margin-bottom:12px">TDS PRO SOFTWARE LICENSE AGREEMENT</p>
            <p style="color:#555;margin-bottom:16px">Effective Date: Upon Installation &nbsp;|&nbsp; Version @AppConstants.AppVersion and above</p>

            <p><b>1. GRANT OF LICENSE</b><br/>
            TDS Pro Software grants you a non-exclusive, non-transferable license to install and use this software on a single machine for which a valid license key has been issued. Trial licenses are limited to 30 days and 1 deductor.</p>

            <p><b>2. RESTRICTIONS</b><br/>
            You may not: (a) copy, modify, or distribute the software; (b) reverse-engineer, decompile, or disassemble the software; (c) rent, lease, or lend the software; (d) use the software to process data for third parties without a multi-user license; (e) remove any proprietary notices or labels.</p>

            <p><b>3. DATA AND PRIVACY</b><br/>
            All your TDS data is stored locally on your computer. TDS Pro does not transmit your financial data to any server. The software may check for version updates by connecting to capitaldesk.co.in. No personal or financial data is sent during update checks.</p>

            <p><b>4. COMPLIANCE</b><br/>
            This software is designed to assist in TDS compliance under the Income-tax Act. TDS Pro Software does not guarantee that use of this software will result in compliance with all applicable laws. You remain solely responsible for ensuring your TDS filings are accurate and timely.</p>

            <p><b>5. DISCLAIMER OF WARRANTIES</b><br/>
            THE SOFTWARE IS PROVIDED "AS IS" WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED. TDS PRO SOFTWARE DOES NOT WARRANT THAT THE SOFTWARE WILL BE ERROR-FREE OR THAT IT WILL MEET YOUR SPECIFIC REQUIREMENTS.</p>

            <p><b>6. LIMITATION OF LIABILITY</b><br/>
            IN NO EVENT SHALL TDS PRO SOFTWARE BE LIABLE FOR ANY INDIRECT, INCIDENTAL, SPECIAL, EXEMPLARY, OR CONSEQUENTIAL DAMAGES (INCLUDING LOSS OF DATA, BUSINESS INTERRUPTION, OR PENALTIES IMPOSED BY TAX AUTHORITIES) ARISING OUT OF THE USE OR INABILITY TO USE THIS SOFTWARE.</p>

            <p><b>7. TERM AND TERMINATION</b><br/>
            This license is effective until terminated. It will terminate automatically if you fail to comply with any term of this agreement. Upon termination, you must destroy all copies of the software.</p>

            <p><b>8. GOVERNING LAW</b><br/>
            This agreement shall be governed by the laws of India. Any disputes shall be subject to the exclusive jurisdiction of the courts of New Delhi, India.</p>

            <p><b>9. CONTACT</b><br/>
            TDS Pro Software &nbsp;|&nbsp; Email: admin@capitaldesk.co.in &nbsp;|&nbsp; Website: capitaldesk.co.in</p>

            <p style="color:#1565C0;font-weight:600;margin-top:16px">
                By clicking "I Accept", you confirm that you have read, understood and agree to all the terms above.
            </p>
        </div>

        <div class="d-flex align-center gap-2 mt-3">
            <MudCheckBox @bind-Value="_accepted" Color="Color.Primary" />
            <MudText Typo="Typo.body2">
                I have read and agree to the <b>TDS Pro End User License Agreement</b>
            </MudText>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Decline">
            Decline &amp; Exit
        </MudButton>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="!_accepted" OnClick="Accept">
            I Accept
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    private bool _accepted = false;

    void Accept()
    {
        Database.SetSetting("EULA_ACCEPTED", DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"));
        Database.SetSetting("EULA_VERSION",  AppConstants.AppVersion);
        MudDialog.Close(DialogResult.Ok(true));
    }

    void Decline()
    {
        MudDialog.Close(DialogResult.Cancel());
        // BeginInvoke avoids deadlock — Blazor render thread must not block on Dispatcher.Invoke
        System.Windows.Application.Current.Dispatcher.BeginInvoke(() =>
            System.Windows.Application.Current.Shutdown(0));
    }
}
