# Build output
bin/
obj/

# Publish artifacts
publish/
publish_out/
publish_output/
installer_output/
# Guard: stray project-local publish folders (e.g. CDeTDS.App\publish) that
# self-nest and poison `dotnet publish -o publish_out` with old binaries.
**/publish/

# User-specific
*.user
*.suo
.vs/
.vscode/launch.json

# OS
Thumbs.db
desktop.ini

# Demo/dev files
demo_*.html
DEPLOYMENT_GUIDE.txt

# Legacy WinForms project
TDSPro.UI/

# SQLite databases
*.db
*.db-shm
*.db-wal

# Logs
*.log
fvu.log

# NSDL FVU utility folder (large binary, not source)
TDS_STANDALONE_FVU_9.4/

# New-Act Beta FVU/RPU staging (large binaries, NOT shipped — source tree only).
# PaymentCodes doc kept; zips, extracts and scratch dumps ignored.
FVU_NEWACT_1.0/*.zip
FVU_NEWACT_1.0/extracted/
FVU_NEWACT_1.0/fvu_extracted/
FVU_NEWACT_1.0/fvu_unpack/
FVU_NEWACT_1.0/rpu/
FVU_NEWACT_1.0/rpu_jar/
FVU_NEWACT_1.0/rpu_codes_ordered.txt
FVU_NEWACT_1.0/rpu_o_strings.txt

# KeyGen build output + generated key log (contains issued license keys)
keygen_out/

# NSDL spec/reference files (large, not source)
*.xls
*.pdf
nsdl_*.tsv
24QRQ*.txt
26QRQ*.txt
*.fvu

# WebView2 installer (large binary)
MicrosoftEdgeWebview2Setup.exe

# IDE cache files
*.lscache

# Installer build artifacts (large binaries — run build_installer.ps1 to regenerate)
installer/AppFiles/
installer/Output/

# Bundled JRE (large binary — download separately)
installer/bundled_jre/

# Velopack build artifacts
publish_velopack/
releases_velopack/
